---
import Base from "../layouts/Base.astro";
import Aurora from "../components/Aurora.astro";
import SideRays from "../components/SideRays.astro";

const slides = [
  {
    kicker: "",
    title: "BeUniq.design",
    body: "",
    note: "",
    meta: "Side Rays",
    cover: true,
  },
  {
    kicker: "",
    title: "Помните, когда появился ChatGPT?",
    titleHtml: 'Помните, когда появился <span class="capture-word capture-word-white">ChatGPT<svg class="capture-ants" aria-hidden="true"><rect x="1.5" y="1.5"></rect></svg><span class="capture-handle capture-tl" aria-hidden="true"></span><span class="capture-handle capture-tr" aria-hidden="true"></span><span class="capture-handle capture-bl" aria-hidden="true"></span><span class="capture-handle capture-br" aria-hidden="true"></span></span>?',
    body: "Все начали писать курсовики, дипломки, эссе, домашку через ChatGPT. Для студентов стало быстрее, для проверяющего почти невозможно проверить вручную.",
    note: "",
    meta: "ChatGPT",
    fullCatch: true,
    bodyReveal: true,
  },
  {
    kicker: "",
    title: "Что было дальше?",
    body: "",
    note: "",
    meta: "After ChatGPT",
    logoReveal: true,
    revealLogos: [
      {
        name: "GPTZero",
        src: "/images/gptzero-seeklogo.png",
        metric: "$30M ARR",
      },
      {
        name: "QuillBot",
        src: "/images/quillbot-logo-transparent.png",
        metric: "~$27.4M ARR",
      },
    ],
  },
  {
    kicker: "",
    title: "История повторяется",
    body: "",
    note: "",
    meta: "Pattern",
    longTitle: true,
    statementSplit: true,
    statementImage: "/images/history-repeat.png",
    statementImageAlt: "История повторяется дважды",
  },
  {
    kicker: "",
    title: "We need a hero",
    body: "",
    note: "",
    meta: "Hero",
    longTitle: true,
    statementHero: true,
    statementImage: "/images/hero.avif",
    statementImageAlt: "Hero",
  },
  {
    kicker: "",
    title: "",
    body: "",
    note: "",
    meta: "Demo",
    video: "/videos/maindemo.mp4",
  },
  {
    kicker: "",
    title: "",
    body: "",
    note: "",
    meta: "Before / After",
    beforeAfter: true,
    beforeImage: "/images/vzyal-before.png",
    beforeImageAlt: "Before landing page screenshot",
    afterVideo: "/videos/vzyal-after.mov",
  },
  {
    kicker: "",
    title: "Моя идея понравилась\nYC фаундеры",
    titleHtml: 'Моя идея понравилась<br /><span class="yc-title-line"><span class="accent-orange">YC</span> фаундеры</span>',
    body: "",
    note: "",
    meta: "YC founders",
    ycFounders: true,
    ycImages: [
      {
        src: "/images/yc-founder-ilyas.png",
        alt: "Ilyas founder screenshot",
      },
      {
        src: "/images/yc-founder-pcstyle.png",
        alt: "pcstyle founder screenshot",
      },
      {
        src: "/images/yc-founder-yahia.png",
        alt: "Yahia Bakour founder screenshot",
      },
    ],
  },
  {
    kicker: "",
    title: "Остальные\nполюбили\nэту идею",
    body: "",
    note: "",
    meta: "Founder feedback",
    founderPraise: true,
    founderImage: "/images/founder-liked-idea.png",
    founderImageAlt: "Founder feedback screenshot",
  },
  {
    kicker: "",
    title: "270 юзеров",
    body: "1 job offer full-stack",
    note: "",
    meta: "Traction",
    traction: true,
    tractionImage: "/images/job-offer-fullstack.png",
    tractionImageAlt: "Full-stack job offer screenshot",
  },
  {
    kicker: "",
    title: "",
    body: "",
    note: "",
    meta: "About me",
    about: true,
    aboutImage: "/images/my-photo.jpg",
    aboutImageAlt: "Portrait",
    aboutLines: [
      "Гений (надеюсь)",
      "Милиардер (почти)",
      "Филантроп (вряд ли)",
    ],
  },
  {
    kicker: "",
    title: "",
    body: "",
    note: "",
    meta: "Achievements",
    achievements: true,
    achievementImages: [
      {
        src: "/images/achievements-digital-ertis.jpg",
        alt: "Digital Ertis hackathon win",
      },
      {
        src: "/images/achievements-presentation.jpg",
        alt: "Project presentation",
      },
      {
        src: "/images/achievements-enactus.jpg",
        alt: "Enactus win",
      },
      {
        src: "/images/achievements-extra.jpg",
        alt: "Achievement photo",
      },
    ],
    achievementLines: [
      "Разработчик в Flowleads",
      "Teenpreneurs Incubator",
      "StartUp: $1600 revenue",
      "Хакатоны: 7 wins",
      "Еще куча побед в научных проектах и дебатах",
    ],
  },
  {
    kicker: "",
    title: "",
    body: "",
    note: "",
    meta: "Bob",
    image: "/images/bob.jpg",
    imageAlt: "bob.jpg",
  },
];
---

<Base
  title="BeUniq Presentation"
  description="A two-minute BeUniq presentation with animated rays and numbered slides."
>
  <main class="presentation-page">
    <section id="slides" class="presentation-stage" aria-label="BeUniq presentation slides">
      <div class="aurora-layer">
        <Aurora
          colorStops={["#ffffff", "#ffffff", "#ffffff"]}
          speed={0.42}
          blend={0.44}
          amplitude={0.86}
          opacity={0.2}
        />
      </div>
      <div class="hero-ray-layer">
        <SideRays
          channel="right"
          origin="top-right"
          speed={2}
          rayColor1="#ffffff"
          rayColor2="#ffffff"
          intensity={2}
          spread={2}
          saturation={0}
          blend={0.5}
          falloff={1.5}
          opacity={0.85}
        />
      </div>
      <div class="hero-ray-layer">
        <SideRays
          channel="left"
          origin="top-left"
          speed={2}
          rayColor1="#ffffff"
          rayColor2="#ffffff"
          intensity={2}
          spread={2}
          saturation={0}
          blend={0.5}
          falloff={1.5}
          opacity={0.85}
        />
      </div>

      <div class="presentation-shell">
        <header class="presentation-top" aria-label="Presentation controls">
          <a class="brand-mark" href="/">
            <span class="brand-dot" aria-hidden="true"></span>
            <span>BeUniq</span>
          </a>
        </header>

        <div class="deck" data-deck data-total={slides.length}>
          {
            slides.map((slide, index) => (
              <article
                class:list={[
                  "slide",
                  slide.cover && "slide-cover",
                  slide.compact && "slide-compact",
                  slide.image && "slide-image",
                  slide.longTitle && "slide-long",
                  slide.productPoints && "slide-product",
                  slide.fullCatch && "slide-full-catch",
                  slide.logoReveal && "slide-logo-reveal",
                  slide.statementHero && "slide-statement-hero",
                  slide.statementSplit && "slide-statement-split",
                  slide.video && "slide-video",
                  slide.beforeAfter && "slide-before-after",
                  slide.ycFounders && "slide-yc-founders",
                  slide.founderPraise && "slide-founder-praise",
                  slide.traction && "slide-traction",
                  slide.about && "slide-about",
                  slide.achievements && "slide-achievements",
                  index === 0 && "is-active",
                ]}
                data-slide
                data-index={index}
                aria-hidden={index === 0 ? "false" : "true"}
              >
                {
                  slide.cover ? (
                    <div class="cover-mark">
                      <img src="/icon-d-light.svg" alt="BeUniq logo" />
                      <h1>{slide.title}</h1>
                    </div>
                  ) : slide.video ? (
                    <video
                      class="slide-demo-video"
                      src={slide.video}
                      loop
                      playsinline
                      preload="auto"
                    />
                  ) : slide.beforeAfter ? (
                    <div class="before-after-layout">
                      <section class="before-after-panel" aria-label="Before">
                        <span>До</span>
                        <img src={slide.beforeImage} alt={slide.beforeImageAlt || ""} />
                      </section>
                      <section class="before-after-panel" aria-label="After">
                        <span>После</span>
                        <video
                          class="before-after-video"
                          src={slide.afterVideo}
                          autoplay
                          muted
                          loop
                          playsinline
                          preload="auto"
                        />
                      </section>
                    </div>
                  ) : slide.ycFounders ? (
                    <div class="yc-founder-layout">
                      {slide.titleHtml ? <h1 set:html={slide.titleHtml} /> : <h1>{slide.title}</h1>}
                      <div class="yc-founder-collage" aria-label="YC founder screenshots">
                        {slide.ycImages.map((image, imageIndex) => (
                          <img
                            class:list={["yc-founder-shot", `yc-founder-shot-${imageIndex + 1}`]}
                            src={image.src}
                            alt={image.alt}
                          />
                        ))}
                      </div>
                    </div>
                  ) : slide.founderPraise ? (
                    <div class="founder-praise-layout">
                      <h1>{slide.title}</h1>
                      <img src={slide.founderImage} alt={slide.founderImageAlt || ""} />
                    </div>
                  ) : slide.traction ? (
                    <div class="traction-layout">
                      <section class="traction-copy" aria-label="Traction">
                        <h1>{slide.title}</h1>
                        <p>{slide.body}</p>
                      </section>
                      <img src={slide.tractionImage} alt={slide.tractionImageAlt || ""} />
                    </div>
                  ) : slide.about ? (
                    <div class="about-layout">
                      <img src={slide.aboutImage} alt={slide.aboutImageAlt || ""} />
                      <ul aria-label="About me">
                        {slide.aboutLines.map((line) => (
                          <li>{line}</li>
                        ))}
                      </ul>
                    </div>
                  ) : slide.achievements ? (
                    <div class="achievements-layout">
                      <div class="achievements-collage" aria-label="Achievement photos">
                        {slide.achievementImages.map((image, imageIndex) => (
                          <img
                            class:list={["achievement-photo", `achievement-photo-${imageIndex + 1}`]}
                            src={image.src}
                            alt={image.alt}
                          />
                        ))}
                      </div>
                      <ul aria-label="Achievements">
                        {slide.achievementLines.map((line) => (
                          <li>{line}</li>
                        ))}
                      </ul>
                    </div>
                  ) : slide.image ? (
                    <div class="slide-image-frame">
                      {slide.meta === "Bob" && (
                        <div class="bob-closing-copy">
                          <span>не будь как все</span>
                          <strong>BeUniq.</strong>
                        </div>
                      )}
                      <img src={slide.image} alt={slide.imageAlt || slide.meta} />
                    </div>
                  ) : slide.logoReveal ? (
                    <div class="logo-reveal-layout">
                      <section class="logo-reveal-catch" aria-label="Catch">
                        <h1>{slide.title}</h1>
                      </section>

                      <section class="logo-reveal-products" aria-label="Click reveals">
                        {slide.revealLogos.map((logo, stepIndex) => (
                          <div
                            class:list={["slide-step", "logo-reveal-card", stepIndex === 0 && "logo-left", stepIndex === 1 && "logo-right"]}
                            data-step
                            data-step-index={stepIndex}
                          >
                            <div class="logo-glass">
                              <img src={logo.src} alt={logo.name} />
                            </div>
                            <span>{logo.metric}</span>
                          </div>
                        ))}
                      </section>
                    </div>
                  ) : slide.longTitle ? (
                    <div class="statement-slide">
                      <h1>{slide.title}</h1>
                      {slide.statementImage && <img src={slide.statementImage} alt={slide.statementImageAlt || ""} />}
                    </div>
                  ) : (
                    <div class="story-layout">
                      <section class="catch-panel" aria-label="Catch">
                        <p class="zone-label">catch / {slide.meta}</p>
                        {
                          slide.titleHtml ? (
                            <h1 set:html={slide.titleHtml} />
                          ) : (
                            <h1>{slide.title}</h1>
                          )
                        }
                      </section>

                      <section class="info-panel" aria-label="Additional information">
                        <p class="zone-label">доп. инфа</p>
                        {
                          slide.body && slide.bodyReveal ? (
                            <div class="slide-step body-reveal-step" data-step data-step-index={0}>
                              <p class="slide-body">{slide.body}</p>
                            </div>
                          ) : (
                            slide.body && <p class="slide-body">{slide.body}</p>
                          )
                        }
                        {
                          slide.productPoints && (
                            <ol class="product-points">
                              {slide.productPoints.map((point) => (
                                <li>{point}</li>
                              ))}
                            </ol>
                          )
                        }
                        {
                          slide.reveals && slide.reveals.some((item) => item.kind !== "product") && (
                            <div class="slide-steps reveal-stack" aria-label="Click reveals">
                              {slide.reveals.map((item, stepIndex) => (
                                item.kind !== "product" && (
                                  <div
                                    class:list={["slide-step", `reveal-${item.kind}`]}
                                    data-step
                                    data-step-index={stepIndex}
                                  >
                                    <p>{item.text}</p>
                                  </div>
                                )
                              ))}
                            </div>
                          )
                        }
                      </section>

                      <section class="visual-panel" aria-label="Pictures and visuals">
                        <p class="zone-label">картинки</p>
                        {
                          slide.products && (
                            <div class="product-logos" aria-label="Products">
                              {slide.products.map((product) => (
                                <div class:list={["product-logo", `product-logo-${product.tone}`]}>
                                  <span class="product-mark">{product.mark}</span>
                                  <span class="product-name">{product.name}</span>
                                  {product.metric && <span class="product-metric">{product.metric}</span>}
                                </div>
                              ))}
                            </div>
                          )
                        }
                        {
                          slide.metric && (
                            <div class="big-metric" aria-label={slide.metricLabel}>
                              <strong>{slide.metric}</strong>
                              <span>{slide.metricLabel}</span>
                            </div>
                          )
                        }
                        {
                          slide.loop && (
                            <div class="loop-list" aria-label="Market loop">
                              {slide.loop.map((item, itemIndex) => (
                                <>
                                  <span>{item}</span>
                                  {itemIndex < slide.loop.length - 1 && <em>→</em>}
                                </>
                              ))}
                            </div>
                          )
                        }
                        {
                          slide.reveals && slide.reveals.some((item) => item.kind === "product") && (
                            <div class="visual-products" aria-label="Product visuals">
                              {slide.reveals.map((item, stepIndex) => (
                                item.kind === "product" && (
                                  <div
                                    class="slide-step reveal-product"
                                    data-step
                                    data-step-index={stepIndex}
                                  >
                                    <div class:list={["product-logo", `product-logo-${item.tone}`]}>
                                      <span class="product-mark">{item.mark}</span>
                                      <span class="product-name">{item.name}</span>
                                      {item.metric && <span class="product-metric">{item.metric}</span>}
                                    </div>
                                  </div>
                                )
                              ))}
                            </div>
                          )
                        }
                        {!slide.products && !slide.metric && !slide.loop && !slide.reveals && !slide.productPoints && (
                          <div class="visual-placeholder" aria-hidden="true">
                            <span>{String(index + 1).padStart(2, "0")}</span>
                          </div>
                        )}
                      </section>
                    </div>
                  )
                }
              </article>
            ))
          }
        </div>

        <footer class="presentation-bottom">
          <div class="slide-arrows" aria-label="Slide arrows">
            <button type="button" class="slide-arrow" data-arrow-button="previous" aria-label="Previous slide">
              ←
            </button>
            <button type="button" class="slide-arrow" data-arrow-button="next" aria-label="Next slide">
              →
            </button>
          </div>
          <div class="slide-nav" aria-label="Slide navigation">
            {
              slides.map((slide, index) => (
                <span
                  class:list={["slide-dot", index === 0 && "is-active"]}
                  data-slide-indicator={index}
                  aria-label={`Slide ${index + 1}: ${slide.meta}`}
                  aria-current={index === 0 ? "step" : undefined}
                >
                  {String(index + 1).padStart(2, "0")}
                </span>
              ))
            }
          </div>
        </footer>
      </div>

      <audio
        data-hero-audio
        src="/audio/weneedhero.mp3"
        preload="auto"
      ></audio>
    </section>
  </main>
</Base>

<script>
  const stage = document.querySelector<HTMLElement>(".presentation-stage");
  const deck = document.querySelector<HTMLElement>("[data-deck]");
  const slideEls = Array.from(document.querySelectorAll<HTMLElement>("[data-slide]"));
  const indicators = Array.from(document.querySelectorAll<HTMLElement>("[data-slide-indicator]"));
  const arrowButtons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-arrow-button]"));
  const heroAudio = document.querySelector<HTMLAudioElement>("[data-hero-audio]");
  const slideVideos = Array.from(document.querySelectorAll<HTMLVideoElement>(".slide-demo-video"));
  const loopVideos = Array.from(document.querySelectorAll<HTMLVideoElement>(".before-after-video"));
  const typeTextTargets = Array.from(
    document.querySelectorAll<HTMLElement>(
      ".slide:not(.slide-yc-founders):not(.slide-full-catch) h1, .slide .slide-body, .slide .product-points li, .slide .logo-reveal-primary p, .slide .logo-reveal-card span"
    )
  );
  const typeTimers = new WeakMap<HTMLElement, number[]>();

  const prepareTypeText = (element: HTMLElement) => {
    if (element.dataset.typePrepared === "true") return;
    element.dataset.typeText = element.textContent ?? "";
    element.dataset.typePrepared = "true";
    element.classList.add("text-type");
  };

  const clearTypeTimers = (element: HTMLElement) => {
    typeTimers.get(element)?.forEach((timer) => window.clearTimeout(timer));
    typeTimers.delete(element);
  };

  const typeElement = (element: HTMLElement) => {
    const text = element.dataset.typeText ?? "";
    clearTypeTimers(element);
    element.textContent = "";
    element.classList.remove("is-typed");
    element.classList.add("is-typing");

    const cursor = document.createElement("span");
    cursor.className = "text-type-cursor";
    cursor.textContent = "|";
    element.appendChild(cursor);

    const timers: number[] = [];
    const speed = Math.max(14, Math.min(34, 720 / Math.max(text.length, 1)));
    const startDelay = Number(element.dataset.typeDelay || 0);

    Array.from(text).forEach((char, index) => {
      const timer = window.setTimeout(() => {
        cursor.before(document.createTextNode(char));
        if (index === text.length - 1) {
          element.classList.remove("is-typing");
          element.classList.add("is-typed");
        }
      }, startDelay + index * speed);
      timers.push(timer);
    });

    if (!text) element.classList.add("is-typed");
    typeTimers.set(element, timers);
  };

  const typeVisibleText = (root: ParentNode) => {
    Array.from(root.querySelectorAll<HTMLElement>(".text-type")).forEach((element, index) => {
      const revealParent = element.closest<HTMLElement>(".slide-step");
      if (revealParent && !revealParent.classList.contains("is-visible")) return;
      element.dataset.typeDelay = String(index * 75);
      typeElement(element);
    });
  };

  typeTextTargets.forEach(prepareTypeText);

  if (heroAudio) {
    heroAudio.volume = 0.2;
  }

  if (deck && slideEls.length && indicators.length) {
    const totalSlides = Number(deck.dataset.total || slideEls.length);
    let activeIndex = 0;
    const revealedSteps = new Map<number, number>();
    const softLightSlides = new Set([1, 2, 5, 6, 7, 8, 9, 10, 11, 12]);
    const backgroundPresets = [
      {
        left: "top-left",
        right: "top-right",
        aurora: { colorStops: ["#ffffff", "#ffffff", "#ffffff"], speed: 0.42, blend: 0.44, amplitude: 0.86, opacity: 0.2 },
      },
      {
        left: "bottom-left",
        right: "middle-right",
        aurora: { colorStops: ["#58a6ff", "#ffffff", "#ff8a45"], speed: 0.74, blend: 0.56, amplitude: 1.18, opacity: 0.24 },
      },
      {
        left: "middle-left",
        right: "top-right",
        aurora: { colorStops: ["#ffffff", "#ff8a45", "#ffffff"], speed: 0.92, blend: 0.6, amplitude: 1.34, opacity: 0.26 },
      },
      {
        left: "top-left",
        right: "bottom-right",
        aurora: { colorStops: ["#7cffd4", "#ffffff", "#5d9cff"], speed: 0.68, blend: 0.48, amplitude: 1.08, opacity: 0.22 },
      },
      {
        left: "bottom-left",
        right: "top-right",
        aurora: { colorStops: ["#ffffff", "#a7b3ff", "#ff8a45"], speed: 1.04, blend: 0.5, amplitude: 1.4, opacity: 0.2 },
      },
      {
        left: "middle-left",
        right: "bottom-right",
        aurora: { colorStops: ["#ffffff", "#ffd0a8", "#ffffff"], speed: 0.58, blend: 0.66, amplitude: 1.2, opacity: 0.24 },
      },
      {
        left: "top-left",
        right: "middle-right",
        aurora: { colorStops: ["#5d9cff", "#ffffff", "#8fffcb"], speed: 0.86, blend: 0.52, amplitude: 1.28, opacity: 0.23 },
      },
      {
        left: "bottom-left",
        right: "middle-right",
        aurora: { colorStops: ["#ffffff", "#ff8a45", "#5d9cff"], speed: 0.72, blend: 0.58, amplitude: 1.18, opacity: 0.22 },
      },
      {
        left: "middle-left",
        right: "top-right",
        aurora: { colorStops: ["#ff8a45", "#ffffff", "#ffe2bd"], speed: 0.54, blend: 0.42, amplitude: 0.72, opacity: 0.08 },
      },
      {
        left: "bottom-left",
        right: "top-right",
        aurora: { colorStops: ["#ffffff", "#8fffcb", "#ff8a45"], speed: 0.66, blend: 0.54, amplitude: 1.08, opacity: 0.16 },
      },
      {
        left: "top-left",
        right: "middle-right",
        aurora: { colorStops: ["#ff8a45", "#ffffff", "#8fffcb"], speed: 0.62, blend: 0.5, amplitude: 1.02, opacity: 0.18 },
      },
      {
        left: "middle-left",
        right: "bottom-right",
        aurora: { colorStops: ["#ff8a45", "#10ff9b", "#ffffff"], speed: 0.7, blend: 0.58, amplitude: 1.18, opacity: 0.18 },
      },
      {
        left: "top-left",
        right: "bottom-right",
        aurora: { colorStops: ["#ffffff", "#ff8a45", "#5d9cff"], speed: 0.76, blend: 0.5, amplitude: 1.24, opacity: 0.18 },
      },
      {
        left: "bottom-left",
        right: "top-right",
        aurora: { colorStops: ["#ffffff", "#ff8a45", "#10ff9b"], speed: 0.68, blend: 0.6, amplitude: 1.16, opacity: 0.2 },
      },
    ] as const;

    const applySlideBackground = (index: number) => {
      const preset = backgroundPresets[index] ?? backgroundPresets[0];
      window.dispatchEvent(new CustomEvent("siderays:set-origin", {
        detail: { channel: "left", origin: preset.left },
      }));
      window.dispatchEvent(new CustomEvent("siderays:set-origin", {
        detail: { channel: "right", origin: preset.right },
      }));
      window.dispatchEvent(new CustomEvent("aurora:chaos", { detail: preset.aurora }));
    };

    const setHash = (index: number) => {
      const hash = index === 0 ? "#slides" : `#slides-${index + 1}`;
      if (window.location.hash !== hash) history.replaceState(null, "", hash);
    };

    const setSlide = (index: number) => {
      typeTextTargets.forEach(clearTypeTimers);
      activeIndex = (index + totalSlides) % totalSlides;
      slideEls.forEach((slide, i) => {
        const active = i === activeIndex;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
        const visibleSteps = revealedSteps.get(i) ?? -1;
        slide.querySelectorAll<HTMLElement>("[data-step]").forEach((step) => {
          const stepIndex = Number(step.dataset.stepIndex);
          step.classList.toggle("is-visible", stepIndex <= visibleSteps);
        });
      });
      indicators.forEach((indicator, i) => {
        const active = i === activeIndex;
        indicator.classList.toggle("is-active", active);
        if (active) indicator.setAttribute("aria-current", "step");
        else indicator.removeAttribute("aria-current");
      });
      if (stage) {
        stage.dataset.light = activeIndex === 8 ? "extra-soft" : softLightSlides.has(activeIndex) ? "soft" : "normal";
        stage.dataset.mode = slideEls[activeIndex]?.classList.contains("slide-video") ? "video" : "slides";
      }
      applySlideBackground(activeIndex);
      typeVisibleText(slideEls[activeIndex]);
      if (heroAudio) {
        if (activeIndex === 5) {
          heroAudio.currentTime = 0;
          heroAudio.volume = 0.2;
          heroAudio.play().catch(() => {});
        } else {
          heroAudio.pause();
          heroAudio.currentTime = 0;
        }
      }
      slideVideos.forEach((video) => {
        const activeVideo = video.closest<HTMLElement>("[data-slide]")?.dataset.index === String(activeIndex);
        if (activeVideo) {
          video.currentTime = 0;
          video.play().catch(() => {});
        } else {
          video.pause();
          video.currentTime = 0;
        }
      });
      loopVideos.forEach((video) => {
        const activeLoopVideo = video.closest<HTMLElement>("[data-slide]")?.dataset.index === String(activeIndex);
        if (activeLoopVideo) {
          video.play().catch(() => {});
        } else {
          video.pause();
          video.currentTime = 0;
        }
      });
      setHash(activeIndex);
    };

    const revealNextStep = () => {
      const activeSlide = slideEls[activeIndex];
      const steps = Array.from(activeSlide.querySelectorAll<HTMLElement>("[data-step]"));
      if (!steps.length) return false;
      const current = revealedSteps.get(activeIndex) ?? -1;
      if (current >= steps.length - 1) return false;
      const next = current + 1;
      revealedSteps.set(activeIndex, next);
      const step = steps[next];
      step?.classList.add("is-visible");
      if (step) typeVisibleText(step);
      return true;
    };

    const readHash = () => {
      const match = window.location.hash.match(/^#slides(?:-(\d+))?$/);
      if (!match) return 0;
      const numeric = match[1] ? Number(match[1]) - 1 : 0;
      return Number.isFinite(numeric) ? Math.min(Math.max(numeric, 0), totalSlides - 1) : 0;
    };

    const goNext = () => {
      if (revealNextStep()) return;
      setSlide(activeIndex + 1);
    };

    const goPrevious = () => {
      setSlide(activeIndex - 1);
    };

    arrowButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (button.dataset.arrowButton === "previous") goPrevious();
        else goNext();
      });
    });

    stage?.addEventListener("click", (event) => {
      if (event.defaultPrevented) return;
      if (event instanceof MouseEvent && event.button !== 0) return;

      const target = event.target as HTMLElement | null;
      if (
        target?.closest(
          "a, button, video, audio, input, textarea, select, [contenteditable='true'], .presentation-bottom"
        )
      ) {
        return;
      }

      goNext();
    });

    slideVideos.forEach((video) => {
      video.volume = 0.85;
      video.addEventListener("pointerup", (event) => {
        event.preventDefault();
        event.stopPropagation();
        video.play().catch(() => {});
      });
    });

    window.addEventListener("keydown", (event) => {
      const target = event.target as HTMLElement | null;
      const isTyping =
        target?.tagName === "INPUT" ||
        target?.tagName === "TEXTAREA" ||
        target?.isContentEditable;

      if (!isTyping && event.key.toLowerCase() === "f") {
        event.preventDefault();
        if (document.fullscreenElement) {
          document.exitFullscreen().catch(() => {});
        } else {
          (stage ?? document.documentElement).requestFullscreen().catch(() => {});
        }
        return;
      }

      if (event.key === "ArrowRight" || event.key === "PageDown") {
        goNext();
      }
      if (event.key === "ArrowLeft" || event.key === "PageUp") {
        goPrevious();
      }
    });

    window.addEventListener("hashchange", () => setSlide(readHash()));

    setSlide(readHash());
  }
</script>

