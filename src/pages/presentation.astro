  .achievement-photo-1 {
    left: 0;
    top: 2%;
    z-index: 1;
    width: 58%;
    height: 38%;
    transform: rotate(-3.2deg);
  }

  .achievement-photo-2 {
    left: 46%;
    top: 4%;
    z-index: 3;
    width: 34%;
    height: 55%;
    transform: rotate(2.8deg);
  }

  .achievement-photo-3 {
    left: 8%;
    top: 43%;
    z-index: 2;
    width: 58%;
    height: 39%;
    transform: rotate(2.4deg);
  }

  .achievement-photo-4 {
    left: 53%;
    top: 54%;
    z-index: 4;
    width: 36%;
    height: 34%;
    transform: rotate(-2.5deg);
  }

  .achievements-layout ul {
    display: grid;
    gap: clamp(0.8rem, 1.6vw, 1.45rem);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .achievements-layout li {
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: clamp(1.45rem, 2.72vw, 3.35rem);
    font-weight: 700;
    line-height: 1.02;
    text-transform: uppercase;
    text-shadow: 0 1rem 2.8rem rgb(0 0 0 / 0.34);
  }

  .achievements-layout li:nth-child(3),
  .achievements-layout li:nth-child(4) {
    color: #ff8a45;
  }

  .slide-image-frame {
    position: relative;
    display: grid;
    width: min(90vw, 1120px);
    max-height: 78dvh;
    place-items: center;
  }

  .slide-image-frame img {
    display: block;
    max-width: 100%;
    max-height: 78dvh;
    object-fit: contain;
    border: 1px solid rgb(255 255 255 / 0.16);
    box-shadow: 0 0 4rem rgb(0 0 0 / 0.36);
  }

  .bob-closing-copy {
    position: relative;
    z-index: 2;
    display: grid;
    justify-items: center;
    gap: 0.12em;
    width: max-content;
    max-width: min(88vw, 64rem);
    padding: 0.34em 0.5em 0.42em;
    color: var(--color-ink);
    font-family: var(--font-display);
    line-height: 0.88;
    text-align: center;
    text-transform: uppercase;
    text-shadow: 0 1rem 2.5rem rgb(0 0 0 / 0.58);
  }

  .bob-closing-copy::before {
    content: "";
    position: absolute;
    inset: -0.08em -0.12em;
    z-index: -1;
    border: 2px dashed #ff8a45;
    background: rgb(0 0 0 / 0.14);
    animation: capture-frame-pulse 1.55s ease-in-out infinite;
  }

  .bob-closing-copy::after {
    content: "";
    position: absolute;
    left: -0.22em;
    top: -0.22em;
    z-index: 2;
    width: 0.16em;
    height: 0.16em;
    min-width: 9px;
    min-height: 9px;
    background: var(--color-paper);
    border: 2px solid #ff8a45;
    box-shadow:
      calc(100% + 0.28em) 0 0 var(--color-paper),
      calc(100% + 0.28em) 0 0 2px #ff8a45,
      0 calc(100% + 0.28em) 0 var(--color-paper),
      0 calc(100% + 0.28em) 0 2px #ff8a45,
      calc(100% + 0.28em) calc(100% + 0.28em) 0 var(--color-paper),
      calc(100% + 0.28em) calc(100% + 0.28em) 0 2px #ff8a45;
    pointer-events: none;
  }

  .bob-closing-copy span,
  .bob-closing-copy strong {
    display: block;
    font-weight: 400;
    white-space: nowrap;
  }

  .bob-closing-copy span {
    font-size: clamp(1.85rem, 3.6vw, 4.15rem);
  }

  .bob-closing-copy strong {
    color: #ff8a45;
    font-size: clamp(2.25rem, 4.6vw, 5.25rem);
  }

  .slide-image-frame:has(.bob-closing-copy) {
    width: min(90vw, 980px);
    max-height: none;
    gap: clamp(1.2rem, 2.5vh, 2rem);
    align-content: center;
  }

  .slide-image-frame:has(.bob-closing-copy) img {
    max-height: 61dvh;
  }

  .slide-steps {
    display: grid;
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 58rem;
  }

  .slide-step {
    margin: 0;
    border-left: 1px solid rgb(255 255 255 / 0.36);
    padding-left: clamp(1rem, 2vw, 1.5rem);
    color: rgb(255 255 255 / 0.8);
    font-size: clamp(1.5rem, 3vw, 3rem);
    line-height: 1.08;
    opacity: 0;
    transform: translateY(0.9rem);
    filter: blur(7px);
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .slide-step.is-visible {
    opacity: 1;
    transform: none;
    filter: none;
  }

  .slide-step p {
    margin: 0;
  }

  .slide-compact .slide-steps {
    max-width: 50rem;
    margin-top: clamp(1.6rem, 2.4vw, 2.2rem);
  }

  .slide-compact .slide-step {
    max-width: 42rem;
    border-left-color: #ff8a45;
    color: rgb(255 255 255 / 0.9);
    font-size: clamp(1.25rem, 1.95vw, 2.05rem);
    line-height: 1.18;
  }

  .reveal-question {
    border-left-color: var(--color-ink);
    font-weight: 700;
  }

  .reveal-product {
    display: inline-flex;
    max-width: max-content;
    border-left: 0;
    padding-left: 0;
    margin-right: 0.6rem;
  }

  .visual-products {
    display: grid;
    gap: 0.8rem;
  }

  .visual-products .reveal-product {
    margin-right: 0;
  }

  .visual-products .slide-step {
    transform: translateY(0.7rem);
  }

  .visual-placeholder {
    display: grid;
    min-height: 14rem;
    place-items: center;
    border: 1px dashed rgb(255 255 255 / 0.2);
    color: rgb(255 255 255 / 0.18);
    font-family: var(--font-display);
    font-size: clamp(4rem, 10vw, 8rem);
    line-height: 1;
  }

  .slide-note {
    border-left: 1px solid rgb(255 255 255 / 0.22);
    padding: 1.15rem 0 1.15rem clamp(1.1rem, 2vw, 1.6rem);
  }

  .slide-note p {
    margin-top: 1.6rem;
    color: rgb(255 255 255 / 0.78);
    font-size: clamp(1rem, 1.25vw, 1.25rem);
    line-height: 1.45;
  }

  .slide-nav {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
  }

  .slide-arrows {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .slide-arrow {
    display: grid;
    width: 2.8rem;
    height: 2.3rem;
    place-items: center;
    border: 1px solid rgb(255 255 255 / 0.22);
    background: rgb(255 255 255 / 0.055);
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 1.1rem;
    line-height: 1;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .slide-arrow:hover {
    border-color: rgb(255 255 255 / 0.6);
    background: rgb(255 255 255 / 0.12);
    transform: translateY(-1px);
  }

  .slide-dot {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.1rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.03);
    color: rgb(255 255 255 / 0.55);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .slide-dot.is-active {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  @media (max-width: 860px) {
    .presentation-shell {
