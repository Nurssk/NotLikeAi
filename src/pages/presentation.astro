    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: clamp(1.25rem, 2vw, 1.8rem);
  }

  .product-logo {
    display: inline-grid;
    grid-template-columns: auto auto;
    grid-template-areas:
      "mark name"
      "mark metric";
    align-items: center;
    column-gap: 0.75rem;
    min-height: 4rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.055);
    padding: 0.65rem 0.9rem;
