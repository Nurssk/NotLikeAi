---
import Base from "../layouts/Base.astro";
import SideRays from "../components/SideRays.astro";

const slides = [
  {
    kicker: "",
    title: "BeUniq.design",
    body: "",
    note: "",
    meta: "Side Rays",
    cover: true,
  },
  {
    kicker: "",
    title: "Помните, что было, когда вышел ChatGPT?",
    titleHtml: 'Помните запуск <span class="capture-word">ChatGPT<svg class="capture-ants" aria-hidden="true"><rect x="1.5" y="1.5"></rect></svg><span class="capture-handle capture-tl" aria-hidden="true"></span><span class="capture-handle capture-tr" aria-hidden="true"></span><span class="capture-handle capture-bl" aria-hidden="true"></span><span class="capture-handle capture-br" aria-hidden="true"></span></span>?',
    body: "",
    note: "",
    meta: "ChatGPT",
    compact: true,
    steps: [
      "Все начали писать через ИИ: эссе, курсовые, документы.",
    ],
  },
  {
    kicker: "",
    title: "Потом вышел GPTZero.",
    titleHtml: 'Потом вышел <span class="capture-word">GPTZero<svg class="capture-ants" aria-hidden="true"><rect x="1.5" y="1.5"></rect></svg><span class="capture-handle capture-tl" aria-hidden="true"></span><span class="capture-handle capture-tr" aria-hidden="true"></span><span class="capture-handle capture-bl" aria-hidden="true"></span><span class="capture-handle capture-br" aria-hidden="true"></span></span>.',
    body: "",
    note: "",
    meta: "Detection",
    compact: true,
    products: [
      { name: "GPTZero", mark: "0", tone: "blue", metric: "$30M ARR" },
      { name: "QuillBot", mark: "Q", tone: "green", metric: "~$27.4M ARR" },
    ],
    steps: [
      "А потом вышел QuillBot.",
      "Один ловит AI-текст. Другой помогает его переписать.",
    ],
  },
  {
    kicker: "01:12",
    title: "[NNN] installs, growing [Y]%/wk.",
    body: "[NNN] developers have installed BeUniq, growing ~[Y]% week over week — pay-as-you-go from $0.33 a review, no subscription.",
    note: "3 free screenshots to start. The first paid credit packs are already live.",
    meta: "Traction",
  },
  {
    kicker: "01:36",
    title: "Built by one person.",
    body: "I designed, built, and shipped BeUniq end to end — the extension, the review engine, and this site.",
    note: "[Your name] — solo technical founder. I built the design reviewer I kept wishing I had.",
    meta: "About me",
  },
];
---

<Base
  title="BeUniq Presentation"
  description="A two-minute BeUniq presentation with animated rays and numbered slides."
>
  <main class="presentation-page">
    <section id="slides" class="presentation-stage" aria-label="BeUniq presentation slides">
      <div class="hero-ray-layer">
        <SideRays
          origin="top-right"
          speed={2}
          rayColor1="#ffffff"
          rayColor2="#ffffff"
          intensity={2}
          spread={2}
          saturation={0}
          blend={0.5}
          falloff={1.5}
          opacity={0.85}
        />
      </div>
      <div class="hero-ray-layer">
        <SideRays
          origin="top-left"
          speed={2}
          rayColor1="#ffffff"
          rayColor2="#ffffff"
          intensity={2}
          spread={2}
          saturation={0}
          blend={0.5}
          falloff={1.5}
          opacity={0.85}
        />
      </div>

      <div class="presentation-shell">
        <header class="presentation-top" aria-label="Presentation controls">
          <a class="brand-mark" href="/">
            <span class="brand-dot" aria-hidden="true"></span>
            <span>BeUniq</span>
          </a>
        </header>

        <div class="deck" data-deck data-total={slides.length}>
          {
            slides.map((slide, index) => (
              <article
                class:list={[
                  "slide",
                  slide.cover && "slide-cover",
                  slide.compact && "slide-compact",
                  index === 0 && "is-active",
                ]}
                data-slide
                data-index={index}
                aria-hidden={index === 0 ? "false" : "true"}
              >
                {
                  slide.cover ? (
                    <div class="cover-mark">
                      <img src="/icon-d-light.svg" alt="BeUniq logo" />
                      <h1>{slide.title}</h1>
                    </div>
                  ) : (
                    <>
                      <div class="slide-copy">
                        <p class="slide-kicker">{slide.kicker} / {slide.meta}</p>
                        {
                          slide.titleHtml ? (
                            <h1 set:html={slide.titleHtml} />
                          ) : (
                            <h1>{slide.title}</h1>
                          )
                        }
                        {
                          slide.products && (
                            <div class="product-logos" aria-label="Products">
                              {slide.products.map((product) => (
                                <div class:list={["product-logo", `product-logo-${product.tone}`]}>
                                  <span class="product-mark">{product.mark}</span>
                                  <span class="product-name">{product.name}</span>
                                  {product.metric && <span class="product-metric">{product.metric}</span>}
                                </div>
                              ))}
                            </div>
                          )
                        }
                        {slide.body && <p class="slide-body">{slide.body}</p>}
                        {
                          slide.steps && (
                            <div class="slide-steps" aria-label="Click reveals">
                              {slide.steps.map((step, stepIndex) => (
                                <p
                                  class="slide-step"
                                  data-step
                                  data-step-index={stepIndex}
                                >
                                  {step}
                                </p>
                              ))}
                            </div>
                          )
                        }
                      </div>
                      {
                        slide.note && (
                          <aside class="slide-note">
                            <span class="note-index">{String(index + 1).padStart(2, "0")}</span>
                            <p>{slide.note}</p>
                          </aside>
                        )
                      }
                    </>
                  )
                }
              </article>
            ))
          }
        </div>

        <footer class="presentation-bottom">
          <div class="slide-nav" aria-label="Slide navigation">
            {
              slides.map((slide, index) => (
                <button
                  type="button"
                  class:list={["slide-dot", index === 0 && "is-active"]}
                  data-slide-button={index}
                  aria-label={`Go to slide ${index + 1}: ${slide.meta}`}
                  aria-current={index === 0 ? "step" : undefined}
                >
                  {String(index + 1).padStart(2, "0")}
                </button>
              ))
            }
          </div>
        </footer>
      </div>
    </section>
  </main>
</Base>

<script>
  const deck = document.querySelector<HTMLElement>("[data-deck]");
  const slideEls = Array.from(document.querySelectorAll<HTMLElement>("[data-slide]"));
  const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-slide-button]"));

  if (deck && slideEls.length && buttons.length) {
    const totalSlides = Number(deck.dataset.total || slideEls.length);
    let activeIndex = 0;
    const revealedSteps = new Map<number, number>();

    const setHash = (index: number) => {
      const hash = index === 0 ? "#slides" : `#slides-${index + 1}`;
      if (window.location.hash !== hash) history.replaceState(null, "", hash);
    };

    const setSlide = (index: number) => {
      activeIndex = (index + totalSlides) % totalSlides;
      slideEls.forEach((slide, i) => {
        const active = i === activeIndex;
        slide.classList.toggle("is-active", active);
        slide.setAttribute("aria-hidden", active ? "false" : "true");
        const visibleSteps = revealedSteps.get(i) ?? -1;
        slide.querySelectorAll<HTMLElement>("[data-step]").forEach((step) => {
          const stepIndex = Number(step.dataset.stepIndex);
          step.classList.toggle("is-visible", stepIndex <= visibleSteps);
        });
      });
      buttons.forEach((button, i) => {
        const active = i === activeIndex;
        button.classList.toggle("is-active", active);
        if (active) button.setAttribute("aria-current", "step");
        else button.removeAttribute("aria-current");
      });
      setHash(activeIndex);
    };

    const revealNextStep = () => {
      const activeSlide = slideEls[activeIndex];
      const steps = Array.from(activeSlide.querySelectorAll<HTMLElement>("[data-step]"));
      if (!steps.length) return false;
      const current = revealedSteps.get(activeIndex) ?? -1;
      if (current >= steps.length - 1) return false;
      const next = current + 1;
      revealedSteps.set(activeIndex, next);
      steps[next]?.classList.add("is-visible");
      return true;
    };

    const readHash = () => {
      const match = window.location.hash.match(/^#slides(?:-(\d+))?$/);
      if (!match) return 0;
      const numeric = match[1] ? Number(match[1]) - 1 : 0;
      return Number.isFinite(numeric) ? Math.min(Math.max(numeric, 0), totalSlides - 1) : 0;
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        setSlide(Number(button.dataset.slideButton));
      });
    });

    deck.addEventListener("click", () => {
      if (revealNextStep()) return;
      setSlide(activeIndex + 1);
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "ArrowRight" || event.key === "PageDown") {
        setSlide(activeIndex + 1);
      }
      if (event.key === "ArrowLeft" || event.key === "PageUp") {
        setSlide(activeIndex - 1);
      }
    });

    window.addEventListener("hashchange", () => setSlide(readHash()));

    setSlide(readHash());
  }
</script>

<style>
  .presentation-page {
    min-height: 100dvh;
    background:
      radial-gradient(circle at 50% 0%, rgb(255 255 255 / 0.1), transparent 34rem),
      var(--color-paper);
    color: var(--color-ink);
  }

  .presentation-stage {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    isolation: isolate;
  }

  .presentation-stage::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to bottom, transparent 0%, transparent 72%, var(--color-paper) 100%),
      repeating-linear-gradient(
        to right,
        rgb(255 255 255 / 0.04) 0,
        rgb(255 255 255 / 0.04) 1px,
        transparent 1px,
        transparent 96px
      );
  }

  .hero-ray-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  :global(#site-cursor) {
    display: none;
  }

  .presentation-shell {
    position: relative;
    z-index: 2;
    display: grid;
    min-height: 100dvh;
    grid-template-rows: auto 1fr auto;
    gap: clamp(1.25rem, 2vw, 2rem);
    padding: clamp(1rem, 2.5vw, 2rem);
  }

  .presentation-top,
  .presentation-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand-mark {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-ink);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand-dot {
    width: 0.65rem;
    height: 0.65rem;
    background: var(--color-ink);
  }

  .deck {
    position: relative;
    min-height: 34rem;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(15rem, 24rem);
    align-items: end;
    gap: clamp(1.5rem, 4vw, 5rem);
    opacity: 0;
    transform: translateY(1.2rem);
    visibility: hidden;
    filter: blur(10px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.7s;
  }

  .slide.is-active {
    opacity: 1;
    transform: none;
    visibility: visible;
    filter: none;
  }

  .slide-copy {
    max-width: 78rem;
  }

  .slide-cover {
    grid-template-columns: 1fr;
    place-items: center;
    text-align: center;
  }

  .cover-mark {
    display: grid;
    justify-items: center;
    gap: clamp(1.35rem, 3vw, 2.4rem);
    transform: translateY(-3vh);
  }

  .slide-cover .cover-mark img {
    width: clamp(5.25rem, 10vw, 8.75rem);
    height: auto;
    filter: drop-shadow(0 0 2.4rem rgb(255 255 255 / 0.18));
  }

  .slide-cover .cover-mark h1 {
    margin: 0;
    max-width: none;
    font-size: clamp(3.4rem, 10vw, 9.6rem);
    line-height: 0.92;
    letter-spacing: 0;
  }

  .slide-kicker,
  .note-index {
    color: rgb(255 255 255 / 0.62);
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1vw, 0.85rem);
    text-transform: uppercase;
  }

  .slide h1 {
    margin-top: clamp(1.1rem, 2vw, 1.6rem);
    max-width: 12ch;
    font-size: clamp(4rem, 11vw, 10.8rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .slide-compact {
    grid-template-columns: minmax(0, 1fr);
    align-items: center;
  }

  .slide-compact .slide-copy {
    max-width: 62rem;
  }

  .slide-compact h1 {
    max-width: 16ch;
    font-size: clamp(2.55rem, 4.9vw, 5.25rem);
    line-height: 1.02;
  }

  .slide-compact h1 :global(.capture-word) {
    position: relative;
    display: inline-block;
    padding: 0.02em 0.12em 0.06em;
    color: var(--color-ink);
  }

  .slide-compact h1 :global(.capture-ants) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .slide-compact h1 :global(.capture-ants rect) {
    width: calc(100% - 4px);
    height: calc(100% - 4px);
    fill: rgb(0 0 0 / 0.08);
    stroke: var(--color-ink);
    stroke-width: 3;
    stroke-dasharray: 11 7;
    animation: capture-march 1.4s linear infinite;
  }

  @keyframes capture-march {
    to {
      stroke-dashoffset: -36;
    }
  }

  .slide-compact h1 :global(.capture-handle) {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--color-paper);
    border: 3px solid var(--color-ink);
    pointer-events: none;
  }

  .slide-compact h1 :global(.capture-tl) {
    left: -6px;
    top: -6px;
  }

  .slide-compact h1 :global(.capture-tr) {
    right: -6px;
    top: -6px;
  }

  .slide-compact h1 :global(.capture-bl) {
    left: -6px;
    bottom: -6px;
  }

  .slide-compact h1 :global(.capture-br) {
    right: -6px;
    bottom: -6px;
  }

  .product-logos {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: clamp(1.25rem, 2vw, 1.8rem);
  }

  .product-logo {
    display: inline-grid;
    grid-template-columns: auto auto;
    grid-template-areas:
      "mark name"
      "mark metric";
    align-items: center;
    column-gap: 0.75rem;
    min-height: 4rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.055);
    padding: 0.65rem 0.9rem;
  }

  .product-mark {
    grid-area: mark;
    display: grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    background: var(--color-ink);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .product-logo-blue .product-mark {
    background: #f4f7ff;
    color: #111111;
  }

  .product-logo-green .product-mark {
    background: #13c783;
    color: #07110d;
  }

  .product-name {
    grid-area: name;
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .product-metric {
    grid-area: metric;
    margin-top: 0.25rem;
    color: #ff8a45;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .slide-body {
    margin-top: clamp(1.4rem, 2.4vw, 2rem);
    max-width: 46rem;
    color: rgb(255 255 255 / 0.76);
    font-size: clamp(1.2rem, 2.1vw, 2rem);
    line-height: 1.25;
  }

  .slide-steps {
    display: grid;
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    max-width: 58rem;
  }

  .slide-step {
    margin: 0;
    border-left: 1px solid rgb(255 255 255 / 0.36);
    padding-left: clamp(1rem, 2vw, 1.5rem);
    color: rgb(255 255 255 / 0.8);
    font-size: clamp(1.5rem, 3vw, 3rem);
    line-height: 1.08;
    opacity: 0;
    transform: translateY(0.9rem);
    filter: blur(7px);
    transition:
      opacity 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .slide-step.is-visible {
    opacity: 1;
    transform: none;
    filter: none;
  }

  .slide-compact .slide-steps {
    max-width: 50rem;
    margin-top: clamp(1.6rem, 2.4vw, 2.2rem);
  }

  .slide-compact .slide-step {
    max-width: 42rem;
    border-left-color: #ff8a45;
    color: rgb(255 255 255 / 0.9);
    font-size: clamp(1.25rem, 1.95vw, 2.05rem);
    line-height: 1.18;
  }

  .slide-note {
    border-left: 1px solid rgb(255 255 255 / 0.22);
    padding: 1.15rem 0 1.15rem clamp(1.1rem, 2vw, 1.6rem);
  }

  .slide-note p {
    margin-top: 1.6rem;
    color: rgb(255 255 255 / 0.78);
    font-size: clamp(1rem, 1.25vw, 1.25rem);
    line-height: 1.45;
  }

  .slide-nav {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
  }

  .slide-dot {
    width: 2.6rem;
    height: 2.1rem;
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.03);
    color: rgb(255 255 255 / 0.55);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      color 0.25s ease;
  }

  .slide-dot.is-active {
    border-color: var(--color-ink);
    background: var(--color-ink);
    color: var(--color-paper);
  }

  @media (hover: hover) and (pointer: fine) {
    .slide-dot:hover {
      border-color: rgb(255 255 255 / 0.6);
      color: var(--color-ink);
    }
  }

  @media (max-width: 860px) {
    .presentation-shell {
      padding: 1rem;
    }

    .presentation-stage::before {
      background:
        radial-gradient(circle at 68% 42%, rgb(11 11 11 / 0.48), rgb(11 11 11 / 0.78) 58%, rgb(11 11 11 / 0.92)),
        linear-gradient(to bottom, rgb(11 11 11 / 0.58), rgb(11 11 11 / 0.7) 42%, rgb(11 11 11 / 0.88)),
        repeating-linear-gradient(
          to right,
          rgb(255 255 255 / 0.05) 0,
          rgb(255 255 255 / 0.05) 1px,
          transparent 1px,
          transparent 78px
        );
    }

    .presentation-top,
    .presentation-bottom {
      align-items: flex-start;
    }

    .presentation-bottom {
      flex-direction: column;
    }

    .deck {
      min-height: 37rem;
    }

    .slide {
      grid-template-columns: 1fr;
      align-content: end;
    }

    .slide-cover {
      align-content: center;
      place-items: center;
    }

    .cover-mark {
      gap: 1.25rem;
      transform: translateY(-4vh);
    }

    .slide-cover .cover-mark img {
      width: clamp(4.5rem, 24vw, 6.25rem);
    }

    .slide-cover .cover-mark h1 {
      max-width: none;
      font-size: clamp(2rem, 9.5vw, 2.55rem);
    }

    .slide h1 {
      max-width: 9ch;
      font-size: clamp(3.6rem, 16vw, 6.8rem);
    }

    .slide-step {
      font-size: clamp(1.25rem, 7vw, 2rem);
    }

    .slide-note {
      border-left: 0;
      border-top: 1px solid rgb(255 255 255 / 0.22);
      padding: 1rem 0 0;
    }

    .slide-note p {
      margin-top: 0.7rem;
      max-width: 34rem;
    }

    .slide-nav {
      width: 100%;
      justify-content: space-between;
    }

    .slide-dot {
      width: 100%;
      min-width: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .slide {
      transform: none;
      filter: none;
      transition: opacity 0.01s linear;
    }
  }
</style>
