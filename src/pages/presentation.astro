    min-width: 8px;
    min-height: 8px;
    background: var(--color-paper);
    border: 2px solid #ff8a45;
    box-shadow:
      calc(100% + 0.36em) 0 0 var(--color-paper),
      calc(100% + 0.36em) 0 0 2px #ff8a45,
      0 calc(100% + 0.36em) 0 var(--color-paper),
      0 calc(100% + 0.36em) 0 2px #ff8a45,
      calc(100% + 0.36em) calc(100% + 0.36em) 0 var(--color-paper),
      calc(100% + 0.36em) calc(100% + 0.36em) 0 2px #ff8a45;
    pointer-events: none;
  }

  @keyframes capture-frame-pulse {
    0%,
    100% {
      opacity: 0.48;
      transform: scale(0.992);
    }
    50% {
      opacity: 1;
      transform: scale(1.012);
    }
  }

  .logo-glass,
  .statement-slide img,
  .slide-image-frame img,
  .before-after-panel img,
  .before-after-panel video,
  .yc-founder-shot,
  .founder-praise-layout img,
  .traction-layout img,
  .about-layout img,
  .achievement-photo {
    outline: 2px dashed rgb(255 138 69 / 0.72);
    outline-offset: 5px;
    animation: capture-photo-pulse 1.8s ease-in-out infinite;
  }

  @keyframes capture-photo-pulse {
    0%,
    100% {
      outline-color: rgb(255 138 69 / 0.42);
      outline-offset: 4px;
    }
    50% {
      outline-color: rgb(255 138 69 / 0.95);
      outline-offset: 8px;
    }
  }

  .slide-compact h1 :global(.capture-handle),
  .slide-full-catch h1 :global(.capture-handle) {
    position: absolute;
    width: 12px;
    height: 12px;
    background: var(--color-paper);
    border: 3px solid var(--color-ink);
    pointer-events: none;
  }

  .slide-compact h1 :global(.capture-tl),
  .slide-full-catch h1 :global(.capture-tl) {
    left: -6px;
    top: -6px;
  }

  .slide-compact h1 :global(.capture-tr),
  .slide-full-catch h1 :global(.capture-tr) {
    right: -6px;
    top: -6px;
  }

  .slide-compact h1 :global(.capture-bl),
  .slide-full-catch h1 :global(.capture-bl) {
    left: -6px;
    bottom: -6px;
  }

  .slide-compact h1 :global(.capture-br),
  .slide-full-catch h1 :global(.capture-br) {
    right: -6px;
    bottom: -6px;
  }

  .product-logos {
