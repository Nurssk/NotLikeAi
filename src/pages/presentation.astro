  .product-mark {
    grid-area: mark;
    display: grid;
    width: 2.65rem;
    height: 2.65rem;
    place-items: center;
    background: var(--color-ink);
    color: var(--color-paper);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
