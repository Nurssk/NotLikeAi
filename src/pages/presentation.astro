    gap: 0.45rem;
    margin-top: clamp(1.5rem, 2.4vw, 2.2rem);
  }

  .big-metric strong {
    font-family: var(--font-display);
    font-size: clamp(3.8rem, 7.2vw, 7.8rem);
    font-weight: 400;
    line-height: 0.85;
  }

  .big-metric span {
    max-width: 34rem;
    color: rgb(255 255 255 / 0.72);
    font-size: clamp(1.05rem, 1.35vw, 1.35rem);
    line-height: 1.3;
  }

  .loop-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    margin-top: clamp(1.5rem, 2.4vw, 2.2rem);
    font-family: var(--font-mono);
  }

  .loop-list span {
    border: 1px solid rgb(255 255 255 / 0.18);
    background: rgb(255 255 255 / 0.055);
    padding: 0.85rem 1rem;
    color: rgb(255 255 255 / 0.9);
    font-size: clamp(0.86rem, 1vw, 1rem);
    text-transform: uppercase;
  }

  .loop-list em {
    color: rgb(255 255 255 / 0.5);
    font-style: normal;
  }

  .product-points {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.7rem;
    margin: clamp(1rem, 1.8vw, 1.5rem) 0 0;
    max-width: 68rem;
    padding: 0;
    list-style: none;
  }

  .product-points li {
    border: 1px solid rgb(255 255 255 / 0.16);
    background: rgb(255 255 255 / 0.045);
    min-height: 4.1rem;
    padding: 0.85rem 0.95rem;
    color: rgb(255 255 255 / 0.82);
    font-size: clamp(0.95rem, 1.12vw, 1.08rem);
    line-height: 1.22;
  }

  .slide-image {
    grid-template-columns: 1fr;
    place-items: center;
  }

  .slide-video {
    grid-template-columns: 1fr;
    place-items: stretch;
    min-height: 100%;
  }

  .slide-demo-video {
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    cursor: pointer;
  }

  .presentation-stage[data-mode="video"] .slide-video,
  .presentation-stage[data-mode="video"] .slide-demo-video {
    height: 100dvh;
  }

  .slide-before-after {
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .before-after-layout {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(0.65rem, 1.4vw, 1.2rem);
    width: 100%;
    min-height: 100%;
    align-items: center;
    padding: 0 clamp(0.15rem, 0.6vw, 0.5rem);
  }

  .before-after-panel {
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: clamp(0.25rem, 0.65vh, 0.5rem);
    min-height: 0;
    align-items: stretch;
  }

  .before-after-panel span {
    justify-self: start;
    color: #ff8a45;
    font-family: var(--font-mono);
    font-size: clamp(1.15rem, 2.15vw, 2.15rem);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
  }

  .before-after-panel img,
  .before-after-panel video {
    display: block;
    justify-self: center;
    width: 100%;
    aspect-ratio: 4 / 3;
