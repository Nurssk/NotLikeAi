    width: min(48vw, 45rem);
    height: min(72vh, 41rem);
    justify-self: start;
  }

  .achievement-photo {
    position: absolute;
    display: block;
    object-fit: cover;
    border: 1px solid rgb(255 255 255 / 0.2);
    background: rgb(255 255 255 / 0.08);
