    background: rgb(255 255 255 / 0.04);
    box-shadow: 0 1.2rem 3.4rem rgb(0 0 0 / 0.34);
  }

  .slide-yc-founders {
    grid-template-columns: 1fr;
    align-items: stretch;
  }


