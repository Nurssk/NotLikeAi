  .product-logo-blue .product-mark {
    background: #f4f7ff;
    color: #111111;
  }

  .product-logo-green .product-mark {
    background: #13c783;
    color: #07110d;
  }

  .product-name {
    grid-area: name;
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.05;
  }

  .product-metric {
    grid-area: metric;
    margin-top: 0.25rem;
    color: #ff8a45;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1;
    text-transform: uppercase;
  }

  .slide-body {
    margin-top: clamp(1.4rem, 2.4vw, 2rem);
