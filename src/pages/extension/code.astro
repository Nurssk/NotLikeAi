---
import "../../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import AmplitudeAnalytics from "../../components/AmplitudeAnalytics.astro";

const pageTitle = "Extension Code | BeUniq Design";
const pageDescription =
  "Copy your one-time BeUniq Design Chrome extension authorization code.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/logo/icon-d.svg" />
    <link rel="apple-touch-icon" href="/logo/app-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="extension-code-body">
    <main class="extension-code-page" data-extension-code-page>
      <section class="extension-code-shell" aria-labelledby="extension-code-title">
        <aside class="extension-code-summary" aria-label="Extension code summary">
          <div class="extension-code-logo" aria-hidden="true">
            <img src="/logo/icon-d.svg" alt="" />
          </div>

          <div>
            <h1 id="extension-code-title">Your extension code</h1>
            <p>
              Copy this one-time code into the Chrome extension with the same email.
            </p>
          </div>

          <div class="extension-code-steps" aria-label="Code requirements">
            <div>
              <span>1</span>
              <strong>Use the same email</strong>
              <p>The extension checks that the email matches this signed-in account.</p>
            </div>
            <div>
              <span>2</span>
              <strong>Use it once</strong>
              <p>The code expires in 10 minutes and is marked used after exchange.</p>
            </div>
          </div>
        </aside>

        <div class="extension-code-card">
          <div class="extension-code-card-head">
            <h2 data-code-heading>Generating code</h2>
            <p data-code-subtitle>Checking your signed-in account...</p>
          </div>

          <div class="extension-code-panel" data-code-panel aria-live="polite">
            <span>One-time code</span>
            <strong data-extension-code>----</strong>
            <p data-code-expiry>Generating...</p>
          </div>

          <div class="extension-code-actions">
            <button class="btn btn-primary extension-copy-button" type="button" data-copy-code disabled>
              Copy code
            </button>
            <button class="extension-secondary-button" type="button" data-regenerate-code disabled>
              New code
            </button>
          </div>

          <p class="extension-code-email" data-code-email></p>
          <p class="extension-code-message" data-code-message aria-live="polite">
            Keep this page open until you finish signing in from the Chrome extension.
          </p>
        </div>
      </section>
    </main>
    <AmplitudeAnalytics />
    <Analytics />
  </body>
</html>

<style>
  .extension-code-body {
    min-height: 100vh;
  }

  .extension-code-page {
    min-height: 100vh;
    display: grid;
    align-items: center;
    padding: clamp(22px, 5vw, 56px);
  }

  .extension-code-shell {
    width: min(100%, 980px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(360px, 1fr);
    overflow: hidden;
    border-radius: 18px;
    background: rgba(250, 247, 243, 0.76);
    box-shadow: 0 2px 8px rgba(16, 17, 18, 0.08);
  }

  .extension-code-summary,
  .extension-code-card {
    min-width: 0;
    padding: clamp(28px, 4.6vw, 44px);
  }

  .extension-code-summary {
    display: flex;
    flex-direction: column;
    gap: 28px;
    background: rgba(238, 231, 219, 0.78);
  }

  .extension-code-logo {
    display: inline-flex;
    width: 58px;
    height: 58px;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: var(--accent);
  }

  .extension-code-logo img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .extension-code-summary h1,
  .extension-code-card h2 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
  }

  .extension-code-summary h1 {
    max-width: 440px;
    font-size: clamp(34px, 5vw, 56px);
  }

  .extension-code-summary p,
  .extension-code-card-head p,
  .extension-code-steps p {
    color: var(--muted);
    font-weight: 700;
    line-height: 1.48;
  }

  .extension-code-summary > div > p {
    max-width: 430px;
    margin: 18px 0 0;
    font-size: 17px;
  }

  .extension-code-steps {
    display: grid;
    gap: 14px;
    margin-top: auto;
  }

  .extension-code-steps div {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    gap: 4px 12px;
    align-items: start;
    padding: 16px 0 0;
    border-top: 1px solid rgba(16, 17, 18, 0.1);
  }

  .extension-code-steps span {
    display: inline-flex;
    width: 24px;
    height: 24px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--accent);
    color: var(--on-accent);
    font-size: 12px;
    font-weight: 900;
  }

  .extension-code-steps strong {
    color: var(--text);
    font-size: 15px;
    font-weight: 800;
  }

  .extension-code-steps p {
    grid-column: 2 / 3;
    margin: 0;
    font-size: 13px;
  }

  .extension-code-card {
    display: grid;
    align-content: center;
    gap: 18px;
    background: rgba(250, 247, 243, 0.86);
  }

  .extension-code-card h2 {
    font-size: clamp(26px, 3vw, 34px);
  }

  .extension-code-card-head p {
    margin: 10px 0 0;
    font-size: 15px;
  }

  .extension-code-panel {
    padding: clamp(22px, 4vw, 30px);
    border-radius: 12px;
    background: #111111;
    color: var(--on-accent);
  }

  .extension-code-panel span,
  .extension-code-panel p {
    color: rgba(250, 247, 243, 0.72);
    font-size: 12px;
    font-weight: 800;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .extension-code-panel strong {
    display: block;
    margin: 12px 0;
    font-family: var(--font-display);
    font-size: clamp(42px, 7vw, 70px);
    font-weight: 900;
    letter-spacing: 0.08em;
    line-height: 0.95;
    overflow-wrap: anywhere;
  }

  .extension-code-panel p {
    margin: 0;
    text-transform: none;
  }

  .extension-code-actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(120px, 0.4fr);
    gap: 12px;
  }

  .extension-copy-button,
  .extension-secondary-button {
    min-height: 54px;
    border-radius: 10px;
    font: inherit;
    font-size: 16px;
    font-weight: 800;
  }

  .extension-secondary-button {
    border: 1px solid rgba(16, 17, 18, 0.12);
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    cursor: pointer;
  }

  .extension-copy-button:disabled,
  .extension-secondary-button:disabled {
    cursor: wait;
    opacity: 0.64;
  }

  .extension-code-email,
  .extension-code-message {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.45;
  }

  .extension-code-email {
    color: #147A3F;
  }

  .extension-code-message.is-error {
    color: #B42318;
  }

  .extension-code-message.is-success {
    color: #147A3F;
  }

  @media (max-width: 780px) {
    .extension-code-page {
      align-items: start;
      padding: 18px;
    }

    .extension-code-shell {
      grid-template-columns: 1fr;
      border-radius: 14px;
    }

    .extension-code-summary,
    .extension-code-card {
      padding: 28px 22px;
    }

    .extension-code-summary h1 {
      font-size: clamp(31px, 12vw, 44px);
    }

    .extension-code-summary > div > p {
      font-size: 15px;
    }

    .extension-code-actions {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const codePage = document.querySelector("[data-extension-code-page]");

  if (codePage) {
    const heading = codePage.querySelector("[data-code-heading]");
    const subtitle = codePage.querySelector("[data-code-subtitle]");
    const codeNode = codePage.querySelector("[data-extension-code]");
    const expiryNode = codePage.querySelector("[data-code-expiry]");
    const emailNode = codePage.querySelector("[data-code-email]");
    const messageNode = codePage.querySelector("[data-code-message]");
    const copyButton = codePage.querySelector("[data-copy-code]");
    const regenerateButton = codePage.querySelector("[data-regenerate-code]");
    let authModulePromise = null;
    let authUser = null;
    let activeCode = "";
    let codeExpiresAt = 0;
    let codeTimer = 0;
    let isGenerating = false;

    const setMessage = (message, tone = "neutral") => {
      if (!messageNode) return;
      messageNode.textContent = message;
      messageNode.classList.toggle("is-error", tone === "error");
      messageNode.classList.toggle("is-success", tone === "success");
    };

    const setButtonsDisabled = (disabled) => {
      [copyButton, regenerateButton].forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = disabled;
        }
      });
    };

    const updateCodeExpiry = () => {
      if (!expiryNode) return;
      const seconds = Math.max(0, Math.ceil((codeExpiresAt - Date.now()) / 1000));
      const minutes = Math.floor(seconds / 60);
      const remainder = String(seconds % 60).padStart(2, "0");
      expiryNode.textContent = seconds > 0 ? `Expires in ${minutes}:${remainder}` : "Expired. Generate a new code.";
      if (seconds <= 0) {
        window.clearInterval(codeTimer);
      }
    };

    const loadAuthModule = () => {
      if (!authModulePromise) {
        authModulePromise = Promise.all([import("firebase/auth"), import("../../lib/firebase")])
          .then(([firebaseAuth, firebase]) => ({
            onAuthStateChanged: firebaseAuth.onAuthStateChanged,
            auth: firebase.auth,
          }))
          .catch((error) => {
            authModulePromise = null;
            throw error;
          });
      }

      return authModulePromise;
    };

    const apiErrorMessage = (error) => {
      if (error === "email_not_verified") return "Verify your email before generating an extension code.";
      if (error === "rate_limited") return "Too many attempts. Wait a moment and try again.";
      if (error === "missing_authorization" || error === "invalid_authorization") return "Log in again before generating a code.";
      return "Could not generate an extension code. Please try again.";
    };

    const showCode = (payload) => {
      activeCode = payload.code;
      codeExpiresAt = Date.parse(payload.expiresAt);
      if (heading) heading.textContent = "Code ready";
      if (subtitle) subtitle.textContent = "Paste this code into the Chrome extension.";
      if (codeNode) codeNode.textContent = activeCode;
      if (emailNode) emailNode.textContent = `Signed in as ${payload.email}`;
      setButtonsDisabled(false);
      window.clearInterval(codeTimer);
      updateCodeExpiry();
      codeTimer = window.setInterval(updateCodeExpiry, 1000);
      setMessage("This code was created for your email and saved on the server as a one-time login attempt.", "success");
    };

    const generateCode = async () => {
      if (isGenerating || !authUser) return;
      isGenerating = true;
      setButtonsDisabled(true);
      if (heading) heading.textContent = "Generating code";
      if (subtitle) subtitle.textContent = "Creating a one-time code for your Chrome extension...";
      if (codeNode) codeNode.textContent = "----";
      if (expiryNode) expiryNode.textContent = "Generating...";
      setMessage("Generating one-time code...");

      try {
        await authUser.reload();
        if (!authUser.emailVerified) {
          window.location.assign("/extension/authorize");
          return;
        }

        const idToken = await authUser.getIdToken(true);
        const response = await fetch("/api/extension-auth/code", {
          method: "POST",
          headers: {
            Authorization: `Bearer ${idToken}`,
          },
        });
        const payload = await response.json().catch(() => ({}));

        if (!response.ok || typeof payload.code !== "string" || typeof payload.expiresAt !== "string") {
          setMessage(apiErrorMessage(payload.error), "error");
          return;
        }

        showCode(payload);
      } catch {
        setMessage("Could not generate an extension code. Please try again.", "error");
      } finally {
        isGenerating = false;
        if (activeCode) setButtonsDisabled(false);
      }
    };

    copyButton?.addEventListener("click", async () => {
      if (!activeCode) return;

      try {
        await navigator.clipboard.writeText(activeCode);
        setMessage("Code copied. Paste it into the Chrome extension.", "success");
      } catch {
        setMessage("Copy failed. Select the code and copy it manually.", "error");
      }
    });

    regenerateButton?.addEventListener("click", () => {
      void generateCode();
    });

    loadAuthModule()
      .then(({ auth, onAuthStateChanged }) => {
        onAuthStateChanged(auth, (user) => {
          if (!user) {
            window.location.assign("/extension/authorize");
            return;
          }

          authUser = user;
          if (emailNode && user.email) {
            emailNode.textContent = `Signed in as ${user.email}`;
          }
          void generateCode();
        });
      })
      .catch(() => {
        setMessage("Authentication could not load. Refresh the page and try again.", "error");
      });
  }
</script>
