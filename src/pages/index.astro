---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Reviews from "../components/Reviews.astro";
import Pricing from "../components/Pricing.astro";
import QA from "../components/QA.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Base stageSeq={true}>
  <Navbar />
  <main>
    <Hero />
    <HowItWorks />
    <Reviews />
    <Pricing />
    <QA />
    <FinalCTA />
  </main>
  <Footer />
</Base>

<script>
  // Landing load sequence: rays → page reveal → videos. Stage classes land
  // on <html>; events let components react. Reduced motion skips the wait.
  const docEl = document.documentElement;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const setStage = (name: string) => {
    docEl.classList.add("stage-" + name);
    document.dispatchEvent(new CustomEvent("stage:" + name));
  };

  if (reduce) {
    setStage("page");
    setStage("videos");
  } else {
    let raysReady = false;
    const reveal = () => {
      if (raysReady) return;
      raysReady = true;
      setStage("page");
      // Let the hero entrance settle, then release the demo GIFs.
      window.setTimeout(() => setStage("videos"), 1000);
    };
    document.addEventListener("rays:ready", reveal);
    // Fail-safe: never trap content behind WebGL.
    window.setTimeout(reveal, 2500);
  }
</script>
