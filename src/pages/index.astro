---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import WhatItDoes from "../components/sections/WhatItDoes.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import WhyItMatters from "../components/sections/WhyItMatters.astro";
import UseCases from "../components/sections/UseCases.astro";
import WaitlistSection from "../components/sections/WaitlistSection.astro";
import QASection from "../components/sections/QASection.astro";
import Footer from "../components/Footer.astro";
import GlobalClickSpark from "../components/GlobalClickSpark";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Design Humanizer is a Chrome extension that helps developers turn generic AI-generated UI into deliberate, structured, and usable layouts."
    />
    <title>Design Humanizer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main>
      <Hero />
      <WhatItDoes />
      <HowItWorks />
      <WhyItMatters />
      <UseCases />
      <WaitlistSection />
      <QASection />
    </main>
    <Footer />
    <!-- Site-wide click sparks (every section, incl. hero); pointer-events:none -->
    <GlobalClickSpark
      client:load
      sparkColor="#FFC928"
      sparkSize={12}
      sparkRadius={22}
      sparkCount={10}
      duration={520}
    />
  </body>
</html>
