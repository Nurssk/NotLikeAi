---
import "../styles/global.css";
import Analytics from '@vercel/analytics/astro'
import Header from "../components/Header.astro";
import Preloader from "../components/Preloader.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import PricingSection from "../components/sections/PricingSection.astro";
import QASection from "../components/sections/QASection.astro";
import Footer from "../components/Footer.astro";
import GlobalClickSpark from "../components/GlobalClickSpark";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Design Humanizer is a Chrome extension that helps developers turn generic AI-generated UI into deliberate, structured, and usable layouts."
    />
    <title>Design Humanizer</title>
    <link rel="icon" type="image/svg+xml" href="/logo/icon-d.svg" />
    <link rel="apple-touch-icon" href="/logo/app-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Preloader />
    <Header />
    <main>
      <Hero />
      <HowItWorks />
      <PricingSection />
      <QASection />
    </main>
    <Footer />
    <!-- Site-wide click sparks (every section, incl. hero); pointer-events:none -->
    <GlobalClickSpark
      client:load
      sparkColor="#111111"
      sparkSize={12}
      sparkRadius={22}
      sparkCount={10}
      duration={520}
    />
    <Analytics />
  </body>
</html>
