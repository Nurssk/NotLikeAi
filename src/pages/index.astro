---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Reviews from "../components/Reviews.astro";
import Pricing from "../components/Pricing.astro";
import QA from "../components/QA.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="BeUniq · Fix your UI"
  description="BeUniq reviews screenshots of AI-generated interfaces and helps make the UI cleaner, clearer, and more intentional."
  stageSeq={true}
>
  <Navbar />
  <main>
    <Hero />
    <HowItWorks />
    <Reviews />
    <Pricing />
    <QA />
    <FinalCTA />
  </main>
  <Footer />
</Base>

<script>
  // Landing load sequence: rays → page reveal → videos. Stage classes land
  // on <html>; events let components react. Reduced motion skips the wait.
  const docEl = document.documentElement;
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const setStage = (name: string) => {
    docEl.classList.add("stage-" + name);
    document.dispatchEvent(new CustomEvent("stage:" + name));
  };

  if (reduce) {
    setStage("page");
    setStage("videos");
  } else {
    let raysReady = false;
    const reveal = () => {
      if (raysReady) return;
      raysReady = true;
      setStage("page");
      // Let the hero entrance settle, then release the demo GIFs.
      window.setTimeout(() => setStage("videos"), 1000);
    };
    document.addEventListener("rays:ready", reveal);
    // Fail-safe: never trap content behind WebGL.
    window.setTimeout(reveal, 2500);
  }
</script>

<style is:global>
  /*
    Landing-only shadcn/Tailwind token bridge.
    The global shadcn light defaults set --foreground to black; that made
    unscoped landing sections render dark text over the dark ray background.
    Keep this scoped to the index page so /presentation is not affected.
  */
  body {
    --background: var(--color-paper);
    --foreground: var(--color-ink);
    --card: #101010;
    --card-foreground: var(--color-ink);
    --popover: #101010;
    --popover-foreground: var(--color-ink);
    --primary: var(--color-ink);
    --primary-foreground: var(--color-paper);
    --secondary: #151515;
    --secondary-foreground: var(--color-ink);
    --muted: #717171;
    --muted-foreground: var(--color-ink-70);
    --accent: #191919;
    --accent-foreground: var(--color-ink);
    --border: var(--color-rule);
    --input: var(--color-rule);
    --ring: var(--color-ink);
  }
</style>
