---
import Base from "../layouts/Base.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const faqs = [
  {
    num: "01",
    q: "What does BeUniq actually do?",
    a: "It analyzes an AI-generated interface and shows what feels generic: weak hierarchy, repeated cards, unclear focus, poor spacing, and low visual priority. Then it suggests how to make the same content feel more intentional.",
  },
  {
    num: "02",
    q: "Is BeUniq a design generator?",
    a: "Not exactly. It is closer to a design critique layer. It does not create a random new website from scratch; it helps improve the interface you already have.",
  },
  {
    num: "03",
    q: "Does it replace a designer?",
    a: "No. It helps non-designers make better design decisions faster. A designer can still make deeper brand and product decisions.",
  },
  {
    num: "04",
    q: "Does it change my content?",
    a: "No. The goal is to keep your original content and improve how it is presented visually.",
  },
  {
    num: "05",
    q: "What problems does it detect?",
    a: "It detects weak hierarchy, repeated cards, unclear CTA focus, generic layout rhythm, poor grouping, spacing issues, and visual sameness.",
  },
  {
    num: "06",
    q: "Can I preview changes before applying them?",
    a: "Yes. The goal is to show a clearer design direction before you change the actual page.",
  },
  {
    num: "07",
    q: "How does the Chrome extension work?",
    a: "The extension runs directly on the current page, reads the visible layout, detects weak design patterns, and shows suggestions in a side panel.",
  },
  {
    num: "08",
    q: "What kinds of pages can it analyze?",
    a: "Landing pages, MVP screens, dashboards, generated frontend pages, and product interfaces that run in the browser.",
  },
  {
    num: "09",
    q: "Is my page data stored?",
    a: "For the MVP, BeUniq avoids storing page content unless the user explicitly chooses to submit or save it.",
  },
  {
    num: "10",
    q: "Will it edit my code automatically?",
    a: "The first version focuses on analysis and preview. Apply and copy features can be added later depending on the product roadmap.",
  },
  {
    num: "11",
    q: "When will it be available?",
    a: "It is available now. Click Start to sign in with Google and open the Chrome Web Store listing.",
  },
];
---

<Base title="FAQ | BeUniq">
  <Navbar />
  <main>
    <section class="px-5 py-16 sm:px-8 sm:py-24">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[1fr_2fr] lg:gap-16">
        <!-- Left column -->
        <div>
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm text-muted transition-colors duration-150 hover:text-ink"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to home
          </a>
          <h1 class="mt-6 text-4xl font-bold leading-tight tracking-tight sm:text-5xl">
            Questions & answers
          </h1>
          <div class="mt-8">
            <a
              href="mailto:sarsennbaj.n@gmail.com"
              class="inline-flex min-h-11 items-center rounded-full bg-ink px-6 text-sm font-medium text-paper transition-opacity duration-150 hover:opacity-80"
            >
              Ask a question
            </a>
          </div>
        </div>

        <!-- Right column — accordion -->
        <div>
          {
            faqs.map((item, i) => (
              <details
                open={i === 0}
                class="group border-b border-rule first:border-t"
              >
                <summary class="flex cursor-pointer list-none items-start gap-6 py-6">
                  <span class="mt-1 font-mono text-sm font-semibold text-muted">
                    {item.num}
                  </span>
                  <span class="flex-1 text-lg font-bold tracking-tight sm:text-xl">
                    {item.q}
                  </span>
                  <span class="mt-1 flex size-8 shrink-0 items-center justify-center rounded-full border border-rule transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-open:border-ink group-open:bg-ink">
                    <span class="plus relative block h-4 w-4 transition-transform duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-open:rotate-[135deg]">
                      <span class="absolute left-1/2 top-0 h-4 w-px -translate-x-1/2 bg-ink transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-open:bg-paper" />
                      <span class="absolute left-0 top-1/2 h-px w-4 -translate-y-1/2 bg-ink transition-colors duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] group-open:bg-paper" />
                    </span>
                  </span>
                </summary>
                <div class="acc-body">
                  <div class="pb-6 pl-10">
                    <p class="max-w-2xl text-base leading-relaxed text-ink-70">
                      {item.a}
                    </p>
                  </div>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
