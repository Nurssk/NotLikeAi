---
const diagnosis = [
  {
    label: "Priority",
    title: "Everything has the same priority",
    description: "The user cannot tell what matters first.",
  },
  {
    label: "Rhythm",
    title: "Cards repeat without rhythm",
    description: "The layout feels assembled, not composed.",
  },
  {
    label: "Spacing",
    title: "Spacing is technically correct, but emotionally flat",
    description: "There is no tension, pause, or emphasis.",
  },
  {
    label: "Intent",
    title: "The interface explains content, not intention",
    description: "It shows blocks, but does not guide attention.",
  },
];
---

<section id="diagnosis" class="section section-gray diagnosis-section">
  <div class="container">
    <div class="section-intro left">
      <p class="section-kicker muted">Diagnosis</p>
      <h2>What makes generated UI feel generic?</h2>
      <p>
        AI can place components on a page. The harder work is deciding what the user should notice,
        ignore, compare, trust, and do next.
      </p>
    </div>

    <div class="diagnosis-board">
      {diagnosis.map((item, index) => (
        <article class={`critique-card critique-${index + 1}`}>
          <span class="critique-number">{String(index + 1).padStart(2, "0")}</span>
          <span class="critique-label">{item.label}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
          <span class="critique-arrow" aria-hidden="true"></span>
          <div class="critique-mark" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
