---
import CrowdCanvasWrapper from "./CrowdCanvasWrapper";
---

<section id="product" class="hero-mvp-scroll">
  <div class="hero-sticky">
    <div class="hero-bg hero-skiper-bg" aria-hidden="true">
      <CrowdCanvasWrapper client:only="react" rows={15} cols={7} />
    </div>
    <div class="hero-peeps-runner" aria-hidden="true">
      <img
        class="hero-peeps-walker"
        src="/images/peeps/peeps.png"
        alt=""
      />
    </div>

    <div class="hero-content">
      <h1 class="hero-title">
        <span class="hero-title-word">Be</span>
        <span class="hero-title-word">Unique</span>
      </h1>
      <p class="hero-subtitle">
        Design Humanizer helps turn generic AI-generated interfaces into cleaner, more intentional product screens.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary btn-large" href="/dashboard">Open dashboard</a>
      </div>
    </div>
  </div>
</section>
