---
import PillNav from "./PillNav";
import StartButton from "./StartButton";

const navItems = [
  { label: "How it works", href: "/#how" },
  { label: "Pricing", href: "/#pricing" },
  { label: "Q&A", href: "/#qa" },
  { label: "FAQ", href: "/faq" },
];

const activeHref = Astro.url.pathname === "/faq" ? "/faq" : undefined;
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <PillNav
      client:load
      logo="/logo/icon-d.svg"
      logoAlt="Design Humanizer logo"
      items={navItems}
      activeHref={activeHref}
      homeHref="/#product"
      baseColor="#111111"
      pillColor="#111111"
      hoveredPillTextColor="#FAF7F3"
      pillTextColor="#FAF7F3"
      className="site-pill-nav"
    />

    <StartButton client:load className="header-start-button" size="sm" />
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]");

  const syncHeader = () => {
    if (!header) return;

    const hero = document.querySelector("#product");

    if (!hero) {
      const isLandingPage = window.location.pathname === "/";
      header.classList.toggle("is-scrolled", !isLandingPage);
      return;
    }

    const revealAt = hero.offsetTop + hero.getBoundingClientRect().height - 80;
    header.classList.toggle("is-scrolled", window.scrollY >= revealAt);
  };

  syncHeader();
  window.addEventListener("DOMContentLoaded", syncHeader, { once: true });
  window.addEventListener("scroll", syncHeader, { passive: true });
  window.addEventListener("resize", syncHeader, { passive: true });
</script>
