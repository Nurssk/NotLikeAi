---
const navItems = [
  { label: "What it does", href: "#what" },
  { label: "How it works", href: "#how" },
  { label: "Why", href: "#why" },
  { label: "Use cases", href: "#use-cases" },
  { label: "Q&A", href: "#qa" },
];
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="#product" aria-label="Design Humanizer home">
      <span class="brand-mark" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <rect x="1" y="1" width="5" height="5" rx="1.5" fill="currentColor" opacity="0.9" />
          <rect x="8" y="1" width="5" height="3" rx="1.5" fill="currentColor" opacity="0.55" />
          <rect x="1" y="8" width="3" height="5" rx="1.5" fill="currentColor" opacity="0.55" />
          <rect x="6" y="6" width="7" height="7" rx="1.5" fill="currentColor" opacity="0.9" />
        </svg>
      </span>
      <span>Design Humanizer</span>
    </a>

    <nav class="nav-links" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a class="btn btn-primary btn-small" href="#waitlist">Join waitlist</a>
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]");
  const syncHeader = () => {
    header?.classList.toggle("is-scrolled", window.scrollY > 8);
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });
</script>
