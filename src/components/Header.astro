---
const navItems = [
  { label: "How it works", href: "/#how" },
  { label: "Q&A", href: "/#qa" },
  { label: "FAQ", href: "/faq" },
];
---

<header class="site-header" data-header>
  <div class="container header-inner">
    <a class="brand" href="/#product" aria-label="Design Humanizer home">
      <span class="brand-mark" aria-hidden="true">
        <svg width="22" height="22" viewBox="0 0 48 48" fill="none">
          <path d="M6 16V12C6 8.7 8.7 6 12 6H16" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
          <path d="M32 6H36C39.3 6 42 8.7 42 12V16" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
          <path d="M42 32V36C42 39.3 39.3 42 36 42H32" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
          <path d="M16 42H12C8.7 42 6 39.3 6 36V32" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
          <rect x="15" y="15" width="18" height="18" rx="4.5" fill="var(--accent)" />
          <rect x="19.5" y="21" width="9" height="2.8" rx="1.4" fill="currentColor" />
          <rect x="19.5" y="26" width="5.5" height="2.8" rx="1.4" fill="currentColor" />
        </svg>
      </span>
      <span>Design Humanizer</span>
    </a>

    <nav class="nav-links" aria-label="Primary navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <a class="btn btn-primary btn-small" href="/#product">Join waitlist</a>
  </div>
</header>

<script>
  const header = document.querySelector("[data-header]");
  const syncHeader = () => {
    header?.classList.toggle("is-scrolled", window.scrollY > 8);
  };

  syncHeader();
  window.addEventListener("scroll", syncHeader, { passive: true });
</script>
