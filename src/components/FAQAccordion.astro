---
type FAQItem = {
  id?: string;
  number?: string;
  category?: string;
  q?: string;
  a?: string;
  question?: string;
  answer?: string;
};

const { items, className = "", startOpenIndex = 0, featuredIndex } = Astro.props as {
  items: FAQItem[];
  className?: string;
  startOpenIndex?: number;
  featuredIndex?: number;
};
---

<div class={`faq-accordion ${className}`} data-faq-accordion>
  {items.map((item, i) => (
    <details
      class:list={["faq-item", { "is-featured": featuredIndex === i }]}
      data-faq-item
      data-featured={featuredIndex === i ? "true" : undefined}
      data-category={item.category}
      data-id={item.id}
      open={i === startOpenIndex}
    >
      <summary>
        <span class="faq-item-number">{item.number ?? String(i + 1).padStart(2, "0")}</span>
        <span class="faq-item-question">{item.question ?? item.q}</span>
        <span class="faq-item-toggle" aria-hidden="true"></span>
      </summary>
      <div class="faq-item-panel">
        <div class="faq-item-panel-inner">
          <p>{item.answer ?? item.a}</p>
        </div>
      </div>
    </details>
  ))}
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-faq-accordion]").forEach((accordion) => {
    if (accordion.dataset.faqBound === "true") return;
    accordion.dataset.faqBound = "true";
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const panelAnimations = new WeakMap<HTMLElement, Animation>();
    const innerAnimations = new WeakMap<HTMLElement, Animation>();

    const getPanel = (item: HTMLDetailsElement) => item.querySelector<HTMLElement>(".faq-item-panel");
    const getInner = (item: HTMLDetailsElement) => item.querySelector<HTMLElement>(".faq-item-panel-inner");

    const resetPanel = (item: HTMLDetailsElement, panel: HTMLElement, inner: HTMLElement) => {
      panelAnimations.delete(panel);
      innerAnimations.delete(inner);
      delete item.dataset.faqAnimating;
      item.classList.remove("is-opening", "is-closing");
      panel.style.height = "";
      panel.style.overflow = "";
    };

    const stopCurrentAnimation = (panel: HTMLElement, inner: HTMLElement) => {
      const currentHeight = panel.getBoundingClientRect().height;
      panelAnimations.get(panel)?.cancel();
      innerAnimations.get(inner)?.cancel();
      panel.style.height = `${currentHeight}px`;
      return currentHeight;
    };

    const animateItem = (item: HTMLDetailsElement, shouldOpen: boolean) => {
      const panel = getPanel(item);
      const inner = getInner(item);
      if (!panel || !inner) return;

      if (reduceMotion) {
        item.open = shouldOpen;
        return;
      }

      const startHeight = item.open ? stopCurrentAnimation(panel, inner) : 0;
      if (shouldOpen) item.open = true;

      item.dataset.faqAnimating = shouldOpen ? "open" : "close";
      item.classList.toggle("is-opening", shouldOpen);
      item.classList.toggle("is-closing", !shouldOpen);
      panel.style.overflow = "hidden";
      panel.style.height = `${startHeight}px`;

      const targetHeight = shouldOpen ? panel.scrollHeight : 0;
      const panelAnimation = panel.animate(
        [{ height: `${startHeight}px` }, { height: `${targetHeight}px` }],
        {
          duration: shouldOpen ? 260 : 240,
          easing: "cubic-bezier(0.22, 1, 0.36, 1)",
          fill: "forwards",
        },
      );
      const startsPartiallyOpen = shouldOpen && startHeight > 4;
      const innerAnimation = inner.animate(
        [
          {
            opacity: startsPartiallyOpen || !shouldOpen ? 1 : 0,
            transform: startsPartiallyOpen || !shouldOpen ? "translateY(0)" : "translateY(-6px)",
          },
          {
            opacity: shouldOpen ? 1 : 0,
            transform: shouldOpen ? "translateY(0)" : "translateY(-4px)",
          },
        ],
        {
          duration: shouldOpen ? 220 : 200,
          easing: "cubic-bezier(0.22, 1, 0.36, 1)",
          fill: "forwards",
        },
      );

      panelAnimations.set(panel, panelAnimation);
      innerAnimations.set(inner, innerAnimation);

      panelAnimation.finished
        .then(() => {
          if (panelAnimations.get(panel) !== panelAnimation || item.dataset.faqAnimating !== (shouldOpen ? "open" : "close")) return;
          if (!shouldOpen) item.open = false;
          resetPanel(item, panel, inner);
        })
        .catch(() => undefined);
    };

    const openItem = (item: HTMLDetailsElement) => {
      if (item.open && item.dataset.faqAnimating !== "close") return;

      accordion.querySelectorAll<HTMLDetailsElement>("details[open]").forEach((openItem) => {
        if (openItem !== item) closeItem(openItem);
      });

      animateItem(item, true);
    };

    const closeItem = (item: HTMLDetailsElement) => {
      if (!item.open || item.dataset.faqAnimating === "close") return;
      animateItem(item, false);
    };

    accordion.querySelectorAll<HTMLDetailsElement>("[data-faq-item]").forEach((item) => {
      const summary = item.querySelector("summary");
      summary?.addEventListener("click", (event) => {
        event.preventDefault();
        if (item.open && item.dataset.faqAnimating !== "close") {
          closeItem(item);
        } else {
          openItem(item);
        }
      });
    });
  });
</script>
