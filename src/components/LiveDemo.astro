---
const findings = [
  "Primary action has no visual priority",
  "Card spacing is inconsistent",
  "Three cards share equal weight",
  "Heading hierarchy is flat",
];
---

<section id="demo" class="border-b border-rule">
  <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <h2
      data-reveal
      class="max-w-2xl text-3xl font-bold leading-tight tracking-tight sm:text-5xl"
    >
      See it in action
    </h2>
    <p
      data-reveal
      style="--reveal-delay: 0.1s"
      class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-70"
    >
      Draw a box around part of your screen. BeUniq captures it and returns
      specific fixes.
    </p>

    <div
      class="demo mt-12 grid gap-px border border-ink bg-ink md:grid-cols-2"
      data-demo
      data-phase="idle"
    >
      <!-- Left: the screen being captured -->
      <div class="stage relative bg-paper p-6 sm:p-8">
        <span class="text-sm text-muted">Your screen</span>

        <!-- Monochrome wireframe of a generic UI -->
        <div class="mt-5 space-y-4" aria-hidden="true">
          <div class="flex items-center justify-between">
            <div class="h-4 w-16 bg-ink/15"></div>
            <div class="flex gap-3">
              <div class="h-2.5 w-10 bg-ink/10"></div>
              <div class="h-2.5 w-10 bg-ink/10"></div>
              <div class="h-2.5 w-10 bg-ink/10"></div>
            </div>
          </div>
          <div class="space-y-2 pt-2">
            <div class="h-6 w-3/4 bg-ink/15"></div>
            <div class="h-3 w-2/3 bg-ink/10"></div>
            <div class="mt-3 h-7 w-28 bg-ink/15"></div>
          </div>
          <div class="grid grid-cols-3 gap-3 pt-2">
            <div class="h-14 bg-ink/10"></div>
            <div class="h-14 bg-ink/10"></div>
            <div class="h-14 bg-ink/10"></div>
          </div>
        </div>

        <!-- Selection marquee that draws itself -->
        <div class="marquee" aria-hidden="true"></div>
        <!-- Screenshot capture flash -->
        <div class="flash" aria-hidden="true"></div>
        <!-- Captured label -->
        <div class="captured" aria-hidden="true">Screenshot captured</div>
        <!-- Crosshair cursor -->
        <svg class="crosshair" viewBox="0 0 24 24" aria-hidden="true">
          <line x1="12" y1="1" x2="12" y2="23"></line>
          <line x1="1" y1="12" x2="23" y2="12"></line>
        </svg>
      </div>

      <!-- Right: the analysis -->
      <div class="bg-paper p-6 sm:p-8">
        <div class="flex items-center justify-between border-b border-ink pb-3">
          <span class="text-sm font-semibold">Analysis</span>
          <span class="text-sm text-muted" data-status>Waiting</span>
        </div>
        <ul class="mt-1">
          {
            findings.map((f, i) => (
              <li class="finding flex gap-3 border-b border-rule py-3.5 last:border-b-0">
                <span class="font-mono text-xs text-muted">{i + 1}</span>
                <span class="text-sm leading-snug text-ink">{f}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <p class="mt-4 text-sm text-muted">
      A demonstration of the capture and analysis flow.
    </p>
  </div>
</section>

<style>
  .stage {
    min-height: 300px;
  }

  /* Selection marquee — box the user draws around a region */
  .marquee {
    position: absolute;
    left: 6%;
    top: 30%;
    width: 60%;
    height: 46%;
    border: 2px dashed var(--color-ink);
    background: rgba(11, 11, 11, 0.05);
    opacity: 0;
    /* Hidden at top-left; reveals toward bottom-right to read as "drawing" */
    clip-path: inset(0 100% 100% 0);
    transition:
      clip-path 0.85s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.3s ease-out;
    pointer-events: none;
  }
  [data-phase="draw"] .marquee,
  [data-phase="capture"] .marquee,
  [data-phase="analyze"] .marquee,
  [data-phase="done"] .marquee {
    opacity: 1;
    clip-path: inset(0);
  }

  /* Crosshair sits at the growing corner while drawing */
  .crosshair {
    position: absolute;
    left: 66%;
    top: 76%;
    width: 22px;
    height: 22px;
    margin: -11px 0 0 -11px;
    stroke: var(--color-ink);
    stroke-width: 1.5;
    opacity: 0;
    transition: opacity 0.25s ease-out;
    pointer-events: none;
    filter: drop-shadow(0 0 2px #fff);
  }
  [data-phase="draw"] .crosshair {
    opacity: 1;
  }

  /* Screenshot flash over the selected region */
  .flash {
    position: absolute;
    left: 6%;
    top: 30%;
    width: 60%;
    height: 46%;
    background: #fff;
    opacity: 0;
    transition: opacity 0.18s ease-out;
    pointer-events: none;
  }
  [data-phase="capture"] .flash {
    opacity: 0.85;
  }

  .captured {
    position: absolute;
    left: 6%;
    top: calc(30% - 28px);
    background: var(--color-ink);
    color: #fff;
    font-size: 12px;
    line-height: 1;
    padding: 4px 8px;
    opacity: 0;
    transition: opacity 0.25s ease-out;
    pointer-events: none;
  }
  [data-phase="capture"] .captured,
  [data-phase="analyze"] .captured,
  [data-phase="done"] .captured {
    opacity: 1;
  }

  /* Findings reveal, staggered */
  .finding {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.3s ease-out,
      transform 0.3s ease-out;
  }
  [data-phase="analyze"] .finding,
  [data-phase="done"] .finding {
    opacity: 1;
    transform: none;
  }
  .finding:nth-child(2) {
    transition-delay: 0.11s;
  }
  .finding:nth-child(3) {
    transition-delay: 0.22s;
  }
  .finding:nth-child(4) {
    transition-delay: 0.33s;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee,
    .crosshair,
    .flash,
    .captured,
    .finding {
      transition: none;
    }
  }
</style>

<script>
  const demo = document.querySelector<HTMLElement>("[data-demo]");
  if (demo) {
    const statusEl = demo.querySelector<HTMLElement>("[data-status]");
    const setStatus = (t: string) => {
      if (statusEl) statusEl.textContent = t;
    };
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    if (reduce) {
      // Skip the animation: show the finished, analyzed state.
      demo.dataset.phase = "done";
      setStatus("4 findings");
    } else {
      const sequence: [string, string, number][] = [
        ["idle", "Waiting", 800],
        ["draw", "Selecting…", 1000],
        ["capture", "Capturing…", 550],
        ["analyze", "Analyzing…", 900],
        ["done", "4 findings", 2600],
      ];
      let i = 0;
      let timer: ReturnType<typeof setTimeout>;
      let running = false;
      const tick = () => {
        const [phase, status, hold] = sequence[i % sequence.length];
        demo.dataset.phase = phase;
        setStatus(status);
        i += 1;
        timer = setTimeout(tick, hold);
      };
      // Pause the loop while the section is off-screen; never run two loops.
      const io = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting && !running) {
            running = true;
            tick();
          } else if (!entry.isIntersecting && running) {
            running = false;
            clearTimeout(timer);
          }
        },
        { threshold: 0.25 }
      );
      io.observe(demo);
    }
  }
</script>
