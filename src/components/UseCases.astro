---
const cases = [
  "AI-generated landing pages",
  "SaaS dashboards",
  "MVP interfaces",
  "no-code prototypes",
  "hackathon demos",
];
---

<section id="use-cases" class="section section-gray use-cases-section">
  <div class="container">
    <div class="section-intro center">
      <p class="section-kicker muted">Use cases</p>
      <h2>Built for builders who ship before they polish</h2>
    </div>

    <div class="use-case-strip">
      {cases.map((item) => (
        <article class="use-case-pill">
          <span></span>
          <h3>{item}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
