---
/**
 * MvpPreview.astro
 *
 * The "before" example shown inside the hero's MVP card: a full, real-looking
 * but deliberately generic AI-generated landing page (English copy). It is the
 * MAIN content of the MVP screen; the Design Humanizer panel
 * (ChromeExtensionPreview) docks over the right side.
 *
 * Intentionally "AI slop": repeated same-size cards, weak hierarchy, vague
 * marketing copy, no focal point — annotated with subtle yellow critique pills.
 * Landing-matched palette (white / beige / yellow / Montserrat). Self-contained:
 * no JS, no external images, no iframe.
 */

const features = [
  { title: "Fast Setup", copy: "Launch your project in minutes with smart AI tools." },
  { title: "Smart Design", copy: "Create beautiful layouts without design experience." },
  { title: "Modern Layout", copy: "Use flexible blocks for any type of website." },
  { title: "Easy Customization", copy: "Change content, colors, and sections quickly." },
  { title: "AI Powered", copy: "Boost your workflow with intelligent automation." },
  { title: "Responsive Blocks", copy: "Everything works across different screen sizes." },
];
---

<div class="fake-ai-site" role="img" aria-label="Example of a generic AI-generated website (before)">
  <!-- Critique labels (subtle annotations) -->
  <span class="critique-pill critique-tl">AI template</span>
  <span class="critique-pill critique-tr">generic copy</span>
  <span class="critique-pill critique-ml">same cards</span>
  <span class="critique-pill critique-bl">no focal point</span>
  <span class="critique-pill critique-br">weak hierarchy</span>

  <div class="fai-scroll">
    <!-- Top nav -->
    <header class="fai-nav">
      <span class="fai-brand"><span class="fai-brand-mark"></span>AI Site</span>
      <nav class="fai-links" aria-hidden="true"><span>Features</span><span>Pricing</span><span>About</span></nav>
      <span class="fai-nav-btn">Start</span>
    </header>

    <!-- Hero -->
    <section class="fai-hero">
      <span class="fai-badge"><span class="fai-badge-dot"></span>Made with AI</span>
      <h3 class="fai-title">AI Generated Website</h3>
      <p class="fai-sub">
        This landing page was created instantly with AI. It includes modern sections, smart content,
        and beautiful components for your next big idea.
      </p>
      <div class="fai-hero-actions">
        <span class="fai-btn fai-btn-primary">Get Started</span>
        <span class="fai-btn fai-btn-ghost">Learn More</span>
      </div>
    </section>

    <!-- Feature grid: 6 identical cards -->
    <p class="fai-section-title">Powerful Features</p>
    <div class="fai-grid">
      {features.map((f) => (
        <article class="fai-card">
          <span class="fai-card-ico"></span>
          <span class="fai-card-title">{f.title}</span>
          <span class="fai-card-copy">{f.copy}</span>
        </article>
      ))}
    </div>

    <!-- Generic CTA -->
    <section class="fai-cta">
      <div class="fai-cta-text">
        <span class="fai-cta-title">Ready to Launch?</span>
        <span class="fai-cta-sub">Everything you need to build faster, smarter, and better with AI.</span>
      </div>
      <span class="fai-btn fai-btn-primary">Get Started</span>
    </section>
  </div>
</div>

<style>
  .fake-ai-site {
    --fake-bg: #FFFFFF;
    --fake-surface: #FFF9EF;
    --fake-card: #FFFFFF;
    --fake-border: #E5D8C8;
    --fake-text: #1E1A16;
    --fake-muted: #8A7B6B;
    --fake-accent: #FFD84D;

    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background:
      radial-gradient(130% 80% at 50% 0%, rgba(255, 216, 77, 0.07), transparent 60%),
      var(--fake-bg);
    color: var(--fake-text);
    text-align: left;
    font-family: var(--font-body, "Montserrat", system-ui, sans-serif);
  }

  /* Scroll container — right padding grows with scroll progress so content
     clears the Design Humanizer panel as it slides in on the right. */
  .fai-scroll {
    position: absolute;
    inset: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 18px 20px 20px;
    padding-right: calc(20px + var(--progress, 0) * min(380px, 30%));
  }

  /* ── Top nav ──────────────────────────────────────────────────────────── */
  .fai-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--fake-border);
  }

  .fai-brand {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 13px;
    font-weight: 700;
  }

  .fai-brand-mark {
    width: 18px;
    height: 18px;
    border-radius: 6px;
    background: var(--fake-accent);
  }

  .fai-links {
    display: flex;
    gap: 18px;
    margin-left: auto;
    color: var(--fake-muted);
    font-size: 12px;
    font-weight: 500;
  }

  .fai-nav-btn {
    padding: 7px 16px;
    border-radius: 999px;
    background: var(--fake-text);
    color: #fff;
    font-size: 12px;
    font-weight: 700;
  }

  /* ── Hero (centered, weak focal point) ────────────────────────────────── */
  .fai-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 11px;
    padding: 16px 0 6px;
  }

  .fai-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: 999px;
    border: 1px solid var(--fake-border);
    background: rgba(255, 216, 77, 0.18);
    font-size: 11px;
    font-weight: 700;
  }

  .fai-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--fake-accent);
  }

  .fai-title {
    margin: 0;
    font-size: clamp(22px, 2.4vw, 34px);
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .fai-sub {
    margin: 0;
    max-width: 480px;
    color: var(--fake-muted);
    font-size: 13px;
    line-height: 1.6;
  }

  .fai-hero-actions {
    display: flex;
    gap: 10px;
    margin-top: 6px;
  }

  .fai-btn {
    padding: 9px 20px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
  }

  .fai-btn-primary { background: var(--fake-accent); color: var(--fake-text); }
  .fai-btn-ghost { background: var(--fake-card); border: 1px solid var(--fake-border); color: var(--fake-text); }

  /* ── Feature section ──────────────────────────────────────────────────── */
  .fai-section-title {
    margin: 6px 0 0;
    text-align: center;
    font-size: 14px;
    font-weight: 700;
  }

  .fai-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  .fai-card {
    display: flex;
    flex-direction: column;
    gap: 7px;
    padding: 13px;
    border-radius: 14px;
    border: 1px solid var(--fake-border);
    background: var(--fake-card);
    box-shadow: 0 6px 16px rgba(80, 58, 35, 0.04);
  }

  .fai-card-ico {
    width: 26px;
    height: 26px;
    border-radius: 8px;
    background: var(--fake-surface);
    border: 1px solid var(--fake-border);
  }

  .fai-card-title { font-size: 12px; font-weight: 700; }

  .fai-card-copy {
    font-size: 11px;
    line-height: 1.45;
    color: var(--fake-muted);
  }

  /* ── Generic CTA ──────────────────────────────────────────────────────── */
  .fai-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: auto;
    padding: 16px 18px;
    border-radius: 16px;
    border: 1px solid var(--fake-border);
    background: linear-gradient(135deg, rgba(255, 216, 77, 0.2), var(--fake-surface));
  }

  .fai-cta-text { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .fai-cta-title { font-size: 15px; font-weight: 800; }
  .fai-cta-sub { font-size: 11px; color: var(--fake-muted); line-height: 1.4; }

  /* ── Critique pills ───────────────────────────────────────────────────── */
  .critique-pill {
    position: absolute;
    z-index: 3;
    padding: 3px 9px;
    border-radius: 999px;
    background: var(--fake-accent);
    border: 1px solid rgba(30, 26, 22, 0.12);
    color: #1E1A16;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.02em;
    box-shadow: 0 4px 12px rgba(80, 58, 35, 0.12);
    pointer-events: none;
    white-space: nowrap;
    opacity: 0.92;
  }

  .critique-tl { top: 60px; left: 16px; }
  .critique-tr { top: 14px; left: 40%; }
  .critique-ml { top: 46%; left: 12px; }
  .critique-bl { bottom: 92px; left: 18px; }
  .critique-br { bottom: 20px; left: 42%; }

  /* ── Responsive ───────────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .fai-scroll { padding: 14px 14px 16px; padding-right: 14px; gap: 12px; }
    .fai-links { gap: 12px; }
    .fai-grid { gap: 8px; }
    .fai-card { padding: 10px; }
    /* Panel is a bottom sheet on small screens — no right padding needed */
    .critique-tr, .critique-br { display: none; }
  }

  @media (max-width: 560px) {
    .fai-links { display: none; }
    .fai-grid { grid-template-columns: repeat(2, 1fr); }
    .critique-ml, .critique-bl { display: none; }
  }
</style>
