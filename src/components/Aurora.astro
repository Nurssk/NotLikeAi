---
interface Props {
  colorStops?: [string, string, string];
  speed?: number;
  blend?: number;
  amplitude?: number;
  opacity?: number;
}

const {
  colorStops = ["#ffffff", "#ffffff", "#ffffff"],
  speed = 0.55,
  blend = 0.48,
  amplitude = 1,
  opacity = 0.34,
} = Astro.props;
---

<div
  class="aurora"
  data-c1={colorStops[0]}
  data-c2={colorStops[1]}
  data-c3={colorStops[2]}
  data-speed={speed}
  data-blend={blend}
  data-amplitude={amplitude}
  data-opacity={opacity}
  aria-hidden="true"
></div>

<script>
  import type { Mesh, Program, Renderer } from "ogl";

  let oglPromise: Promise<typeof import("ogl")> | null = null;
  const loadOgl = () => (oglPromise ??= import("ogl"));

  const RES = 0.45;
  const MAX_DPR = 1.35;

  const hexToRgb = (hex: string): [number, number, number] => {
    const match = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return match
      ? [parseInt(match[1], 16) / 255, parseInt(match[2], 16) / 255, parseInt(match[3], 16) / 255]
      : [1, 1, 1];
  };

  const vert = `
attribute vec2 position;
void main() {
  gl_Position = vec4(position, 0.0, 1.0);
}`;

  const frag = `
precision highp float;

uniform float uTime;
uniform float uAmplitude;
uniform float uBlend;
uniform float uOpacity;
uniform vec2 uResolution;
uniform vec3 uColorA;
uniform vec3 uColorB;
uniform vec3 uColorC;

vec3 permute(vec3 x) {
  return mod(((x * 34.0) + 1.0) * x, 289.0);
}

float snoise(vec2 v) {
  const vec4 C = vec4(
    0.211324865405187, 0.366025403784439,
    -0.577350269189626, 0.024390243902439
  );
  vec2 i = floor(v + dot(v, C.yy));
  vec2 x0 = v - i + dot(i, C.xx);
  vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
  vec4 x12 = x0.xyxy + C.xxzz;
  x12.xy -= i1;
  i = mod(i, 289.0);

  vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
  vec3 m = max(0.5 - vec3(dot(x0, x0), dot(x12.xy, x12.xy), dot(x12.zw, x12.zw)), 0.0);
  m = m * m;
  m = m * m;

  vec3 x = 2.0 * fract(p * C.www) - 1.0;
  vec3 h = abs(x) - 0.5;
  vec3 ox = floor(x + 0.5);
  vec3 a0 = x - ox;
  m *= 1.79284291400159 - 0.85373472095314 * (a0 * a0 + h * h);

  vec3 g;
  g.x = a0.x * x0.x + h.x * x0.y;
  g.yz = a0.yz * x12.xz + h.yz * x12.yw;
  return 130.0 * dot(m, g);
}

void main() {
  vec2 uv = gl_FragCoord.xy / uResolution.xy;
  vec3 firstMix = mix(uColorA, uColorB, smoothstep(0.0, 0.52, uv.x));
  vec3 rampColor = mix(firstMix, uColorC, smoothstep(0.42, 1.0, uv.x));

  float wave = snoise(vec2(uv.x * 2.2 + uTime * 0.1, uTime * 0.25)) * 0.5 * uAmplitude;
  float height = exp(wave);
  height = uv.y * 2.0 - height + 0.2;

  float intensity = 0.62 * height;
  float alpha = smoothstep(0.2 - uBlend * 0.5, 0.2 + uBlend * 0.5, intensity);
  vec3 color = intensity * rampColor;

  gl_FragColor = vec4(color * alpha, alpha * uOpacity);
}`;

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const containers = document.querySelectorAll<HTMLElement>(".aurora");

  containers.forEach((container) => {
    if (reduce) return;

    const uniforms = {
      uTime: { value: 0 },
      uAmplitude: { value: Number(container.dataset.amplitude) },
      uBlend: { value: Number(container.dataset.blend) },
      uOpacity: { value: Number(container.dataset.opacity) },
      uResolution: { value: [1, 1] as number[] },
      uColorA: { value: hexToRgb(container.dataset.c1 ?? "#ffffff") },
      uColorB: { value: hexToRgb(container.dataset.c2 ?? "#ffffff") },
      uColorC: { value: hexToRgb(container.dataset.c3 ?? "#ffffff") },
    };

    let speed = Number(container.dataset.speed);
    let renderer: Renderer | null = null;
    let program: Program | null = null;
    let mesh: Mesh | null = null;
    let raf = 0;
    let ready = false;

    const updateSize = () => {
      if (!renderer || !program) return;
      const width = container.clientWidth;
      const height = container.clientHeight;
      if (!width || !height) return;
      renderer.dpr = Math.min(window.devicePixelRatio || 1, MAX_DPR);
      renderer.setSize(Math.max(1, Math.round(width * RES)), Math.max(1, Math.round(height * RES)));
      renderer.gl.canvas.style.width = "100%";
      renderer.gl.canvas.style.height = "100%";
      uniforms.uResolution.value = [renderer.gl.drawingBufferWidth, renderer.gl.drawingBufferHeight];
    };

    const render = (time: number) => {
      if (!renderer || !mesh) return;
      uniforms.uTime.value = time * 0.001 * speed;
      renderer.render({ scene: mesh });
      raf = requestAnimationFrame(render);
    };

    const setChaos = (detail: {
      colorStops?: [string, string, string];
      speed?: number;
      blend?: number;
      amplitude?: number;
      opacity?: number;
    }) => {
      if (detail.colorStops) {
        uniforms.uColorA.value = hexToRgb(detail.colorStops[0]);
        uniforms.uColorB.value = hexToRgb(detail.colorStops[1]);
        uniforms.uColorC.value = hexToRgb(detail.colorStops[2]);
      }
      if (typeof detail.speed === "number") speed = detail.speed;
      if (typeof detail.blend === "number") uniforms.uBlend.value = detail.blend;
      if (typeof detail.amplitude === "number") uniforms.uAmplitude.value = detail.amplitude;
      if (typeof detail.opacity === "number") uniforms.uOpacity.value = detail.opacity;
      container.classList.remove("aurora-shift");
      requestAnimationFrame(() => container.classList.add("aurora-shift"));
    };

    window.addEventListener("aurora:chaos", (event) => {
      setChaos((event as CustomEvent).detail ?? {});
    });

    const init = async () => {
      try {
        const { Renderer, Program, Triangle, Mesh } = await loadOgl();
        renderer = new Renderer({ alpha: true, premultipliedAlpha: true });
        const gl = renderer.gl;
        gl.clearColor(0, 0, 0, 0);
        gl.enable(gl.BLEND);
        gl.blendFunc(gl.ONE, gl.ONE_MINUS_SRC_ALPHA);
        gl.canvas.style.width = "100%";
        gl.canvas.style.height = "100%";
        container.appendChild(gl.canvas);

        const geometry = new Triangle(gl);
        program = new Program(gl, { vertex: vert, fragment: frag, uniforms });
        mesh = new Mesh(gl, { geometry, program });
        updateSize();
        ready = true;
        container.classList.add("aurora-ready");
        raf = requestAnimationFrame(render);
      } catch {
        container.classList.add("aurora-ready");
      }
    };

    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting && !ready) init();
    });
    observer.observe(container);
    window.addEventListener("resize", updateSize);
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) cancelAnimationFrame(raf);
      else if (ready) raf = requestAnimationFrame(render);
    });
  });
</script>

<style>
  .aurora {
    position: absolute;
    inset: -22% -10% auto;
    height: 62%;
    overflow: hidden;
    opacity: 0;
    filter: blur(0.4px);
    mix-blend-mode: screen;
    pointer-events: none;
    transform: translate3d(0, 0, 0) rotate(0deg) scaleX(1.05);
    transition:
      opacity 0.8s ease,
      transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .aurora-ready {
    opacity: 1;
  }

  .aurora-shift {
    transform: translate3d(0, 5%, 0) rotate(2deg) scaleX(1.12);
  }

  .aurora :global(canvas) {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
