---
/**
 * ChromeExtensionPreview.astro
 *
 * The Design Humanizer Chrome-extension product panel, recreated from the
 * mockup structure in mockups/extension-panel/ExtensionPanelMockup.tsx
 * (header + status + primary action + analysis cards + footer actions),
 * recolored to the landing's warm yellow-orange product palette.
 *
 * It is an overlay panel inside the expanding MVP shell. It slides in from the
 * right and fades in driven by the section's --progress scroll variable
 * (inherited from the ancestor .hero-mvp-scroll). It reads like a real Chrome
 * extension docked over the bad AI-generated website behind it.
 *
 * Self-contained: no JS, no external images, no new dependencies.
 */

const sections = [
  { label: "Hierarchy", state: "weak" },
  { label: "Spacing", state: "ok" },
  { label: "Repetition", state: "weak" },
  { label: "CTA focus", state: "weak" },
  { label: "Layout rhythm", state: "ok" },
];

const findings = [
  "6 similar cards detected",
  "Weak primary CTA",
  "Repeated section rhythm",
  "No clear focal point",
];
---

<aside class="extension-panel" aria-label="Design Humanizer Chrome extension">
  <div class="ext-chrome">
    <!-- Warm amber header bar -->
    <header class="ext-head">
      <div class="ext-brand">
        <span class="ext-logo">DH</span>
        <div class="ext-brand-text">
          <span class="ext-name">Design Humanizer</span>
          <span class="ext-sub">Chrome extension</span>
        </div>
      </div>
      <span class="ext-status"><span class="ext-status-dot"></span>Analyzing UI</span>
    </header>

    <!-- Scrollable body -->
    <div class="ext-body">
      <button class="ext-primary" type="button" tabindex="-1">Humanize this page</button>

      <section class="ext-card">
        <div class="ext-card-head">
          <span class="ext-card-title">Analysis</span>
          <span class="ext-scan">Scanning…</span>
        </div>
        <ul class="ext-sections">
          {sections.map((s) => (
            <li class={`ext-section ext-${s.state}`}>
              <span class="ext-section-label">{s.label}</span>
              <span class="ext-section-bar"><span class="ext-section-fill"></span></span>
              <span class="ext-section-flag">{s.state === "weak" ? "Weak" : "OK"}</span>
            </li>
          ))}
        </ul>
      </section>

      <section class="ext-card">
        <div class="ext-card-head">
          <span class="ext-card-title">Findings</span>
          <span class="ext-count">4</span>
        </div>
        <ul class="ext-findings">
          {findings.map((f) => (
            <li class="ext-finding"><span class="ext-finding-dot"></span>{f}</li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Footer actions -->
    <footer class="ext-foot">
      <button class="ext-btn ext-btn-yellow" type="button" tabindex="-1">Preview changes</button>
      <div class="ext-foot-row">
        <button class="ext-btn ext-btn-amber" type="button" tabindex="-1">Apply layout</button>
        <button class="ext-btn ext-btn-ghost" type="button" tabindex="-1">Copy CSS suggestions</button>
      </div>
    </footer>
  </div>
</aside>

<style>
  .extension-panel {
    /* Light, landing-matched product palette with a YELLOW accent */
    --product-bg: #FFFFFF;
    --product-surface: #F8FAFA;
    --product-card: #FFFFFF;
    --product-card-elevated: #ECFBF8;
    --product-primary: #00F5D4;
    --product-primary-bright: #0A6B5D; /* readable amber for text on light */
    --product-primary-deep: #00DDC0;
    --product-border: rgba(230, 236, 236, 0.95);
    --product-border-strong: rgba(0, 221, 192, 0.7);
    --product-text: #101112;
    --product-muted: #5F666A;
    --product-soft: #9AA3A6;
    --product-success: #101112; /* neutral dark for "OK" states */

    /* Scroll-driven reveal: enters from the right as --progress passes ~0.42 */
    --reveal: clamp(0, calc((var(--progress, 0) - 0.42) * 2.4), 1);

    position: absolute;
    top: 32px;
    right: 32px;
    width: min(380px, 34%);
    height: calc(100% - 64px);
    z-index: 4;
    border-radius: 28px;
    background: var(--product-bg);
    border: 1px solid var(--product-border);
    box-shadow: 0 28px 80px rgba(16, 17, 18, 0.18), 0 0 44px rgba(0, 245, 212, 0.14);
    overflow: hidden;
    opacity: var(--reveal);
    transform: translateX(calc((1 - var(--reveal)) * 120%));
    will-change: transform, opacity;
  }

  .ext-chrome {
    display: flex;
    flex-direction: column;
    height: 100%;
    font-family: var(--font-body, "Montserrat", system-ui, sans-serif);
    color: var(--product-text);
    text-align: left;
  }

  /* ── Warm header ──────────────────────────────────────────────────────── */
  .ext-head {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 14px 16px;
    background:
      radial-gradient(circle at 80% 0%, rgba(0, 245, 212, 0.32), transparent 120px),
      linear-gradient(135deg, var(--product-primary-deep) 0%, var(--product-primary) 100%);
    color: #101112;
  }

  .ext-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .ext-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    border-radius: 11px;
    background: rgba(16, 17, 18, 0.12);
    border: 1px solid rgba(16, 17, 18, 0.22);
    font-size: 12px;
    font-weight: 800;
    color: #101112;
  }

  .ext-brand-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .ext-name {
    font-size: 14px;
    font-weight: 800;
    line-height: 1.2;
  }

  .ext-sub {
    font-size: 10px;
    font-weight: 600;
    color: rgba(16, 17, 18, 0.68);
  }

  .ext-status {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex: 0 0 auto;
    padding: 5px 9px;
    border-radius: 999px;
    background: rgba(16, 17, 18, 0.12);
    border: 1px solid rgba(16, 17, 18, 0.22);
    font-size: 10px;
    font-weight: 700;
    white-space: nowrap;
  }

  .ext-status-dot {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #101112;
    box-shadow: 0 0 10px rgba(16, 17, 18, 0.35);
  }

  /* ── Body ─────────────────────────────────────────────────────────────── */
  .ext-body {
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px 14px 6px;
  }

  .ext-primary {
    flex: 0 0 auto;
    width: 100%;
    height: 42px;
    border: 0;
    border-radius: 13px;
    background: linear-gradient(90deg, var(--product-primary-deep), var(--product-primary));
    color: #101112;
    font-size: 13px;
    font-weight: 800;
    box-shadow: 0 12px 26px rgba(0, 221, 192, 0.4);
    cursor: default;
  }

  .ext-card {
    flex: 0 0 auto;
    padding: 12px;
    border-radius: 16px;
    border: 1px solid var(--product-border);
    background: var(--product-card);
  }

  .ext-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .ext-card-title {
    font-size: 12px;
    font-weight: 800;
  }

  .ext-scan {
    font-size: 10px;
    font-weight: 700;
    color: var(--product-primary-bright);
  }

  .ext-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    background: rgba(0, 245, 212, 0.22);
    color: var(--product-primary-bright);
    font-size: 10px;
    font-weight: 800;
  }

  /* Analysis sections */
  .ext-sections {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .ext-section {
    display: grid;
    grid-template-columns: 78px 1fr auto;
    align-items: center;
    gap: 9px;
  }

  .ext-section-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--product-text);
  }

  .ext-section-bar {
    height: 6px;
    border-radius: 999px;
    background: var(--product-card-elevated);
    overflow: hidden;
  }

  .ext-section-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: var(--product-primary);
  }

  .ext-ok .ext-section-fill { width: 82%; background: var(--product-success); }
  .ext-weak .ext-section-fill { width: 34%; background: var(--product-primary); }

  .ext-section-flag {
    font-size: 9px;
    font-weight: 800;
    padding: 2px 7px;
    border-radius: 999px;
  }

  .ext-ok .ext-section-flag {
    color: var(--product-muted);
    background: rgba(16, 17, 18, 0.06);
  }

  .ext-weak .ext-section-flag {
    color: #101112;
    background: rgba(0, 245, 212, 0.5);
  }

  /* Findings */
  .ext-findings {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ext-finding {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 11px;
    font-weight: 600;
    color: var(--product-muted);
  }

  .ext-finding-dot {
    width: 7px;
    height: 7px;
    flex: 0 0 auto;
    border-radius: 999px;
    background: var(--product-primary);
    border: 1px solid var(--product-border-strong);
  }

  /* ── Footer ───────────────────────────────────────────────────────────── */
  .ext-foot {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 12px 14px 14px;
    border-top: 1px solid var(--product-border);
    background: linear-gradient(180deg, var(--product-surface), var(--product-bg));
  }

  .ext-foot-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .ext-btn {
    border: 0;
    border-radius: 11px;
    padding: 9px 10px;
    font-size: 11px;
    font-weight: 800;
    cursor: default;
    text-align: center;
  }

  .ext-btn-yellow {
    background: linear-gradient(90deg, var(--product-primary-deep), var(--product-primary));
    color: #101112;
  }

  .ext-btn-amber {
    background: var(--product-card-elevated);
    border: 1px solid var(--product-border-strong);
    color: var(--product-primary-bright);
  }

  .ext-btn-ghost {
    background: var(--product-card);
    border: 1px solid var(--product-border);
    color: var(--product-muted);
  }

  /* ── Responsive: panel becomes a bottom sheet on small screens ────────── */
  @media (max-width: 760px) {
    .extension-panel {
      top: auto;
      left: 14px;
      right: 14px;
      bottom: 14px;
      width: auto;
      height: min(58%, 380px);
      border-radius: 22px;
      /* Slide up from the bottom instead of in from the right */
      transform: translateY(calc((1 - var(--reveal)) * 120%));
    }
  }

  /* ── Reduced motion: show statically, no slide ────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .extension-panel {
      opacity: 1;
      transform: none;
    }
  }
</style>
