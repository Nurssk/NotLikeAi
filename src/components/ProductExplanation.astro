---
const improvements = [
  "Находит слабую иерархию",
  "Убирает одинаковость блоков",
  "Усиливает главный фокус",
  "Перестраивает композицию",
  "Делает интерфейс визуально убедительнее",
];

const audiences = [
  "разработчиков",
  "indie hackers",
  "AI app builders",
  "no-code builders",
  "стартап-команд",
  "студентов на hackathon/demo day",
];
---

<section class="product-explanation">
  <div class="container product-explanation-inner">
    <section class="product-explanation-block product-explanation-lead">
      <p class="section-kicker accent">Product</p>
      <h2>Что делает Design Humanizer</h2>
      <p>
        Design Humanizer помогает превратить обычный AI-generated интерфейс в более осмысленный
        дизайн: с понятной иерархией, правильными акцентами, хорошим ритмом, чистыми карточками и
        структурой, которая ведет пользователя.
      </p>
    </section>

    <section class="product-explanation-block">
      <div class="product-explanation-heading">
        <h2>Он не меняет смысл. Он меняет подачу.</h2>
      </div>
      <div class="product-card-grid product-card-grid-five">
        {improvements.map((item) => (
          <article class="product-info-card">
            <span aria-hidden="true"></span>
            <h3>{item}</h3>
          </article>
        ))}
      </div>
    </section>

    <section class="product-explanation-block">
      <div class="product-explanation-heading">
        <h2>Для кого это</h2>
      </div>
      <div class="product-card-grid">
        {audiences.map((item) => (
          <article class="product-info-card compact-card">
            <span aria-hidden="true"></span>
            <h3>{item}</h3>
          </article>
        ))}
      </div>
    </section>
  </div>
</section>
