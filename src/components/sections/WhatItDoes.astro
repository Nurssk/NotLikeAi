---
const cards = [
  { title: "Find weak hierarchy", copy: "Detects when every block has the same visual weight and nothing stands out." },
  { title: "Improve layout rhythm", copy: "Breaks repetitive grids and helps the page feel more composed." },
  { title: "Strengthen the main action", copy: "Makes the primary CTA easier to notice and understand." },
  { title: "Clean up spacing", copy: "Improves grouping, margins, and visual balance between sections." },
];
---

<section id="what" class="lp-section">
  <div class="lp-container">
    <div class="lp-head">
      <span class="lp-label">What it does</span>
      <h2 class="lp-title">Turn AI-generated layouts into interfaces with intention.</h2>
      <p class="lp-text">
        AI builders can create screens fast, but the result often feels generic: equal cards, weak hierarchy,
        repeated sections, and no clear focus.
      </p>
      <p class="lp-text">
        Design Humanizer helps you improve that first draft. It analyzes the page, detects what feels unfinished,
        and suggests a cleaner visual structure — without changing your content.
      </p>
    </div>

    <div class="lp-grid lp-grid--2">
      {cards.map((c) => (
        <article class="lp-card">
          <span class="lp-card-ico" aria-hidden="true"></span>
          <h3>{c.title}</h3>
          <p>{c.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
