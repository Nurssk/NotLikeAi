---
const steps = [
  {
    title: "Read the page",
    detail: "Design Humanizer scans the visible structure of your interface.",
    bullets: ["sections and cards", "buttons and CTAs", "spacing and repeated patterns"],
    icon: "scan",
  },
  {
    title: "Find what feels generic",
    detail: "It detects the patterns that make AI-generated UI feel unfinished.",
    bullets: ["weak hierarchy", "repeated cards", "unclear visual focus"],
    icon: "find",
  },
  {
    title: "Suggest improvements",
    detail: "It gives practical design recommendations without changing your content.",
    bullets: ["stronger grouping", "better rhythm", "clearer CTA priority"],
    icon: "suggest",
  },
  {
    title: "Preview the result",
    detail: "You compare the same content with a cleaner, more intentional structure.",
    bullets: ["before and after view", "improved composition", "ready-to-apply direction"],
    icon: "preview",
  },
];
---

<section id="how" class="how-it-works-section">
  <div class="how-inner">
    <div class="how-layout">
      <div class="how-copy">
        <div class="how-head">
          <h2 class="how-title">How it works</h2>
        </div>

        <div class="how-cards" aria-label="How Design Humanizer works">
          {steps.map((step) => (
            <article class="how-card" tabindex="0">
              <span class="how-card-ico" aria-hidden="true">
                {step.icon === "scan" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M3 12h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "find" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
                    <path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "suggest" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M9 18h6M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  </svg>
                )}
                {step.icon === "preview" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
                    <path d="M12 4v16" stroke="currentColor" stroke-width="1.8" stroke-dasharray="2 2.4"/>
                  </svg>
                )}
              </span>

              <div class="how-card-copy">
                <h3 class="how-card-title">{step.title}</h3>

                <div class="how-card-details">
                  <p class="how-card-detail">{step.detail}</p>
                  <ul class="how-card-bullets">
                    {step.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <figure class="how-demo" aria-label="Design Humanizer demo video">
        <video
          class="how-demo-video"
          src="/demo/demoview.mp4"
          autoplay
          muted
          loop
          playsinline
          controls
          preload="metadata"
        ></video>
      </figure>
    </div>
  </div>
</section>

<style>
  .how-it-works-section {
    position: relative;
    overflow: hidden;
    background: var(--bg, #ffffff);
  }

  .how-inner {
    width: min(100% - 48px, 1320px);
    margin: 0 auto;
    padding: clamp(78px, 10vw, 126px) 0;
  }

  .how-layout {
    display: grid;
    grid-template-columns: minmax(330px, 0.78fr) minmax(0, 1.22fr);
    align-items: center;
    gap: clamp(36px, 5.8vw, 86px);
  }

  .how-copy {
    min-width: 0;
  }

  .how-head {
    max-width: 460px;
    margin: 0 0 32px;
    text-align: left;
  }

  .how-title {
    margin: 0;
    color: var(--text, #101112);
    font-family: var(--font-display, "Montserrat", system-ui, sans-serif);
    font-size: clamp(34px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.015em;
  }

  .how-demo {
    position: relative;
    justify-self: end;
    width: min(100%, 800px);
    margin: 0;
    overflow: hidden;
    border: 0;
    border-radius: 28px;
    background: var(--accent, #81D8D0);
    box-shadow: 0 28px 90px rgba(129, 216, 208, 0.32), 0 18px 50px rgba(16, 17, 18, 0.08);
    transform: translateX(clamp(10px, 2.2vw, 30px));
  }

  .how-demo::before {
    content: "";
    position: absolute;
    inset: -1px;
    z-index: 1;
    border-radius: inherit;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.56);
    pointer-events: none;
  }

  .how-demo-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--accent, #81D8D0);
  }

  .how-cards {
    display: grid;
    gap: 12px;
    align-items: start;
  }

  .how-card {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr);
    align-items: start;
    gap: 16px;
    min-height: 82px;
    padding: 18px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(129, 216, 208, 0.36);
    box-shadow: 0 8px 24px rgba(129, 216, 208, 0.09);
    overflow: hidden;
    cursor: default;
    transition:
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 240ms ease,
      box-shadow 260ms ease,
      background 240ms ease;
    will-change: transform;
  }

  .how-card:hover,
  .how-card:focus-within {
    z-index: 3;
    transform: translateX(8px) scale(1.035);
    border-color: rgba(129, 216, 208, 0.86);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 70px rgba(129, 216, 208, 0.18), 0 16px 40px rgba(16, 17, 18, 0.08);
  }

  .how-card:focus-visible {
    outline: 2px solid var(--accent, #81D8D0);
    outline-offset: 3px;
  }

  .how-card-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 54px;
    height: 54px;
    flex: 0 0 auto;
    border-radius: 16px;
    background: rgba(129, 216, 208, 0.22);
    border: 1px solid rgba(129, 216, 208, 0.32);
    color: var(--text, #101112);
    transition:
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      background 240ms ease,
      border-color 240ms ease;
  }

  .how-card:hover .how-card-ico,
  .how-card:focus-within .how-card-ico {
    transform: scale(1.06);
    background: var(--accent, #81D8D0);
    border-color: transparent;
  }

  .how-card-copy {
    min-width: 0;
  }

  .how-card-title {
    margin: 4px 0 0;
    color: var(--text, #101112);
    font-size: clamp(18px, 1.7vw, 22px);
    font-weight: 800;
    line-height: 1.22;
  }

  .how-card-details {
    opacity: 0;
    max-height: 0;
    transform: translateY(-6px);
    overflow: hidden;
    transition:
      opacity 260ms ease,
      max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms ease;
  }

  .how-card:hover .how-card-details,
  .how-card:focus-within .how-card-details {
    opacity: 1;
    max-height: 220px;
    transform: translateY(0);
  }

  .how-card-detail {
    margin: 12px 0 12px;
    color: var(--muted, #5f666a);
    font-size: 15px;
    line-height: 1.6;
    max-width: 42ch;
  }

  .how-card-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .how-card-bullets li {
    position: relative;
    padding-left: 22px;
    color: var(--text, #101112);
    font-size: 14px;
    font-weight: 600;
  }

  .how-card-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--accent, #81D8D0);
    border: 1px solid rgba(16, 17, 18, 0.12);
  }

  @media (max-width: 980px) {
    .how-layout {
      grid-template-columns: 1fr;
    }
    .how-head {
      max-width: 680px;
    }
    .how-demo {
      order: -1;
      justify-self: stretch;
      width: 100%;
      transform: none;
      border-radius: 20px;
      margin-bottom: 24px;
    }
  }

  @media (max-width: 640px) {
    .how-inner {
      width: min(100% - 32px, 1320px);
      padding: 72px 0;
    }
    .how-card {
      grid-template-columns: 46px minmax(0, 1fr);
      gap: 14px;
      padding: 16px;
    }
    .how-card-ico {
      width: 46px;
      height: 46px;
      border-radius: 14px;
    }
    .how-card:hover,
    .how-card:focus-within {
      transform: none;
    }
    .how-card-details {
      opacity: 1;
      max-height: none;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .how-card,
    .how-card-ico,
    .how-card-details {
      transition: none !important;
    }
    .how-card:hover,
    .how-card:focus-within {
      transform: none !important;
    }
    .how-card-details {
      opacity: 1 !important;
      max-height: none !important;
      transform: none !important;
    }
  }
</style>
