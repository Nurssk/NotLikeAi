---
import StartButton from "../StartButton";

const steps = [
  {
    title: "Create screenshot",
    detail: "Design Humanizer captures the page, parses its HTML and CSS, and scans the visible structure of your interface.",
    bullets: ["sections and cards", "buttons and CTAs", "spacing and repeated patterns"],
    icon: "scan",
  },
  {
    title: "Find what feels generic",
    detail: "It detects the patterns that make AI-generated UI feel unfinished.",
    bullets: ["weak hierarchy", "repeated cards", "unclear visual focus"],
    icon: "find",
  },
  {
    title: "Suggest improvements",
    detail: "It gives practical design recommendations without changing your content.",
    bullets: ["stronger grouping", "better rhythm", "clearer CTA priority"],
    icon: "suggest",
  },
  {
    title: "Preview the result",
    detail: "You compare the same content with a cleaner, more intentional structure.",
    bullets: ["before and after view", "improved composition", "ready-to-apply direction"],
    icon: "preview",
  },
];
---

<section id="how" class="how-it-works-section" style={`--how-pin-height: ${steps.length + 1}00vh;`} data-how-section>
  <div class="how-inner">
    <div class="how-layout">
      <div class="how-copy">
        <div class="how-head">
          <h2 class="how-title">How it works</h2>
        </div>

        <div class="how-cards" aria-label="How Design Humanizer works">
          {steps.map((step) => (
            <article
              class="how-card"
              data-how-card
            >
              <span class="how-card-ico" aria-hidden="true">
                {step.icon === "scan" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M3 12h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "find" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
                    <path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "suggest" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M9 18h6M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  </svg>
                )}
                {step.icon === "preview" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
                    <path d="M12 4v16" stroke="currentColor" stroke-width="1.8" stroke-dasharray="2 2.4"/>
                  </svg>
                )}
              </span>

              <div class="how-card-copy">
                <h3 class="how-card-title">{step.title}</h3>

                <div class="how-card-details">
                  <p class="how-card-detail">{step.detail}</p>
                  <ul class="how-card-bullets">
                    {step.bullets.map((b) => (
                      <li>{b}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="how-demo-stack">
        <figure class="how-demo" aria-label="Design Humanizer demo video">
          <video
            class="how-demo-video"
            src="/demo/demovid.mp4"
            autoplay
            muted
            loop
            playsinline
            controls
            preload="metadata"
          ></video>
        </figure>

        <div class="how-extension-action">
          <StartButton client:visible size="lg" />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-how-section]").forEach((section) => {
    const cards = Array.from(section.querySelectorAll<HTMLElement>("[data-how-card]"));
    let frame = 0;

    const clamp = (value: number, min = 0, max = 1) => Math.min(max, Math.max(min, value));

    const smoothstep = (value: number) => {
      const t = clamp(value);
      return t * t * (3 - 2 * t);
    };

    const setCardProgress = (card: HTMLElement, amount: number) => {
      const openAmount = smoothstep(amount);
      card.style.setProperty("--open", openAmount.toFixed(3));
      card.style.setProperty("--detail-height", `${Math.round(openAmount * 220)}px`);
      card.style.setProperty("--detail-y", `${(1 - openAmount) * -6}px`);
      card.classList.toggle("is-open", openAmount > 0.12);
    };

    const closeAllCards = () => {
      cards.forEach((card) => setCardProgress(card, 0));
    };

    const syncCards = () => {
      frame = 0;

      const scrollRange = section.offsetHeight - window.innerHeight;
      if (scrollRange <= 0 || cards.length === 0) {
        closeAllCards();
        return;
      }

      const rect = section.getBoundingClientRect();
      const progress = clamp(-rect.top / scrollRange);
      const introProgress = 0.08;

      if (progress < introProgress) {
        closeAllCards();
        return;
      }

      const activeProgress = clamp((progress - introProgress) / (1 - introProgress));
      const cursor = activeProgress * cards.length - 1;

      cards.forEach((card, index) => {
        const openAmount = 1 - Math.abs(cursor - index);
        setCardProgress(card, openAmount);
      });
    };

    const requestSync = () => {
      if (frame) return;
      frame = window.requestAnimationFrame(syncCards);
    };

    syncCards();
    window.addEventListener("scroll", requestSync, { passive: true });
    window.addEventListener("resize", requestSync, { passive: true });
  });
</script>

<style>
  .how-it-works-section {
    position: relative;
    min-height: var(--how-pin-height, 500vh);
    overflow: visible;
    background: var(--bg, #f4efe6);
  }

  .how-inner {
    position: sticky;
    top: 0;
    width: min(100% - 48px, 1320px);
    min-height: 100vh;
    margin: 0 auto;
    padding: clamp(56px, 8vh, 88px) 0;
    display: flex;
    align-items: center;
  }

  .how-layout {
    width: 100%;
    display: grid;
    grid-template-columns: minmax(330px, 0.78fr) minmax(0, 1.22fr);
    align-items: center;
    gap: clamp(32px, 5.8vw, 88px);
  }

  .how-copy {
    min-width: 0;
  }

  .how-head {
    max-width: 460px;
    margin: 0 0 32px;
    text-align: left;
  }

  .how-title {
    margin: 0;
    color: var(--text, #111111);
    font-family: var(--font-display, "Archivo", system-ui, sans-serif);
    font-size: clamp(34px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .how-demo-stack {
    position: relative;
    justify-self: end;
    display: grid;
    justify-items: end;
    gap: 14px;
    width: min(100%, 800px);
    transform: translateX(clamp(8px, 2vw, 24px));
  }

  .how-extension-action {
    justify-self: end;
  }

  .how-demo {
    position: relative;
    width: 100%;
    margin: 0;
    overflow: hidden;
    border: 0;
    border-radius: 12px;
    background: var(--accent, #111111);
    box-shadow: 0 2px 8px rgba(16, 17, 18, 0.1);
  }

  .how-demo::before {
    display: none;
  }

  .how-demo-video {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: var(--accent, #111111);
  }

  .how-cards {
    display: grid;
    gap: 8px;
    align-items: start;
  }

  .how-card {
    --open: 0;
    --detail-height: 0px;
    --detail-y: -6px;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    align-items: start;
    gap: 16px;
    min-height: 80px;
    padding: 16px;
    border-radius: 12px;
    background: rgba(250, 247, 243, 0.76);
    border: 0;
    box-shadow: 0 1px 4px rgba(16, 17, 18, 0.06);
    overflow: hidden;
    cursor: default;
    touch-action: pan-y;
    transition:
      border-color 240ms ease,
      box-shadow 260ms ease,
      background 240ms ease;
  }

  .how-card.is-open {
    z-index: 3;
    background: rgba(250, 247, 243, 0.94);
    box-shadow: 0 2px 8px rgba(16, 17, 18, 0.1);
  }

  .how-card-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    flex: 0 0 auto;
    border-radius: 10px;
    background: rgba(17, 17, 17, 0.18);
    border: 0;
    color: var(--text, #111111);
    transition:
      transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
      background 240ms ease,
      border-color 240ms ease;
  }

  .how-card.is-open .how-card-ico {
    background: var(--accent, #111111);
    color: var(--on-accent, #FAF7F3);
  }

  .how-card-copy {
    min-width: 0;
  }

  .how-card-title {
    margin: 0;
    color: var(--text, #111111);
    font-size: clamp(18px, 1.7vw, 21px);
    font-weight: 800;
    line-height: 1.22;
  }

  .how-card-details {
    opacity: var(--open);
    max-height: var(--detail-height);
    transform: translateY(var(--detail-y));
    overflow: hidden;
    will-change: max-height, opacity, transform;
  }

  .how-card-detail {
    margin: 8px 0 12px;
    color: var(--text, #111111);
    font-size: 15px;
    line-height: 1.6;
    max-width: 42ch;
  }

  .how-card-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .how-card-bullets li {
    position: relative;
    padding-left: 20px;
    color: var(--text, #111111);
    font-size: 14px;
    font-weight: 600;
  }

  .how-card-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--accent, #111111);
  }

  @media (max-width: 980px) {
    .how-layout {
      grid-template-columns: 1fr;
    }
    .how-head {
      max-width: 680px;
    }
    .how-demo-stack {
      order: -1;
      justify-self: stretch;
      width: 100%;
      transform: none;
      margin-bottom: 24px;
    }
    .how-demo {
      border-radius: 12px;
    }
  }

  @media (max-width: 640px) {
    .how-inner {
      width: min(100% - 32px, 1320px);
      padding: 72px 0;
    }
    .how-card {
      grid-template-columns: 46px minmax(0, 1fr);
      gap: 16px;
      padding: 16px;
    }
    .how-card-ico {
      width: 46px;
      height: 46px;
      border-radius: 10px;
    }
    .how-card-details {
      opacity: var(--open);
      max-height: var(--detail-height);
      transform: translateY(var(--detail-y));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .how-card,
    .how-card-ico,
    .how-card-details {
      transition: none !important;
    }
  }
</style>
