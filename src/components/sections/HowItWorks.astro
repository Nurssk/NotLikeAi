---
const steps = [
  {
    title: "Read the page",
    detail: "Design Humanizer scans the visible structure of your interface.",
    bullets: ["sections and cards", "buttons and CTAs", "spacing and repeated patterns"],
    icon: "scan",
  },
  {
    title: "Find what feels generic",
    detail: "It detects the patterns that make AI-generated UI feel unfinished.",
    bullets: ["weak hierarchy", "repeated cards", "unclear visual focus"],
    icon: "find",
  },
  {
    title: "Suggest improvements",
    detail: "It gives practical design recommendations without changing your content.",
    bullets: ["stronger grouping", "better rhythm", "clearer CTA priority"],
    icon: "suggest",
  },
  {
    title: "Preview the result",
    detail: "You compare the same content with a cleaner, more intentional structure.",
    bullets: ["before and after view", "improved composition", "ready-to-apply direction"],
    icon: "preview",
  },
];
---

<section id="how" class="how-it-works-scroll">
  <div class="how-it-works-sticky">
    <div class="how-inner">
      <div class="how-head">
        <span class="lp-label">Process</span>
        <h2 class="how-title">How it works</h2>
        <p class="how-sub">
          Design Humanizer reads your AI-generated page, finds what feels generic, and shows how to make it feel designed.
        </p>
      </div>

      <div class="how-cards" data-how-cards>
        {steps.map((step, i) => (
          <article class:list={["how-card", { "is-active": i === 0 }]} data-how-card tabindex="0" aria-expanded={i === 0 ? "true" : "false"}>
            <div class="how-card-top">
              <span class="how-card-ico" aria-hidden="true">
                {step.icon === "scan" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M3 8V5a2 2 0 0 1 2-2h3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M3 12h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "find" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
                    <path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                )}
                {step.icon === "suggest" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M9 18h6M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  </svg>
                )}
                {step.icon === "preview" && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <rect x="3" y="4" width="18" height="16" rx="2.5" stroke="currentColor" stroke-width="1.8"/>
                    <path d="M12 4v16" stroke="currentColor" stroke-width="1.8" stroke-dasharray="2 2.4"/>
                  </svg>
                )}
              </span>
              <span class="how-card-step">{`0${i + 1}`}</span>
            </div>

            <h3 class="how-card-title">{step.title}</h3>

            <div class="how-card-details">
              <p class="how-card-detail">{step.detail}</p>
              <ul class="how-card-bullets">
                {step.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>

      <div class="how-progress" aria-hidden="true">
        {steps.map((_, i) => (
          <span class:list={["how-dot", { "is-active": i === 0 }]} data-how-dot></span>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-how-card]"));
  const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-how-dot]"));
  const mobile = window.matchMedia("(max-width: 768px)");

  function setActiveCard(activeIndex: number) {
    cards.forEach((card, index) => {
      const isActive = index === activeIndex;
      card.classList.toggle("is-active", isActive);
      card.setAttribute("aria-expanded", isActive ? "true" : "false");
    });
    dots.forEach((dot, i) => dot.classList.toggle("is-active", i === activeIndex));
  }

  cards.forEach((card, index) => {
    // Hover (mouse / pen) expands the card and collapses the others.
    // Touch is ignored — on mobile every card is expanded via CSS, so there
    // is no hover dependency there.
    card.addEventListener("pointerenter", (event) => {
      if (event.pointerType === "touch" || mobile.matches) return;
      setActiveCard(index);
    });
    // Keyboard focus mirrors hover so the section works without a mouse.
    card.addEventListener("focusin", () => {
      if (mobile.matches) return;
      setActiveCard(index);
    });
  });

  // First card open by default.
  setActiveCard(0);
</script>

<style>
  /* Normal page content — no scroll-controlled height, no sticky pinning. */
  .how-it-works-scroll {
    position: relative;
    min-height: auto;
    background: var(--bg, #ffffff);
  }

  .how-it-works-sticky {
    position: relative;
    min-height: auto;
  }

  .how-inner {
    width: min(100% - 48px, 1200px);
    margin: 0 auto;
    padding: clamp(64px, 9vh, 120px) 0;
  }

  .how-head {
    max-width: 760px;
    margin: 0 auto clamp(36px, 5vh, 64px);
    text-align: center;
  }

  .how-title {
    margin: 16px 0 0;
    color: var(--text, #101112);
    font-family: var(--font-display, "Montserrat", system-ui, sans-serif);
    font-size: clamp(34px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.015em;
  }

  .how-sub {
    margin: 18px auto 0;
    max-width: 620px;
    color: var(--muted, #5f666a);
    font-size: 17px;
    line-height: 1.6;
  }

  /* ── Cards row: each card driven by its own --expand (0..1) ───────────── */
  .how-cards {
    display: flex;
    gap: 18px;
    align-items: stretch;
  }

  .how-card {
    --expand: 0;
    --detail: 0;
    /* Compact by default; --expand/--detail are flipped to 1 by the
       .is-active class (set on hover / focus), and CSS transitions animate
       the resolved size, opacity, transform, color and shadow. */
    flex: calc(0.9 + var(--expand) * 1.35);
    opacity: calc(0.76 + var(--expand) * 0.24);
    transform: scale(calc(0.975 + var(--expand) * 0.035));
    transform-origin: center bottom;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 320px;
    padding: 26px;
    border-radius: 28px;
    background: var(--card, #ffffff);
    border: 1px solid color-mix(in srgb, var(--border, #e6ecec) calc(100% - var(--expand) * 100%), rgba(0, 245, 212, 0.85) calc(var(--expand) * 100%));
    /* Soft depth that grows with expand */
    box-shadow:
      0 8px 24px rgba(16, 17, 18, 0.04),
      0 calc(var(--expand) * 28px) calc(var(--expand) * 70px) rgba(0, 245, 212, calc(var(--expand) * 0.14));
    overflow: hidden;
    cursor: default;
    transition:
      flex 420ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 260ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 240ms ease,
      box-shadow 240ms ease,
      background 240ms ease;
    will-change: flex-grow, opacity, transform;
  }

  .how-card:focus-visible {
    outline: 2px solid var(--accent, #00f5d4);
    outline-offset: 3px;
  }

  /* Active = hovered / focused card. */
  .how-card.is-active {
    --expand: 1;
    --detail: 1;
  }

  .how-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .how-card-ico {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: calc(44px + var(--expand) * 10px);
    height: calc(44px + var(--expand) * 10px);
    flex: 0 0 auto;
    border-radius: 14px;
    /* Tile fills with accent as --expand grows */
    background: color-mix(in srgb, var(--accent-soft, rgba(0, 245, 212, 0.14)) calc(100% - var(--expand) * 100%), var(--accent, #00f5d4) calc(var(--expand) * 100%));
    border: 1px solid color-mix(in srgb, var(--border, #e6ecec) calc(100% - var(--expand) * 100%), transparent calc(var(--expand) * 100%));
    color: var(--text, #101112);
    transition:
      width 300ms cubic-bezier(0.22, 1, 0.36, 1),
      height 300ms cubic-bezier(0.22, 1, 0.36, 1),
      background 240ms ease,
      border-color 240ms ease;
  }

  .how-card-step {
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.04em;
    /* Faint → strong text color with expand */
    color: color-mix(in srgb, var(--faint, #9aa3a6) calc(100% - var(--expand) * 100%), var(--text, #101112) calc(var(--expand) * 100%));
    transition: color 240ms ease;
  }

  .how-card-title {
    margin: 4px 0 0;
    color: var(--text, #101112);
    font-size: calc(18px + var(--expand) * 4px);
    font-weight: 700;
    line-height: 1.22;
    transition: font-size 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* ── Detail content: revealed via --detail (lags --expand for a premium feel) */
  .how-card-details {
    opacity: var(--detail);
    max-height: calc(var(--detail) * 280px);
    transform: translateY(calc((1 - var(--detail)) * 16px));
    overflow: hidden;
    transition:
      opacity 260ms ease,
      max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 300ms ease;
  }

  .how-card-detail {
    margin: 0 0 14px;
    color: var(--muted, #5f666a);
    font-size: 15px;
    line-height: 1.6;
    max-width: 42ch;
  }

  .how-card-bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .how-card-bullets li {
    position: relative;
    padding-left: 22px;
    color: var(--text, #101112);
    font-size: 14px;
    font-weight: 600;
  }

  .how-card-bullets li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--accent, #00f5d4);
    border: 1px solid rgba(16, 17, 18, 0.12);
  }

  /* ── Progress dots ────────────────────────────────────────────────────── */
  .how-progress {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: clamp(28px, 4vh, 44px);
  }

  .how-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--border, #e6ecec);
    transition: width 360ms ease, background 360ms ease;
  }

  .how-dot.is-active {
    width: 26px;
    background: var(--accent, #00f5d4);
  }

  /* ── Mobile: vertical stack, all details visible, no scroll-driven expand ─ */
  @media (max-width: 768px) {
    .how-it-works-scroll {
      min-height: auto;
    }
    .how-it-works-sticky {
      position: relative;
      min-height: auto;
    }
    .how-cards {
      flex-direction: column;
      gap: 14px;
    }
    .how-card {
      --expand: 1 !important;
      --detail: 1 !important;
      flex: none;
      width: 100%;
      min-height: 0;
      opacity: 1;
      transform: none;
    }
    .how-card-details {
      opacity: 1;
      max-height: none;
      transform: none;
    }
    .how-progress {
      display: none;
    }
  }

  /* ── Reduced motion: static, all cards expanded, no transitions ───────── */
  @media (prefers-reduced-motion: reduce) {
    .how-cards {
      flex-wrap: wrap;
    }
    .how-card {
      --expand: 1 !important;
      --detail: 1 !important;
      flex: 1 1 260px;
      opacity: 1 !important;
      transform: none !important;
    }
    .how-card,
    .how-card-ico,
    .how-card-step,
    .how-card-title,
    .how-card-details {
      transition: none !important;
    }
    .how-card-details {
      opacity: 1 !important;
      max-height: none !important;
      transform: none !important;
    }
    .how-progress {
      display: none;
    }
  }
</style>
