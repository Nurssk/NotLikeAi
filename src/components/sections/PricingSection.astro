---
import RollingButtonText from "../RollingButtonText";

const creditPricing = {
  minCredits: 3,
  maxCredits: 200,
  minAmount: 100,
  maxAmount: 6500,
  defaultCredits: 3,
};

const amountForCredits = (credits: number) => {
  const progress =
    (credits - creditPricing.minCredits) / (creditPricing.maxCredits - creditPricing.minCredits);
  return Math.round(creditPricing.minAmount + progress * (creditPricing.maxAmount - creditPricing.minAmount));
};

const formatAmount = (amount: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: amount % 100 === 0 ? 0 : 2,
  }).format(amount / 100);

const defaultAmount = amountForCredits(creditPricing.defaultCredits);
---

<section id="pricing" class="lp-section pricing-section" aria-labelledby="pricing-title">
  <div class="pricing-shell">
    <div class="pricing-flow" data-pricing-flow data-selected-credits={creditPricing.defaultCredits}>
      <script type="application/json" data-pricing-data set:html={JSON.stringify({ creditPricing })}></script>

      <div class="pricing-flow-view is-active" data-flow-view="plans">
        <div class="pricing-flow-main">
          <div class="pricing-main-copy">
            <h2 id="pricing-title">Buy screenshots</h2>
          </div>

          <div class="pricing-choice-stack">
            <div class="pricing-credit-control">
              <div class="pricing-credit-head">
                <span>Screenshots selected</span>
                <strong><span data-credit-count data-current-value={creditPricing.defaultCredits}>{
                  creditPricing.defaultCredits
                }</span></strong>
              </div>

              <div class="pricing-free-plan" aria-label="Free plan allowance">
                <span>Free plan</span>
                <strong>3 screenshots included</strong>
                <p>Start reviewing your UI before buying more screenshots.</p>
              </div>

              <div class="pricing-credit-inputs" aria-label="Custom screenshot purchase">
                <label class="pricing-credit-input">
                  <span>Screenshots</span>
                  <input
                    type="number"
                    min={creditPricing.minCredits}
                    max={creditPricing.maxCredits}
                    step="1"
                    inputmode="numeric"
                    value={creditPricing.defaultCredits}
                    data-credit-input
                  />
                </label>

                <label class="pricing-credit-input">
                  <span>Budget</span>
                  <div class="pricing-money-input">
                    <span aria-hidden="true">$</span>
                    <input
                      type="number"
                      min={(creditPricing.minAmount / 100).toFixed(2)}
                      max={(creditPricing.maxAmount / 100).toFixed(2)}
                      step="0.01"
                      inputmode="decimal"
                      value={(defaultAmount / 100).toFixed(2)}
                      data-amount-input
                    />
                  </div>
                </label>
              </div>

              <div class="pricing-credit-slider-shell">
                <input
                  class="pricing-credit-range"
                  type="range"
                  min={creditPricing.minCredits}
                  max={creditPricing.maxCredits}
                  step="1"
                  value={creditPricing.defaultCredits}
                  aria-label="Screenshot amount"
                  data-credit-slider
                />
                <div class="pricing-credit-slider-track" aria-hidden="true">
                  <span data-credit-progress></span>
                </div>
                <div class="pricing-credit-balance" aria-hidden="true" data-credit-balance>
                  <span data-credit-balance-value>{creditPricing.defaultCredits}</span>
                </div>
              </div>

              <div class="pricing-credit-bounds">
                <span>{creditPricing.minCredits} screenshots for {formatAmount(creditPricing.minAmount)}</span>
                <span>{creditPricing.maxCredits} screenshots for {formatAmount(creditPricing.maxAmount)}</span>
              </div>
            </div>

            <div class="pricing-summary-card" aria-live="polite">
              <div class="pricing-summary-copy">
                <span>Total today</span>
                <span>one-time purchase</span>
              </div>
              <div class="pricing-summary-count">
                <strong data-credit-price>{formatAmount(defaultAmount)}</strong>
                <span data-credit-rate>
                  {(defaultAmount / creditPricing.defaultCredits / 100).toLocaleString("en-US", {
                    style: "currency",
                    currency: "USD",
                    maximumFractionDigits: 2,
                  })} per screenshot
                </span>
              </div>
            </div>

            <button class="btn btn-primary pricing-buy-button" type="button" data-buy-now>
              <span data-buy-credits-label>
                <RollingButtonText text={`Buy ${creditPricing.defaultCredits} screenshots`} />
              </span>
              <small data-buy-price-label>{formatAmount(defaultAmount)} today</small>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-pricing-flow]").forEach((flow) => {
    const data = JSON.parse(flow.querySelector("[data-pricing-data]")?.textContent || "{}");
    const pricing = data.creditPricing || {};
    const minCredits = Number(pricing.minCredits || 3);
    const maxCredits = Number(pricing.maxCredits || 200);
    const minAmount = Number(pricing.minAmount || 100);
    const maxAmount = Number(pricing.maxAmount || 6500);
    let selectedCredits = Number(flow.getAttribute("data-selected-credits") || pricing.defaultCredits || maxCredits);
    let selectedAmount = 0;
    let selectionMode = "credits";

    const clampCredits = (value) => Math.min(maxCredits, Math.max(minCredits, Math.round(Number(value) || minCredits)));

    const clampAmount = (value) => {
      const amount = Math.round(Number(value) * 100);
      if (!Number.isFinite(amount)) return minAmount;
      return Math.min(maxAmount, Math.max(minAmount, amount));
    };

    const amountForCredits = (credits) => {
      const progress = (credits - minCredits) / (maxCredits - minCredits);
      return Math.round(minAmount + progress * (maxAmount - minAmount));
    };

    const creditsForAmount = (amount) => {
      const progress = (amount - minAmount) / (maxAmount - minAmount);
      return clampCredits(minCredits + progress * (maxCredits - minCredits));
    };

    const formatAmount = (amount) =>
      new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: amount % 100 === 0 ? 0 : 2,
      }).format(amount / 100);

    const formatInputAmount = (amount) => (amount / 100).toFixed(2);

    const escapeHtml = (value) =>
      String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");

    const makeRollingMarkup = (value) => {
      const characters = Array.from(String(value))
        .map((character, index) => {
          const glyph = escapeHtml(character === " " ? "\u00a0" : character);

          return `<span class="rolling-button-text__char" style="--rolling-index: ${index}"><span class="rolling-button-text__track"><span class="rolling-button-text__line">${glyph}</span><span class="rolling-button-text__line">${glyph}</span></span></span>`;
        })
        .join("");

      return `<span class="rolling-button-text__chars" aria-hidden="true">${characters}</span>`;
    };

    const setText = (selector, value) => {
      const node = flow.querySelector(selector);
      if (!node) return;

      const rollingText = node.querySelector(".rolling-button-text");
      if (rollingText) {
        rollingText.setAttribute("aria-label", value);
        rollingText.innerHTML = makeRollingMarkup(value);
        return;
      }

      node.textContent = value;
    };

    const setCreditCount = (value) => {
      const counter = flow.querySelector("[data-credit-count]");
      if (!counter) return;

      const nextValue = clampCredits(value);
      counter.textContent = nextValue.toLocaleString();
      counter.setAttribute("data-current-value", String(nextValue));
    };

    const updatePricingInputs = (credits, amount, source) => {
      const creditInput = flow.querySelector("[data-credit-input]");
      if (creditInput instanceof HTMLInputElement && document.activeElement !== creditInput) {
        creditInput.value = String(credits);
      }

      const amountInput = flow.querySelector("[data-amount-input]");
      if (amountInput instanceof HTMLInputElement && document.activeElement !== amountInput) {
        amountInput.value = formatInputAmount(amount);
      }

      if (source === "amount" && creditInput instanceof HTMLInputElement) {
        creditInput.value = String(credits);
      }
    };

    const updateCreditSelection = (rawValue, source = "credits") => {
      const amount = source === "amount" ? clampAmount(rawValue) : amountForCredits(clampCredits(rawValue));
      const credits = source === "amount" ? creditsForAmount(amount) : clampCredits(rawValue);
      const progress = ((credits - minCredits) / (maxCredits - minCredits)) * 100;
      const rate = amount / credits / 100;

      selectedCredits = credits;
      selectedAmount = amount;
      selectionMode = source;
      flow.dataset.selectedCredits = String(credits);
      flow.dataset.selectedAmount = String(amount);
      flow.dataset.selectionMode = selectionMode;

      const slider = flow.querySelector("[data-credit-slider]");
      if (slider instanceof HTMLInputElement) slider.value = String(credits);

      const progressNode = flow.querySelector("[data-credit-progress]");
      if (progressNode instanceof HTMLElement) progressNode.style.width = `${progress}%`;

      const balanceNode = flow.querySelector("[data-credit-balance]");
      if (balanceNode instanceof HTMLElement) balanceNode.style.left = `${progress}%`;
      setText("[data-credit-balance-value]", credits.toLocaleString());

      updatePricingInputs(credits, amount, source);
      setCreditCount(credits);
      setText("[data-credit-price]", formatAmount(amount));
      setText(
        "[data-credit-rate]",
        `${rate.toLocaleString("en-US", {
          style: "currency",
          currency: "USD",
          maximumFractionDigits: 2,
        })} per screenshot`,
      );
      setText("[data-buy-credits-label]", `Buy ${credits.toLocaleString()} screenshots`);
      setText("[data-buy-price-label]", `${formatAmount(amount)} today`);
    };

    const getCheckoutUrl = () => {
      const href = new URL("/api/checkout", window.location.origin);
      if (selectionMode === "amount") {
        href.searchParams.set("amount", String(selectedAmount));
      } else {
        href.searchParams.set("credits", String(selectedCredits));
      }
      return href.toString();
    };

    const redirectToPolar = () => {
      const buyButton = flow.querySelector("[data-buy-now]");
      if (buyButton instanceof HTMLButtonElement) {
        buyButton.disabled = true;
        setText("[data-buy-credits-label]", "Opening Polar Checkout");
      }

      window.location.href = getCheckoutUrl();
    };

    flow.querySelector("[data-credit-slider]")?.addEventListener("input", (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement) updateCreditSelection(target.value, "credits");
    });

    flow.querySelector("[data-credit-input]")?.addEventListener("input", (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement) updateCreditSelection(target.value, "credits");
    });

    flow.querySelector("[data-credit-input]")?.addEventListener("blur", () => {
      updateCreditSelection(selectedCredits, "credits");
    });

    flow.querySelector("[data-amount-input]")?.addEventListener("input", (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement) updateCreditSelection(target.value, "amount");
    });

    flow.querySelector("[data-amount-input]")?.addEventListener("blur", () => {
      const amountInput = flow.querySelector("[data-amount-input]");
      if (amountInput instanceof HTMLInputElement) amountInput.value = formatInputAmount(selectedAmount);
    });

    flow.querySelector("[data-buy-now]")?.addEventListener("click", redirectToPolar);

    updateCreditSelection(selectedCredits);
  });
</script>
