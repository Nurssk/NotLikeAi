---
const plans = [
  {
    id: "minimal",
    name: "Minimal",
    price: "$10",
    period: "/month",
    screenshots: "50",
    limit: "screenshots per week",
    href: "/api/checkout?plan=minimal",
  },
  {
    id: "popular",
    name: "Popular",
    price: "$25",
    period: "/month",
    screenshots: "200",
    limit: "screenshots per month",
    href: "/api/checkout?plan=popular",
  },
  {
    id: "maximum",
    name: "Maximum",
    price: "$40",
    period: "/month",
    screenshots: "450",
    limit: "screenshots per month",
    href: "/api/checkout?plan=maximum",
  },
];

const features = [
  { label: "AI UI analysis", plans: ["minimal", "popular", "maximum"] },
  { label: "Design improvement suggestions", plans: ["minimal", "popular", "maximum"] },
  { label: "Chrome extension access", plans: ["minimal", "popular", "maximum"] },
  { label: "Priority UI analysis", plans: ["popular", "maximum"] },
  { label: "Multiple projects", plans: ["maximum"] },
  { label: "Extended usage limit", plans: ["maximum"] },
];
---

<section id="pricing" class="lp-section pricing-section" aria-labelledby="pricing-title">
  <div class="pricing-shell">
    <div class="pricing-flow" data-pricing-flow data-selected-plan="popular">
      <script type="application/json" data-pricing-data set:html={JSON.stringify({ plans, features })}></script>

      <div class="pricing-flow-view is-active" data-flow-view="plans">
        <aside class="pricing-flow-left" aria-label="Selected plan details">
          <div class="pricing-benefits-copy">
            <h3>Check out these benefits</h3>
            <p>Attributes update as you switch plans.</p>
          </div>

          <div class="pricing-feature-table">
            <div class="pricing-feature-head">
              <span>Attributes</span>
              <strong>Included</strong>
            </div>

            {
              features.map((feature) => (
                <div class="pricing-feature-row" data-feature-row data-available={feature.plans.join(" ")}>
                  <span>{feature.label}</span>
                  <span class="pricing-feature-check" data-feature-check aria-hidden="true"></span>
                </div>
              ))
            }
          </div>
        </aside>

        <div class="pricing-flow-main">
          <div class="pricing-main-copy">
            <h2 id="pricing-title">Choose your plan</h2>
          </div>

          <div class="pricing-choice-stack">
            <div class="pricing-choice-list" role="group" aria-label="Pricing plans">
              {
                plans.map((plan) => (
                  <button
                    class:list={["pricing-choice", { "is-selected": plan.id === "popular" }]}
                    type="button"
                    data-plan-choice
                    data-plan-id={plan.id}
                    aria-pressed={plan.id === "popular" ? "true" : "false"}
                  >
                    <span class="pricing-choice-radio" aria-hidden="true"></span>
                    <span class="pricing-choice-name">{plan.name}</span>
                    <span class="pricing-choice-price">{plan.price}<small>{plan.period}</small></span>
                  </button>
                ))
              }
            </div>

            <div class="pricing-summary-card" aria-live="polite">
              <div class="pricing-summary-copy">
                <span>Screenshots</span>
                <span>included</span>
              </div>
              <div class="pricing-summary-count">
                <strong data-screenshot-count data-current-value="0">0</strong>
                <span data-screenshot-limit>screenshots per month</span>
              </div>
            </div>

            <button class="btn btn-primary pricing-buy-button" type="button" data-buy-now>
              Buy Now
            </button>
          </div>
        </div>
      </div>

      <div class="pricing-flow-view pricing-checkout-view" data-flow-view="checkout" aria-hidden="true">
        <aside class="checkout-summary">
          <button class="checkout-back" type="button" data-back-to-plans aria-label="Back to plan selection">
            ×
          </button>
          <div class="checkout-product">
            <div class="checkout-product-icon" aria-hidden="true">DH</div>
            <div>
              <h3><span data-checkout-plan-name>Minimal</span> plan</h3>
              <p data-checkout-plan-limit>Monthly subscription</p>
            </div>
          </div>

          <div class="checkout-lines">
            <div>
              <span>Subtotal</span>
              <strong data-checkout-price>$10</strong>
            </div>
            <div>
              <span>Billed now</span>
              <strong data-checkout-price-repeat>$10</strong>
            </div>
          </div>

          <p class="checkout-secure">Discount codes and billing details are handled in Polar Checkout.</p>
        </aside>

        <div class="checkout-form">
          <h3>Log in before payment</h3>
          <p class="checkout-note">
            Use the email you want to connect to Chrome extension credits. New accounts must verify email before payment.
          </p>

          <div class="checkout-auth-panel" data-auth-panel>
            <div class="checkout-auth-switch" role="tablist" aria-label="Account action">
              <button class="is-active" type="button" data-auth-mode="login" aria-pressed="true">Log in</button>
              <button type="button" data-auth-mode="register" aria-pressed="false">Register</button>
            </div>

            <form class="checkout-auth-form" data-auth-form>
              <div class="checkout-field">
                <label for="pricing-email">Email for credits</label>
                <input
                  id="pricing-email"
                  type="email"
                  autocomplete="email"
                  placeholder="you@gmail.com"
                  required
                />
              </div>

              <div class="checkout-field checkout-password-field">
                <label for="pricing-password">Password</label>
                <input
                  id="pricing-password"
                  type="password"
                  autocomplete="current-password"
                  minlength="6"
                  placeholder="6 characters minimum"
                  required
                />
              </div>

              <button class="btn btn-primary checkout-upgrade" type="submit" data-checkout-submit>
                Pay Now
              </button>
            </form>

            <p class="checkout-auth-message" data-auth-message aria-live="polite">
              Log in or register with email and password. Verification is required before payment.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-pricing-flow]").forEach((flow) => {
    const data = JSON.parse(flow.querySelector("[data-pricing-data]")?.textContent || "{}");
    const plans = data.plans || [];
    const planMap = new Map(plans.map((plan) => [plan.id, plan]));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let selectedPlanId = flow.getAttribute("data-selected-plan") || plans[0]?.id || "popular";
    let authMode = "login";
    let authUser = null;
    let authLoading = false;
    let authModulePromise = null;
    let authUnsubscribe = null;
    let screenshotAnimationFrame = 0;

    const setText = (selector, value) => {
      const node = flow.querySelector(selector);
      if (node) node.textContent = value;
    };

    const setScreenshotCount = (value) => {
      const counter = flow.querySelector("[data-screenshot-count]");
      if (!counter) return;

      const nextValue = Math.max(0, Math.round(value));
      counter.textContent = nextValue.toLocaleString();
      counter.setAttribute("data-current-value", String(nextValue));
    };

    const animateScreenshotCount = (plan) => {
      const counter = flow.querySelector("[data-screenshot-count]");
      const target = Number(plan.screenshots);
      if (!counter || Number.isNaN(target)) return;

      const limit = flow.querySelector("[data-screenshot-limit]");
      if (limit) limit.textContent = plan.limit;

      window.cancelAnimationFrame(screenshotAnimationFrame);

      const currentValue = Number(counter.getAttribute("data-current-value") || counter.textContent || "0");
      if (reduceMotion || currentValue === target) {
        setScreenshotCount(target);
        return;
      }

      const startValue = Number.isNaN(currentValue) ? 0 : currentValue;
      const distance = target - startValue;
      const duration = Math.min(1000, Math.max(620, Math.abs(distance) * 2.2));
      const startTime = window.performance.now();
      const easeOutCubic = (value) => 1 - Math.pow(1 - value, 3);

      const tick = (time) => {
        const progress = Math.min((time - startTime) / duration, 1);
        const eased = easeOutCubic(progress);
        setScreenshotCount(startValue + distance * eased);

        if (progress < 1) {
          screenshotAnimationFrame = window.requestAnimationFrame(tick);
        } else {
          setScreenshotCount(target);
        }
      };

      screenshotAnimationFrame = window.requestAnimationFrame(tick);
    };

    const updateFeatureChecks = (planId) => {
      flow.querySelectorAll("[data-feature-row]").forEach((row) => {
        const availablePlans = (row.getAttribute("data-available") || "").split(" ");
        const isAvailable = availablePlans.includes(planId);
        const check = row.querySelector("[data-feature-check]");

        row.classList.toggle("is-muted", !isAvailable);
        if (check) {
          check.classList.toggle("is-off", !isAvailable);
        }
      });
    };

    const setChoiceImpact = (choice, event) => {
      if (!(choice instanceof HTMLElement)) return;

      const rect = choice.getBoundingClientRect();
      let x = rect.width / 2;
      let y = rect.height / 2;

      if (event instanceof MouseEvent && event.detail !== 0) {
        x = event.clientX - rect.left;
        y = event.clientY - rect.top;
      }

      const radius = Math.hypot(Math.max(x, rect.width - x), Math.max(y, rect.height - y));
      choice.style.setProperty("--ripple-x", `${x}px`);
      choice.style.setProperty("--ripple-y", `${y}px`);
      choice.style.setProperty("--ripple-size", `${Math.ceil(radius * 2)}px`);
    };

    const selectPlan = (planId, event) => {
      const plan = planMap.get(planId);
      if (!plan) return;

      selectedPlanId = planId;
      flow.dataset.selectedPlan = planId;

      flow.querySelectorAll("[data-plan-choice]").forEach((choice) => {
        const isSelected = choice.getAttribute("data-plan-id") === planId;
        if (isSelected && event instanceof MouseEvent && choice.getAttribute("aria-pressed") !== "true") {
          setChoiceImpact(choice, event);
        }
        choice.classList.toggle("is-selected", isSelected);
        choice.setAttribute("aria-pressed", String(isSelected));
      });

      animateScreenshotCount(plan);
      setText("[data-checkout-plan-name]", plan.name);
      setText("[data-checkout-plan-limit]", "Monthly subscription");
      setText("[data-checkout-price]", plan.price);
      setText("[data-checkout-price-repeat]", plan.price);

      updateFeatureChecks(planId);
    };

    const setAuthMessage = (message, isError = false) => {
      const messageNode = flow.querySelector("[data-auth-message]");
      if (!messageNode) return;
      messageNode.textContent = message;
      messageNode.classList.toggle("is-error", isError);
    };

    const setAuthLoading = (isLoading) => {
      authLoading = isLoading;
      flow.querySelectorAll("[data-auth-form] button").forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = isLoading;
        }
      });
    };

    const getCheckoutUrl = (email) => {
      const plan = planMap.get(selectedPlanId);
      const href = new URL(plan?.href || "/api/checkout?plan=popular", window.location.origin);
      href.searchParams.set("email", email.trim().toLowerCase());
      return href.toString();
    };

    const redirectToPolar = (email) => {
      window.location.href = getCheckoutUrl(email);
    };

    const setSubmitLabel = (label) => {
      const submit = flow.querySelector("[data-checkout-submit]");
      if (submit) submit.textContent = label;
    };

    const sendVerification = async (user, sendEmailVerification) => {
      await sendEmailVerification(user);
    };

    const updateAuthState = () => {
      const emailInput = flow.querySelector("#pricing-email");
      const passwordInput = flow.querySelector("#pricing-password");
      const isAuthenticated = Boolean(authUser?.email);
      const isVerified = Boolean(authUser?.emailVerified);

      flow.classList.toggle("is-authenticated", isAuthenticated);
      flow.classList.toggle("is-email-verified", isVerified);

      if (emailInput instanceof HTMLInputElement && authUser?.email) {
        emailInput.value = authUser.email;
      }

      if (passwordInput instanceof HTMLInputElement) {
        passwordInput.required = !isAuthenticated;
      }

      if (authUser?.email) {
        setSubmitLabel(isVerified ? "Pay Now" : "Send verification email");
        setAuthMessage(
          isVerified
            ? `Email verified. Click Pay Now to continue to Polar.`
            : `Signed in as ${authUser.email}. Verify this email before payment.`,
        );
      } else {
        setSubmitLabel(authMode === "register" ? "Create account" : "Pay Now");
        setAuthMessage(
          authMode === "register"
            ? "Create your account. We will send a verification email before payment."
            : "Log in with a verified email to continue to Polar.",
        );
      }
    };

    const setAuthMode = (mode) => {
      authMode = mode;
      flow.querySelectorAll("[data-auth-mode]").forEach((button) => {
        const isActive = button.getAttribute("data-auth-mode") === mode;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });

      const passwordInput = flow.querySelector("#pricing-password");
      if (passwordInput instanceof HTMLInputElement) {
        passwordInput.autocomplete = mode === "register" ? "new-password" : "current-password";
      }

      setSubmitLabel(mode === "register" ? "Create account" : "Pay Now");
      setAuthMessage(
        mode === "register"
          ? "Create your account. We will email you a verification link before payment."
          : "Log in with a verified email to continue to Polar.",
      );
    };

    const authErrorMessage = (error) => {
      const code = typeof error === "object" && error && "code" in error ? error.code : "";
      if (code === "auth/email-already-in-use") return "This email already has an account. Switch to Log in.";
      if (
        code === "auth/invalid-credential" ||
        code === "auth/invalid-login-credentials" ||
        code === "auth/user-not-found" ||
        code === "auth/wrong-password"
      ) {
        return "No matching account found or password is incorrect. Switch to Register if this is your first time.";
      }
      if (code === "auth/weak-password") return "Use a password with at least 6 characters.";
      if (code === "auth/too-many-requests") return "Too many attempts. Wait a moment and try again.";
      if (code === "auth/invalid-email") return "Enter a valid email address.";
      if (code === "auth/missing-password") return "Enter a password.";
      if (code === "auth/user-disabled") return "This account is disabled.";
      if (code === "auth/operation-not-allowed") return "This sign-in method is disabled in Firebase Authentication.";
      if (code === "auth/unauthorized-domain") return "This domain is not allowed in Firebase Authentication settings.";
      if (code === "auth/unauthorized-continue-uri") return "Firebase is not allowed to use this verification redirect domain.";
      if (code === "auth/invalid-continue-uri") return "Firebase email verification redirect URL is invalid.";
      if (code === "auth/network-request-failed") return "Network error while contacting Firebase. Please try again.";
      if (code === "auth/api-key-not-valid") return "Firebase API key is not valid for this project.";
      return code ? `Authentication failed: ${code.replace("auth/", "")}.` : "Authentication failed. Please try again.";
    };

    const authLoadErrorMessage = () => "Authentication could not load. Refresh the page and try again.";

    const loadAuthModule = () => {
      if (!authModulePromise) {
        authModulePromise = Promise.all([import("firebase/auth"), import("../../lib/firebase")])
          .then(([firebaseAuth, firebase]) => ({
            createUserWithEmailAndPassword: firebaseAuth.createUserWithEmailAndPassword,
            onAuthStateChanged: firebaseAuth.onAuthStateChanged,
            sendEmailVerification: firebaseAuth.sendEmailVerification,
            signOut: firebaseAuth.signOut,
            signInWithEmailAndPassword: firebaseAuth.signInWithEmailAndPassword,
            auth: firebase.auth,
          }))
          .catch((error) => {
            authModulePromise = null;
            throw error;
          });
      }

      return authModulePromise;
    };

    const ensureAuthState = async () => {
      if (authUnsubscribe) return;

      try {
        const { auth, onAuthStateChanged } = await loadAuthModule();
        authUnsubscribe = onAuthStateChanged(auth, (user) => {
          authUser = user;
          updateAuthState();
        });
      } catch (error) {
        setAuthMessage(authLoadErrorMessage(), true);
      }
    };

    const showCheckout = () => {
      flow.classList.add("is-checkout");
      flow.querySelector("[data-flow-view='plans']")?.setAttribute("aria-hidden", "true");
      flow.querySelector("[data-flow-view='checkout']")?.setAttribute("aria-hidden", "false");
      flow.querySelector("[data-flow-view='checkout']")?.classList.add("is-active");
      flow.querySelector("[data-flow-view='plans']")?.classList.remove("is-active");
      flow.querySelector("#pricing-email")?.focus();
      updateAuthState();
      void ensureAuthState();
    };

    const showPlans = () => {
      flow.classList.remove("is-checkout");
      flow.querySelector("[data-flow-view='plans']")?.setAttribute("aria-hidden", "false");
      flow.querySelector("[data-flow-view='checkout']")?.setAttribute("aria-hidden", "true");
      flow.querySelector("[data-flow-view='plans']")?.classList.add("is-active");
      flow.querySelector("[data-flow-view='checkout']")?.classList.remove("is-active");
    };

    flow.querySelectorAll("[data-plan-choice]").forEach((choice) => {
      choice.addEventListener("click", (event) => {
        const nextPlanId = choice.getAttribute("data-plan-id") || selectedPlanId;
        if (nextPlanId === selectedPlanId) return;
        selectPlan(nextPlanId, event);
      });
    });

    flow.querySelector("[data-buy-now]")?.addEventListener("click", showCheckout);
    flow.querySelector("[data-back-to-plans]")?.addEventListener("click", showPlans);
    flow.querySelectorAll("[data-auth-mode]").forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.getAttribute("data-auth-mode");
        if (mode === "login" || mode === "register") {
          setAuthMode(mode);
        }
      });
    });

    flow.querySelector("[data-auth-form]")?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (authLoading) return;
      const emailInput = flow.querySelector("#pricing-email");
      const passwordInput = flow.querySelector("#pricing-password");
      if (!(emailInput instanceof HTMLInputElement)) return;

      const email = emailInput.value.trim().toLowerCase();
      if (!email || !emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
      }

      if (!(passwordInput instanceof HTMLInputElement) || !passwordInput.checkValidity()) {
        passwordInput?.reportValidity();
        return;
      }

      setAuthLoading(true);
      setAuthMessage(authMode === "register" ? "Creating account..." : "Logging in...");

      try {
        const { auth, createUserWithEmailAndPassword, sendEmailVerification, signInWithEmailAndPassword, signOut } =
          await loadAuthModule();
        await ensureAuthState();

        if (auth.currentUser?.email) {
          await auth.currentUser.reload();
          const currentUser = auth.currentUser;
          authUser = currentUser;
          const currentEmail = currentUser?.email?.toLowerCase();

          if (currentUser && currentEmail !== email) {
            await signOut(auth);
            authUser = null;
          } else if (currentUser?.emailVerified) {
            redirectToPolar(currentUser.email);
            return;
          } else if (currentUser) {
            await sendVerification(currentUser, sendEmailVerification);
            setAuthMessage("Verification email sent. Check your inbox and spam folder, then log in again to continue.");
            return;
          }
        }

        let result;
        let reusedExistingAccount = false;
        try {
          result = authMode === "register"
            ? await createUserWithEmailAndPassword(auth, email, passwordInput.value)
            : await signInWithEmailAndPassword(auth, email, passwordInput.value);
        } catch (error) {
          const code = typeof error === "object" && error && "code" in error ? error.code : "";

          if (authMode === "register" && code === "auth/email-already-in-use") {
            reusedExistingAccount = true;
            result = await signInWithEmailAndPassword(auth, email, passwordInput.value);
          } else {
            throw error;
          }
        }

        if (!result.user.email) {
          setAuthMessage("Account does not have an email address.", true);
        } else if (authMode === "register") {
          await sendVerification(result.user, sendEmailVerification);
          setAuthMessage(
            reusedExistingAccount
              ? "Account already exists. Verification email sent again. Check your inbox and spam folder."
              : "Account created. Verification email sent. Check your inbox and spam folder.",
          );
        } else if (result.user.emailVerified) {
          redirectToPolar(result.user.email);
        } else {
          await sendVerification(result.user, sendEmailVerification);
          setAuthMessage("Email is not verified yet. We sent a new verification link to your inbox.", true);
        }
      } catch (error) {
        setAuthMessage(authErrorMessage(error), true);
      } finally {
        setAuthLoading(false);
      }
    });

    selectPlan(selectedPlanId);
  });
</script>
