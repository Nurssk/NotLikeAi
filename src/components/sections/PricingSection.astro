---
const creditPricing = {
  minCredits: 3,
  maxCredits: 200,
  minAmount: 100,
  maxAmount: 6500,
  defaultCredits: 200,
};

const amountForCredits = (credits: number) => {
  const progress =
    (credits - creditPricing.minCredits) / (creditPricing.maxCredits - creditPricing.minCredits);
  return Math.round(creditPricing.minAmount + progress * (creditPricing.maxAmount - creditPricing.minAmount));
};

const formatAmount = (amount: number) =>
  new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: amount % 100 === 0 ? 0 : 2,
  }).format(amount / 100);

const defaultAmount = amountForCredits(creditPricing.defaultCredits);
---

<section id="pricing" class="lp-section pricing-section" aria-labelledby="pricing-title">
  <div class="pricing-shell">
    <div class="pricing-flow" data-pricing-flow data-selected-credits={creditPricing.defaultCredits}>
      <script type="application/json" data-pricing-data set:html={JSON.stringify({ creditPricing })}></script>

      <div class="pricing-flow-view is-active" data-flow-view="plans">
        <div class="pricing-flow-main">
          <div class="pricing-main-copy">
            <h2 id="pricing-title">Buy credits</h2>
          </div>

          <div class="pricing-choice-stack">
            <div class="pricing-credit-control">
              <div class="pricing-credit-head">
                <span>Credits selected</span>
                <strong><span data-credit-count data-current-value={creditPricing.defaultCredits}>{
                  creditPricing.defaultCredits
                }</span></strong>
              </div>

              <div class="pricing-credit-slider-shell">
                <input
                  class="pricing-credit-range"
                  type="range"
                  min={creditPricing.minCredits}
                  max={creditPricing.maxCredits}
                  step="1"
                  value={creditPricing.defaultCredits}
                  aria-label="Credit amount"
                  data-credit-slider
                />
                <div class="pricing-credit-slider-track" aria-hidden="true">
                  <span data-credit-progress></span>
                </div>
                <div class="pricing-credit-balance" aria-hidden="true" data-credit-balance>
                  <span data-credit-balance-value>{creditPricing.defaultCredits}</span>
                </div>
              </div>

              <div class="pricing-credit-bounds">
                <span>{creditPricing.minCredits} credits for {formatAmount(creditPricing.minAmount)}</span>
                <span>{creditPricing.maxCredits} credits for {formatAmount(creditPricing.maxAmount)}</span>
              </div>
            </div>

            <div class="pricing-summary-card" aria-live="polite">
              <div class="pricing-summary-copy">
                <span>Total today</span>
                <span>one-time purchase</span>
              </div>
              <div class="pricing-summary-count">
                <strong data-credit-price>{formatAmount(defaultAmount)}</strong>
                <span data-credit-rate>
                  {(defaultAmount / creditPricing.defaultCredits / 100).toLocaleString("en-US", {
                    style: "currency",
                    currency: "USD",
                    maximumFractionDigits: 2,
                  })} per credit
                </span>
              </div>
            </div>

            <button class="btn btn-primary pricing-buy-button" type="button" data-buy-now>
              <span data-buy-credits-label>Buy {creditPricing.defaultCredits} credits</span>
              <small data-buy-price-label>{formatAmount(defaultAmount)} today</small>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  document.querySelectorAll("[data-pricing-flow]").forEach((flow) => {
    const data = JSON.parse(flow.querySelector("[data-pricing-data]")?.textContent || "{}");
    const pricing = data.creditPricing || {};
    const minCredits = Number(pricing.minCredits || 3);
    const maxCredits = Number(pricing.maxCredits || 200);
    const minAmount = Number(pricing.minAmount || 100);
    const maxAmount = Number(pricing.maxAmount || 6500);
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let selectedCredits = Number(flow.getAttribute("data-selected-credits") || pricing.defaultCredits || maxCredits);
    let creditAnimationFrame = 0;

    const clampCredits = (value) => Math.min(maxCredits, Math.max(minCredits, Math.round(Number(value) || minCredits)));

    const amountForCredits = (credits) => {
      const progress = (credits - minCredits) / (maxCredits - minCredits);
      return Math.round(minAmount + progress * (maxAmount - minAmount));
    };

    const formatAmount = (amount) =>
      new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
        maximumFractionDigits: amount % 100 === 0 ? 0 : 2,
      }).format(amount / 100);

    const setText = (selector, value) => {
      const node = flow.querySelector(selector);
      if (node) node.textContent = value;
    };

    const setCreditCount = (value) => {
      const counter = flow.querySelector("[data-credit-count]");
      if (!counter) return;

      const nextValue = clampCredits(value);
      counter.textContent = nextValue.toLocaleString();
      counter.setAttribute("data-current-value", String(nextValue));
    };

    const animateCreditCount = (credits) => {
      const counter = flow.querySelector("[data-credit-count]");
      if (!counter) return;

      window.cancelAnimationFrame(creditAnimationFrame);

      const currentValue = Number(counter.getAttribute("data-current-value") || counter.textContent || minCredits);
      if (reduceMotion || currentValue === credits) {
        setCreditCount(credits);
        return;
      }

      const startValue = Number.isNaN(currentValue) ? minCredits : currentValue;
      const distance = credits - startValue;
      const duration = Math.min(760, Math.max(260, Math.abs(distance) * 5));
      const startTime = window.performance.now();
      const easeOutCubic = (value) => 1 - Math.pow(1 - value, 3);

      const tick = (time) => {
        const progress = Math.min((time - startTime) / duration, 1);
        const eased = easeOutCubic(progress);
        setCreditCount(startValue + distance * eased);

        if (progress < 1) {
          creditAnimationFrame = window.requestAnimationFrame(tick);
        } else {
          setCreditCount(credits);
        }
      };

      creditAnimationFrame = window.requestAnimationFrame(tick);
    };

    const updateCreditSelection = (rawCredits) => {
      const credits = clampCredits(rawCredits);
      const amount = amountForCredits(credits);
      const progress = ((credits - minCredits) / (maxCredits - minCredits)) * 100;
      const rate = amount / credits / 100;

      selectedCredits = credits;
      flow.dataset.selectedCredits = String(credits);

      const slider = flow.querySelector("[data-credit-slider]");
      if (slider instanceof HTMLInputElement) slider.value = String(credits);

      const progressNode = flow.querySelector("[data-credit-progress]");
      if (progressNode instanceof HTMLElement) progressNode.style.width = `${progress}%`;

      const balanceNode = flow.querySelector("[data-credit-balance]");
      if (balanceNode instanceof HTMLElement) balanceNode.style.left = `${progress}%`;
      setText("[data-credit-balance-value]", credits.toLocaleString());

      animateCreditCount(credits);
      setText("[data-credit-price]", formatAmount(amount));
      setText(
        "[data-credit-rate]",
        `${rate.toLocaleString("en-US", {
          style: "currency",
          currency: "USD",
          maximumFractionDigits: 2,
        })} per credit`,
      );
      setText("[data-buy-credits-label]", `Buy ${credits.toLocaleString()} credits`);
      setText("[data-buy-price-label]", `${formatAmount(amount)} today`);
    };

    const getCheckoutUrl = () => {
      const href = new URL("/api/checkout", window.location.origin);
      href.searchParams.set("credits", String(selectedCredits));
      return href.toString();
    };

    const redirectToPolar = () => {
      const buyButton = flow.querySelector("[data-buy-now]");
      if (buyButton instanceof HTMLButtonElement) {
        buyButton.disabled = true;
        setText("[data-buy-credits-label]", "Opening Polar Checkout");
      }

      window.location.href = getCheckoutUrl();
    };

    flow.querySelector("[data-credit-slider]")?.addEventListener("input", (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement) updateCreditSelection(target.value);
    });

    flow.querySelector("[data-buy-now]")?.addEventListener("click", redirectToPolar);

    updateCreditSelection(selectedCredits);
  });
</script>
