---
const features = [
  {
    icon: "masonry",
    title: "Visual hierarchy",
    description: "Adds clear hierarchy so the most important content stands out.",
  },
  {
    icon: "layout",
    title: "Layout structure",
    description: "Improves page structure with intentional sections and balanced columns.",
  },
  {
    icon: "align",
    title: "Spacing and alignment",
    description: "Applies consistent spacing so every layout feels intentional.",
  },
  {
    icon: "cards",
    title: "Card variation",
    description: "Breaks repetitive layouts with richer card sizes and emphasis.",
  },
  {
    icon: "preserve",
    title: "Content preservation",
    description: "Keeps your existing copy and structure while improving visual polish.",
  },
  {
    icon: "preview",
    title: "Developer-friendly preview",
    description: "Preview the improved layout before applying or exporting it.",
  },
];
---

<section id="features" class="section">
  <div class="container">
    <div class="section-intro center">
      <p class="section-kicker muted">Features</p>
      <h2>What Design Humanizer improves</h2>
    </div>

    <div class="features-grid">
      {features.map((feature) => (
        <article class="feature-card hover-soft">
          <div class="feature-icon">
            {feature.icon === "masonry" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="2" width="6" height="9" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="10" y="2" width="6" height="5" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="10" y="9" width="6" height="7" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="2" y="13" width="6" height="3" rx="2" stroke="currentColor" stroke-width="1.5" />
              </svg>
            )}
            {feature.icon === "layout" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="2" width="14" height="5" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="2" y="9" width="6" height="7" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="10" y="9" width="6" height="7" rx="2" stroke="currentColor" stroke-width="1.5" />
              </svg>
            )}
            {feature.icon === "align" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <line x1="4" y1="9" x2="14" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <line x1="4" y1="5" x2="14" y2="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <line x1="4" y1="13" x2="14" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <circle cx="9" cy="9" r="2" fill="currentColor" />
              </svg>
            )}
            {feature.icon === "cards" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="2" width="7" height="7" rx="2" stroke="currentColor" stroke-width="1.5" />
                <rect x="11" y="2" width="5" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                <rect x="2" y="11" width="5" height="5" rx="1.5" stroke="currentColor" stroke-width="1.5" />
                <rect x="9" y="11" width="7" height="5" rx="2" stroke="currentColor" stroke-width="1.5" />
              </svg>
            )}
            {feature.icon === "preserve" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 3L15 9L9 15L3 9L9 3Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <path d="M9 7V11M7 9H11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
              </svg>
            )}
            {feature.icon === "preview" && (
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <rect x="2" y="4" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5" />
                <path d="M6 9H8.5L10 7L11.5 11L13 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            )}
          </div>
          <div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
