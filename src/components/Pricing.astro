---
import { CTA_URL } from "../consts";
import LandingRays from "./LandingRays.astro";
---

<section id="pricing" class="relative overflow-hidden">
  <LandingRays
    side="left"
    width="min(78vw, 900px)"
    offset="14%"
    opacity={0.5}
    intensity={1.2}
    spread={1.95}
    falloff={1.62}
    speed={1.28}
    blend={0.5}
  />
  <div class="relative z-10 mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
    <h2
      data-reveal
      class="max-w-3xl text-3xl font-bold leading-tight tracking-tight sm:text-5xl"
    >
      Pay only for the screenshots you review
    </h2>
    <p
      data-reveal
      style="--reveal-delay: 0.1s"
      class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-70"
    >
      Choose the number of screenshots you need. One screenshot equals one
      complete UI analysis.
    </p>

    <div data-reveal style="--reveal-delay: 0.15s" class="mt-12 border border-rule p-8 sm:p-12">
      <!-- Price + count display -->
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <span class="text-sm font-semibold text-muted">Pay as you go</span>
          <div class="mt-3 flex items-baseline gap-2">
            <span class="text-3xl font-bold text-ink/60">$</span>
            <input
              id="price-input"
              type="number"
              min="1"
              max="65"
              value="1"
              class="w-32 max-w-full border-0 bg-transparent text-6xl font-bold leading-none tracking-tight outline-none focus:outline-none sm:w-40 sm:text-7xl"
              aria-label="Price in dollars"
            />
            <span class="text-lg text-ink/60">one-time</span>
          </div>
          <p id="per-display" class="mt-2 font-mono text-xs text-muted">~$0.33 each</p>
        </div>
        <div class="text-right">
          <div class="flex items-baseline justify-end gap-4">
            <input
              id="count-input"
              type="number"
              min="3"
              max="200"
              value="3"
              class="w-36 max-w-full border-0 bg-transparent text-6xl font-bold leading-none tracking-tight text-right outline-none focus:outline-none sm:w-44 sm:text-7xl"
              aria-label="Number of screenshots"
            />
            <span class="text-lg text-ink/60">screenshots</span>
          </div>
        </div>
      </div>

      <!-- Slider -->
      <div class="mt-10">
        <input
          id="screenshot-slider"
          type="range"
          min="3"
          max="200"
          value="3"
          step="1"
          class="w-full cursor-pointer appearance-none bg-transparent"
          aria-label="Number of screenshots"
        />
        <div class="mt-2 flex justify-between font-mono text-xs text-muted">
          <span>3</span>
          <span>50</span>
          <span>100</span>
          <span>150</span>
          <span>200</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
        <a
          href="/api/checkout?credits=3"
          id="buy-btn"
          class="inline-flex min-h-12 items-center justify-center bg-ink px-8 text-base font-medium text-paper transition-opacity duration-150 hover:opacity-80"
        >
          Buy 3 screenshots for $1
        </a>
        <p class="text-sm text-ink/60">One-time purchase. No subscription.</p>
      </div>
    </div>

    <!-- Free tier note -->
    <div data-reveal style="--reveal-delay: 0.2s" class="mt-6 border border-rule p-6 sm:flex sm:items-center sm:justify-between">
      <div>
        <span class="text-sm font-semibold text-muted">Free</span>
        <p class="mt-1 text-base text-ink-70">
          3 screenshots included. Start reviewing your UI before buying more.
        </p>
      </div>
      <a
        href={CTA_URL}
        class="mt-4 inline-flex min-h-11 items-center justify-center border border-ink px-6 text-sm font-medium text-ink transition-colors duration-150 hover:bg-ink hover:text-paper sm:mt-0"
      >
        Start free
      </a>
    </div>
  </div>
</section>

<style>
  #screenshot-slider {
    height: 2px;
    background: var(--color-rule);
    border-radius: 0;
  }
  #screenshot-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    background: var(--color-ink);
    border-radius: 9999px;
    cursor: pointer;
    border: 2px solid var(--color-paper);
    transition: transform 0.15s ease;
  }
  #screenshot-slider::-webkit-slider-thumb:hover {
    transform: scale(1.15);
  }
  #screenshot-slider::-moz-range-thumb {
    width: 20px;
    height: 20px;
    background: var(--color-ink);
    border-radius: 9999px;
    cursor: pointer;
    border: 2px solid var(--color-paper);
  }
  #screenshot-slider::-moz-range-track {
    height: 2px;
    background: var(--color-rule);
  }

  #price-input::-webkit-outer-spin-button,
  #price-input::-webkit-inner-spin-button,
  #count-input::-webkit-outer-spin-button,
  #count-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #price-input,
  #count-input {
    -moz-appearance: textfield;
    appearance: textfield;
  }
</style>

<script>
  const slider = document.getElementById("screenshot-slider") as HTMLInputElement;
  const countInput = document.getElementById("count-input") as HTMLInputElement;
  const priceInput = document.getElementById("price-input") as HTMLInputElement;
  const perDisplay = document.getElementById("per-display");
  const buyBtn = document.getElementById("buy-btn");

  const MIN_COUNT = 3;
  const MAX_COUNT = 200;
  const MIN_PRICE = 1;
  const MAX_PRICE = 65;

  function calcPrice(count: number): number {
    if (count <= MIN_COUNT) return MIN_PRICE;
    if (count >= MAX_COUNT) return MAX_PRICE;
    const ratio = (count - MIN_COUNT) / (MAX_COUNT - MIN_COUNT);
    return Math.round(MIN_PRICE + ratio * (MAX_PRICE - MIN_PRICE));
  }

  function calcCount(price: number): number {
    if (price <= MIN_PRICE) return MIN_COUNT;
    if (price >= MAX_PRICE) return MAX_COUNT;
    const ratio = (price - MIN_PRICE) / (MAX_PRICE - MIN_PRICE);
    return Math.round(MIN_COUNT + ratio * (MAX_COUNT - MIN_COUNT));
  }

  function updateDisplays(count: number, price: number) {
    const per = (price / count).toFixed(2);
    perDisplay!.textContent = `~$${per} each`;
    buyBtn!.textContent = `Buy ${count} screenshot${count === 1 ? "" : "s"} for $${price}`;
    // Carry the chosen screenshot count into the checkout route; the server
    // resolves the authoritative price so the charge always matches the count.
    (buyBtn as HTMLAnchorElement).href = `/api/checkout?credits=${count}`;
  }

  function fromSlider() {
    let count = parseInt(slider.value) || MIN_COUNT;
    count = Math.max(MIN_COUNT, Math.min(MAX_COUNT, count));
    const price = calcPrice(count);
    countInput.value = String(count);
    priceInput.value = String(price);
    updateDisplays(count, price);
  }

  function fromCount() {
    let count = parseInt(countInput.value) || MIN_COUNT;
    count = Math.max(MIN_COUNT, Math.min(MAX_COUNT, count));
    const price = calcPrice(count);
    slider.value = String(count);
    priceInput.value = String(price);
    updateDisplays(count, price);
  }

  function fromPrice() {
    let price = parseInt(priceInput.value) || MIN_PRICE;
    price = Math.max(MIN_PRICE, Math.min(MAX_PRICE, price));
    const count = calcCount(price);
    slider.value = String(count);
    countInput.value = String(count);
    updateDisplays(count, price);
  }

  slider.addEventListener("input", fromSlider);
  countInput.addEventListener("input", fromCount);
  priceInput.addEventListener("input", fromPrice);
  updateDisplays(MIN_COUNT, MIN_PRICE);
</script>
