---
import { CTA_URL } from "../consts";

const links = [
  { label: "How it works", href: "#how-it-works" },
  { label: "Pricing", href: "#pricing" },
  { label: "FAQ", href: "/faq" },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-40 border-b border-rule bg-paper"
>
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8"
  >
    <a href="#top" class="text-lg font-bold tracking-tight">BeUniq</a>

    <nav class="hidden items-center gap-8 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="text-sm text-muted transition-colors duration-150 hover:text-ink"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:block">
      <a
        href={CTA_URL}
        class="inline-flex min-h-11 items-center bg-ink px-4 py-2 text-sm font-medium text-paper transition-opacity duration-150 hover:opacity-80"
      >
        Analyze your first screen
      </a>
    </div>

    <button
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      class="inline-flex size-11 items-center justify-center md:hidden"
    >
      <span
        class="block h-px w-5 bg-ink shadow-[0_6px_0_0_var(--color-ink),0_-6px_0_0_var(--color-ink)]"
      ></span>
    </button>
  </div>

  <div id="nav-menu" class="hidden border-t border-rule bg-paper md:hidden">
    <nav class="mx-auto flex max-w-6xl flex-col px-5 py-2 sm:px-8">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="flex min-h-11 items-center border-b border-rule text-sm text-ink last:border-b-0"
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={CTA_URL}
        class="mt-3 mb-2 inline-flex min-h-11 items-center justify-center bg-ink px-4 text-sm font-medium text-paper"
      >
        Analyze your first screen
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Open menu");
    })
  );

  // Hidden over the hero, slides in once the hero is scrolled past.
  // Only in animated contexts — no-JS/static/reduced-motion keep a fixed,
  // always-visible header so navigation never depends on scripting.
  const nav = document.getElementById("site-nav");
  const hero = document.getElementById("top");
  if (nav && hero && "IntersectionObserver" in window) {
    nav.classList.add("nav-auto");
    new IntersectionObserver(
      ([entry]) => {
        nav.classList.toggle("nav-shown", !entry.isIntersecting);
      },
      { rootMargin: "-64px 0px 0px 0px" }
    ).observe(hero);
  }
</script>

<style>
  :global(.js-anim) .nav-auto {
    transform: translateY(-100%);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :global(.js-anim) .nav-auto.nav-shown {
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-auto {
      transition: none;
    }
  }
</style>
