---
const steps = [
  {
    name: "Read",
    text: "Understands the page structure, sections, cards, hierarchy, and repeated patterns.",
  },
  {
    name: "Judge",
    text: "Finds where the interface feels flat, overloaded, repetitive, or unclear.",
  },
  {
    name: "Recompose",
    text: "Suggests a layout with stronger priority, rhythm, and visual intent.",
  },
];
---

<section id="thinking" class="section thinking-section">
  <div class="container">
    <div class="section-intro center">
      <p class="section-kicker accent">Thinking model</p>
      <h2>How Design Humanizer thinks</h2>
    </div>

    <div class="thinking-diagram">
      {steps.map((step, index) => (
        <article class="thinking-step">
          <div class="thinking-index">0{index + 1}</div>
          <h3>{step.name}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>

    <div class="judgment-strip" aria-label="Design judgment sequence">
      <span>structure</span>
      <i></i>
      <span>priority</span>
      <i></i>
      <span>rhythm</span>
      <i></i>
      <span>intent</span>
    </div>
  </div>
</section>
