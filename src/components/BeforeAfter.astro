---
const beforeItems = ["six equal cards", "no anchor element", "weak primary action", "same spacing everywhere"];
const afterItems = ["one dominant card", "grouped secondary content", "clearer CTA", "stronger reading path"];
const flatItems = Array.from({ length: 6 });
const groupedItems = Array.from({ length: 3 });
---

<section id="breakdown" class="section breakdown-section">
  <div class="container">
    <div class="section-intro center comparison-intro">
      <p class="section-kicker muted">Breakdown</p>
      <h2>From generated layout to designed composition</h2>
    </div>

    <div class="breakdown-grid">
      <article class="breakdown-panel">
        <div class="breakdown-copy">
          <strong class="tag before">Before</strong>
          <ul>
            {beforeItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="annotated-frame before-frame">
          <span class="annotation note-a">equal weight</span>
          <span class="annotation note-b">where do I look?</span>
          <div class="repetitive-grid compact">
            {flatItems.map(() => (
              <div>
                <span class="skeleton-icon"></span>
                <span class="skeleton-line w70"></span>
                <span class="skeleton-line pale"></span>
              </div>
            ))}
          </div>
        </div>
      </article>

      <article class="breakdown-panel emphasized">
        <div class="breakdown-copy">
          <strong class="tag after">After</strong>
          <ul>
            {afterItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="annotated-frame after-frame">
          <span class="annotation note-c">anchor element</span>
          <span class="annotation note-d">clear action</span>
          <div class="dominant-card">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="grouped-content">
            {groupedItems.map(() => (
              <div>
                <span></span>
                <span></span>
              </div>
            ))}
          </div>
          <div class="cta-wire"></div>
        </div>
      </article>
    </div>
  </div>
</section>
