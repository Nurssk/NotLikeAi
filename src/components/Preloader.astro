<div class="site-preloader" data-preloader aria-live="polite" aria-label="Loading beuniq.design">
  <div class="preloader-lockup" aria-hidden="true">
    <img class="preloader-logo" src="/logo/icon-d.svg" alt="" width="56" height="56" />
    <div class="preloader-wordmark">
      <span class="preloader-bracket preloader-bracket--left">[</span>
      <span class="preloader-name">beuniq.design</span>
      <span class="preloader-bracket preloader-bracket--right">]</span>
    </div>
  </div>

  <div class="preloader-progress" aria-hidden="true">
    <span class="preloader-progress-fill" data-preloader-bar></span>
    <span class="preloader-progress-count" data-preloader-count>1%</span>
  </div>
</div>

<script>
  const preloader = document.querySelector<HTMLElement>("[data-preloader]");
  const progressBar = document.querySelector<HTMLElement>("[data-preloader-bar]");
  const progressCount = document.querySelector<HTMLElement>("[data-preloader-count]");

  if (preloader && progressBar && progressCount) {
    const html = document.documentElement;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const startedAt = window.performance.now();
    const minVisibleMs = reduceMotion ? 240 : 1450;
    const maxWaitMs = 7600;
    const criticalImages = [
      "/logo/icon-d.svg",
      "/images/peeps/all-peeps.png",
      "/images/peeps/peeps.png",
      "/images/peeps/wink_peep.png",
    ];
    let progress = 1;
    let rafId = 0;
    let isCompleting = false;

    html.classList.add("is-preloading");

    const renderProgress = (value: number) => {
      const normalized = Math.min(100, Math.max(1, Math.round(value)));
      progressBar.style.transform = `scaleX(${normalized / 100})`;
      progressCount.textContent = `${normalized}%`;
    };

    const loop = () => {
      if (isCompleting) return;

      progress += (92 - progress) * 0.024;
      renderProgress(progress);
      rafId = window.requestAnimationFrame(loop);
    };

    const timeout = (ms: number) =>
      new Promise<void>((resolve) => window.setTimeout(resolve, ms));

    const waitForWindowLoad = () =>
      document.readyState === "complete"
        ? Promise.resolve()
        : new Promise<void>((resolve) => window.addEventListener("load", () => resolve(), { once: true }));

    const waitForFonts = () => {
      if (!("fonts" in document)) return Promise.resolve();
      return Promise.race([document.fonts.ready.then(() => undefined), timeout(2200)]);
    };

    const waitForImage = (src: string) =>
      new Promise<void>((resolve) => {
        const image = new Image();
        image.decoding = "async";
        image.onload = () => resolve();
        image.onerror = () => resolve();
        image.src = src;

        if (image.complete) resolve();
      });

    const waitForEvent = (eventName: string, ms: number) =>
      new Promise<void>((resolve) => {
        let settled = false;
        const done = () => {
          if (settled) return;
          settled = true;
          window.removeEventListener(eventName, done);
          resolve();
        };

        window.addEventListener(eventName, done, { once: true });
        window.setTimeout(done, ms);
      });

    const waitForNextPaint = () =>
      new Promise<void>((resolve) => {
        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => resolve());
        });
      });

    const waitForCriticalAssets = () =>
      Promise.race([
        Promise.all([
          waitForWindowLoad(),
          waitForFonts(),
          ...criticalImages.map(waitForImage),
          waitForEvent("hero:crowd-ready", 4800),
          waitForEvent("waitlist:morph-ready", 4800),
        ]).then(() => waitForNextPaint()),
        timeout(maxWaitMs),
      ]);

    const finish = () => {
      if (isCompleting) return;

      isCompleting = true;
      window.cancelAnimationFrame(rafId);

      const elapsed = window.performance.now() - startedAt;
      const wait = Math.max(0, minVisibleMs - elapsed);

      window.setTimeout(() => {
        const duration = reduceMotion ? 120 : 620;
        const finishStartedAt = window.performance.now();
        const start = progress;

        const tick = (time: number) => {
          const t = Math.min((time - finishStartedAt) / duration, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          renderProgress(start + (100 - start) * eased);

          if (t < 1) {
            window.requestAnimationFrame(tick);
            return;
          }

          preloader.classList.add("is-done");
          html.classList.remove("is-preloading");
          window.setTimeout(() => preloader.remove(), reduceMotion ? 140 : 760);
        };

        window.requestAnimationFrame(tick);
      }, wait);
    };

    renderProgress(progress);
    rafId = window.requestAnimationFrame(loop);
    waitForCriticalAssets().then(finish);
  }
</script>
