{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/checkout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/credits/consume/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/credits/me/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/extension-auth/code/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/extension-auth/exchange/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/polar/webhook/?$",
			"dest": "_render"
		},
		{
			"src": "^/extension/authorize/?$",
			"dest": "_render"
		},
		{
			"src": "^/extension/code/?$",
			"dest": "_render"
		},
		{
			"src": "^/faq/?$",
			"dest": "_render"
		},
		{
			"src": "^/majd-style/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		}
	]
}