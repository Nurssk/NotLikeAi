---
import "../../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import AmplitudeAnalytics from "../../components/AmplitudeAnalytics.astro";

const pageTitle = "Authorize Chrome Extension | BeUniq Design";
const pageDescription =
  "Authorize the BeUniq Design Chrome extension with a short one-time code.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/logo/icon-d.svg" />
    <link rel="apple-touch-icon" href="/logo/app-icon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700;800;900&family=Inter+Tight:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class="extension-authorize-body">
    <main class="extension-authorize-page" data-extension-authorize>
      <section class="extension-authorize-shell" aria-labelledby="extension-authorize-title">
        <aside class="extension-authorize-summary" aria-label="Extension authorization summary">
          <div class="extension-authorize-logo">
            <img src="/logo/icon-d-light.svg" alt="BeUniq Design" />
          </div>

          <div>
            <h1 id="extension-authorize-title">Authorize extension</h1>
            <p>
              Sign in with Google or verify your email, then copy the one-time code into the Chrome extension.
            </p>
          </div>

          <div class="extension-authorize-steps" aria-label="Authorization steps">
            <div>
              <span>1</span>
              <strong>Log in on the website</strong>
              <p>Google and email sign-in stay in the browser where they work normally.</p>
            </div>
            <div>
              <span>2</span>
              <strong>Use the short code</strong>
              <p>Codes expire in 10 minutes and can only be exchanged once.</p>
            </div>
          </div>
        </aside>

        <div class="extension-authorize-card" data-authorize-card>
          <div class="extension-authorize-card-head">
            <h2 data-auth-heading>Log in</h2>
            <p data-auth-subtitle>Access the account you want to connect to the Chrome extension.</p>
          </div>

          <button class="extension-google-button" type="button" data-google-auth>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09Z"></path>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"></path>
              <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84Z"></path>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.3 9.14 5.38 12 5.38Z"></path>
            </svg>
            <span>Continue with Google</span>
          </button>

          <div class="extension-auth-divider" role="separator">
            <span>or use email</span>
          </div>

          <div class="extension-auth-switch" role="tablist" aria-label="Account action">
            <button class="is-active" type="button" data-auth-mode="login" aria-pressed="true">Log in</button>
            <button type="button" data-auth-mode="register" aria-pressed="false">Register</button>
          </div>

          <form class="extension-auth-form" data-auth-form>
            <div class="extension-auth-field">
              <label for="extension-email">Email</label>
              <input
                id="extension-email"
                type="email"
                autocomplete="email"
                placeholder="you@gmail.com"
                required
              />
            </div>

            <div class="extension-auth-field">
              <label for="extension-password">Password</label>
              <input
                id="extension-password"
                type="password"
                autocomplete="current-password"
                minlength="6"
                placeholder="6 characters minimum"
                required
              />
            </div>

            <button class="btn btn-primary extension-auth-submit" type="submit" data-auth-submit>
              Log in
            </button>
            <button class="extension-forgot-button" type="button" data-forgot-password>
              Forgot password?
            </button>
          </form>

          <p class="extension-auth-message" data-auth-message aria-live="polite">
            Log in or register with email and password. Verification is required before generating a code.
          </p>
        </div>
      </section>
    </main>
    <AmplitudeAnalytics />
    <Analytics />
  </body>
</html>

<style>
  .extension-authorize-body {
    min-height: 100vh;
  }

  .extension-authorize-page {
    min-height: 100vh;
    display: grid;
    align-items: center;
    padding: clamp(22px, 5vw, 56px);
  }

  .extension-authorize-shell {
    width: min(100%, 980px);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(360px, 1fr);
    overflow: hidden;
    border-radius: 18px;
    background: rgba(250, 247, 243, 0.76);
    box-shadow: 0 2px 8px rgba(16, 17, 18, 0.08);
  }

  .extension-authorize-summary,
  .extension-authorize-card {
    min-width: 0;
    padding: clamp(28px, 4.6vw, 44px);
  }

  .extension-authorize-summary {
    display: flex;
    flex-direction: column;
    gap: 28px;
    background: rgba(238, 231, 219, 0.78);
  }

  .extension-authorize-logo {
    display: inline-flex;
    width: 58px;
    height: 58px;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: var(--accent);
  }

  .extension-authorize-logo img {
    width: 36px;
    height: 36px;
    object-fit: contain;
  }

  .extension-authorize-summary h1,
  .extension-authorize-card h2 {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 1.02;
  }

  .extension-authorize-summary h1 {
    max-width: 440px;
    font-size: clamp(34px, 5vw, 56px);
  }

  .extension-authorize-summary p,
  .extension-authorize-card-head p,
  .extension-authorize-steps p {
    color: var(--muted);
    font-weight: 700;
    line-height: 1.48;
  }

  .extension-authorize-summary > div > p {
    max-width: 430px;
    margin: 18px 0 0;
    font-size: 17px;
  }

  .extension-authorize-steps {
    display: grid;
    gap: 14px;
    margin-top: auto;
  }

  .extension-authorize-steps div {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    gap: 4px 12px;
    align-items: start;
    padding: 16px 0 0;
    border-top: 1px solid rgba(16, 17, 18, 0.1);
  }

  .extension-authorize-steps span {
    display: inline-flex;
    width: 24px;
    height: 24px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: var(--accent);
    color: var(--on-accent);
    font-size: 12px;
    font-weight: 900;
  }

  .extension-authorize-steps strong {
    color: var(--text);
    font-size: 15px;
    font-weight: 800;
  }

  .extension-authorize-steps p {
    grid-column: 2 / 3;
    margin: 0;
    font-size: 13px;
  }

  .extension-authorize-card {
    display: grid;
    align-content: center;
    gap: 16px;
    background: rgba(250, 247, 243, 0.86);
  }

  .extension-authorize-card h2 {
    font-size: clamp(26px, 3vw, 34px);
  }

  .extension-authorize-card-head p {
    margin: 10px 0 0;
    font-size: 15px;
  }

  .extension-google-button,
  .extension-auth-submit,
  .extension-forgot-button {
    width: 100%;
    min-height: 54px;
    border-radius: 10px;
    font: inherit;
    font-size: 16px;
    font-weight: 800;
  }

  .extension-google-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border: 1px solid rgba(16, 17, 18, 0.12);
    background: rgba(255, 255, 255, 0.8);
    color: var(--text);
    cursor: pointer;
    transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
  }

  .extension-google-button:hover {
    border-color: rgba(16, 17, 18, 0.28);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 2px 8px rgba(16, 17, 18, 0.08);
  }

  .extension-google-button svg {
    width: 20px;
    height: 20px;
    flex: 0 0 auto;
  }

  .extension-auth-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .extension-auth-divider::before,
  .extension-auth-divider::after {
    content: "";
    height: 1px;
    flex: 1 1 auto;
    background: rgba(16, 17, 18, 0.1);
  }

  .extension-auth-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 4px;
    padding: 4px;
    border-radius: 12px;
    background: rgba(16, 17, 18, 0.06);
  }

  .extension-auth-switch button {
    min-height: 44px;
    border: 0;
    border-radius: 10px;
    background: transparent;
    color: var(--text);
    cursor: pointer;
    font: inherit;
    font-size: 14px;
    font-weight: 800;
  }

  .extension-auth-switch button.is-active {
    background: #111111;
    color: #ffffff;
  }

  .extension-auth-form {
    display: grid;
    gap: 14px;
  }

  .extension-auth-field {
    display: grid;
    gap: 8px;
  }

  .extension-auth-field label {
    color: var(--text);
    font-size: 15px;
    font-weight: 800;
  }

  .extension-auth-field input {
    width: 100%;
    min-height: 50px;
    border: 1px solid rgba(16, 17, 18, 0.12);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    font: inherit;
    font-size: 16px;
    padding: 0 16px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
  }

  .extension-auth-field input:focus {
    border-color: rgba(16, 17, 18, 0.42);
    outline: 0;
    box-shadow: 0 0 0 3px rgba(16, 17, 18, 0.08);
  }

  .extension-forgot-button {
    min-height: 44px;
    border: 1px solid rgba(16, 17, 18, 0.12);
    background: rgba(255, 255, 255, 0.78);
    color: var(--text);
    cursor: pointer;
  }

  .extension-auth-message {
    min-height: 40px;
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.45;
  }

  .extension-auth-message.is-error {
    color: #B42318;
  }

  .extension-auth-message.is-success {
    color: #147A3F;
  }

  .extension-google-button:disabled,
  .extension-auth-switch button:disabled,
  .extension-auth-submit:disabled,
  .extension-forgot-button:disabled {
    cursor: wait;
    opacity: 0.64;
  }

  @media (max-width: 780px) {
    .extension-authorize-page {
      align-items: start;
      padding: 18px;
    }

    .extension-authorize-shell {
      grid-template-columns: 1fr;
      border-radius: 14px;
    }

    .extension-authorize-summary,
    .extension-authorize-card {
      padding: 28px 22px;
    }

    .extension-authorize-summary {
      gap: 22px;
    }

    .extension-authorize-summary h1 {
      font-size: clamp(31px, 12vw, 44px);
    }

    .extension-authorize-summary > div > p {
      font-size: 15px;
    }

  }
</style>

<script>
  const authPage = document.querySelector("[data-extension-authorize]");

  if (authPage) {
    const heading = authPage.querySelector("[data-auth-heading]");
    const subtitle = authPage.querySelector("[data-auth-subtitle]");
    const messageNode = authPage.querySelector("[data-auth-message]");
    const emailInput = authPage.querySelector("#extension-email");
    const passwordInput = authPage.querySelector("#extension-password");
    const submitButton = authPage.querySelector("[data-auth-submit]");
    const googleButton = authPage.querySelector("[data-google-auth]");
    const forgotPasswordButton = authPage.querySelector("[data-forgot-password]");
    let authMode = "login";
    let authUser = null;
    let authLoading = false;
    let authModulePromise = null;
    let authUnsubscribe = null;
    let isRedirecting = false;
    const codePagePath = "/extension/code";

    const setMessage = (message, tone = "neutral") => {
      if (!messageNode) return;
      messageNode.textContent = message;
      messageNode.classList.toggle("is-error", tone === "error");
      messageNode.classList.toggle("is-success", tone === "success");
    };

    const setLoading = (isLoading) => {
      authLoading = isLoading;
      authPage.querySelectorAll("button").forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.disabled = isLoading;
        }
      });
    };

    const setSubmitLabel = (label) => {
      if (submitButton) submitButton.textContent = label;
    };

    const redirectToCodePage = () => {
      if (isRedirecting) return;
      isRedirecting = true;
      window.location.assign(codePagePath);
    };

    const ensureFreeCredits = async (user) => {
      if (!user?.getIdToken) return;

      try {
        const token = await user.getIdToken();
        await fetch("/api/credits/me", {
          headers: {
            Authorization: `Bearer ${token}`,
          },
        });
      } catch {
        // Credits are also initialized by the credits API when the extension reads them.
      }
    };

    const authErrorMessage = (error) => {
      const code = typeof error === "object" && error && "code" in error ? error.code : "";
      if (code === "auth/email-already-in-use") return "This email already has an account. Switch to Log in.";
      if (
        code === "auth/invalid-credential" ||
        code === "auth/invalid-login-credentials" ||
        code === "auth/user-not-found" ||
        code === "auth/wrong-password"
      ) {
        return "No matching account found or password is incorrect. Switch to Register if this is your first time.";
      }
      if (code === "auth/weak-password") return "Use a password with at least 6 characters.";
      if (code === "auth/too-many-requests") return "Too many attempts. Wait a moment and try again.";
      if (code === "auth/invalid-email") return "Enter a valid email address.";
      if (code === "auth/missing-email") return "Enter your email address.";
      if (code === "auth/missing-password") return "Enter a password.";
      if (code === "auth/user-disabled") return "This account is disabled.";
      if (code === "auth/popup-closed-by-user") return "Google sign-in was closed before it finished.";
      if (code === "auth/cancelled-popup-request") return "Google sign-in was cancelled because another popup opened.";
      if (code === "auth/popup-blocked") return "The browser blocked Google sign-in. Allow popups and try again.";
      if (code === "auth/operation-not-allowed") return "This sign-in method is disabled in Firebase Authentication.";
      if (code === "auth/unauthorized-domain") return "This domain is not allowed in Firebase Authentication settings.";
      if (code === "auth/network-request-failed") return "Network error while contacting Firebase. Please try again.";
      if (code === "auth/api-key-not-valid") return "Firebase API key is not valid for this project.";
      return code ? `Authentication failed: ${code.replace("auth/", "")}.` : "Authentication failed. Please try again.";
    };

    const loadAuthModule = () => {
      if (!authModulePromise) {
        authModulePromise = Promise.all([import("firebase/auth"), import("../../lib/firebase")])
          .then(([firebaseAuth, firebase]) => ({
            createUserWithEmailAndPassword: firebaseAuth.createUserWithEmailAndPassword,
            GoogleAuthProvider: firebaseAuth.GoogleAuthProvider,
            onAuthStateChanged: firebaseAuth.onAuthStateChanged,
            sendPasswordResetEmail: firebaseAuth.sendPasswordResetEmail,
            sendEmailVerification: firebaseAuth.sendEmailVerification,
            signInWithEmailAndPassword: firebaseAuth.signInWithEmailAndPassword,
            signInWithPopup: firebaseAuth.signInWithPopup,
            signOut: firebaseAuth.signOut,
            auth: firebase.auth,
          }))
          .catch((error) => {
            authModulePromise = null;
            throw error;
          });
      }

      return authModulePromise;
    };

    const updateAuthState = () => {
      const isAuthenticated = Boolean(authUser?.email);
      const isVerified = Boolean(authUser?.emailVerified);

      if (emailInput instanceof HTMLInputElement && authUser?.email) {
        emailInput.value = authUser.email;
      }

      if (passwordInput instanceof HTMLInputElement) {
        passwordInput.required = !isAuthenticated;
      }

      if (authUser?.email) {
        if (isVerified) {
          if (heading) heading.textContent = "Redirecting";
          if (subtitle) subtitle.textContent = "Generating your Chrome extension code...";
          setSubmitLabel("Signed in");
          setMessage(`Signed in as ${authUser.email}. Redirecting to your code...`, "success");
          redirectToCodePage();
          return;
        }

        if (heading) heading.textContent = "Verify email";
        if (subtitle) {
          subtitle.textContent = "Check your inbox before generating a Chrome extension code.";
        }
        setSubmitLabel("Send verification email");
        setMessage(
          `Signed in as ${authUser.email}. Verify this email before generating a code.`,
          "neutral",
        );
      } else {
        if (heading) heading.textContent = authMode === "register" ? "Create account" : "Log in";
        if (subtitle) {
          subtitle.textContent =
            authMode === "register"
              ? "Create the account you want to connect to the Chrome extension."
              : "Access the account you want to connect to the Chrome extension.";
        }
        setSubmitLabel(authMode === "register" ? "Create account" : "Log in");
        setMessage(
          authMode === "register"
            ? "Create your account. We will email you a verification link before generating a code."
            : "Log in with a verified email or continue with Google.",
        );
      }
    };

    const ensureAuthState = async () => {
      if (authUnsubscribe) return;

      try {
        const { auth, onAuthStateChanged } = await loadAuthModule();
        authUnsubscribe = onAuthStateChanged(auth, (user) => {
          authUser = user;
          updateAuthState();
        });
      } catch {
        setMessage("Authentication could not load. Refresh the page and try again.", "error");
      }
    };

    const setAuthMode = (mode) => {
      authMode = mode;
      authPage.querySelectorAll("[data-auth-mode]").forEach((button) => {
        const isActive = button.getAttribute("data-auth-mode") === mode;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });

      if (passwordInput instanceof HTMLInputElement) {
        passwordInput.autocomplete = mode === "register" ? "new-password" : "current-password";
      }

      updateAuthState();
    };

    authPage.querySelectorAll("[data-auth-mode]").forEach((button) => {
      button.addEventListener("click", () => {
        const mode = button.getAttribute("data-auth-mode");
        if (mode === "login" || mode === "register") {
          setAuthMode(mode);
        }
      });
    });

    googleButton?.addEventListener("click", async () => {
      if (authLoading) return;
      setLoading(true);
      setMessage("Opening Google sign-in...");

      try {
        const { auth, GoogleAuthProvider, signInWithPopup } = await loadAuthModule();
        await ensureAuthState();
        const provider = new GoogleAuthProvider();
        provider.setCustomParameters({ prompt: "select_account" });
        const result = await signInWithPopup(auth, provider);
        authUser = result.user;
        await ensureFreeCredits(result.user);
        if (result.user.emailVerified) {
          redirectToCodePage();
        } else {
          setMessage(`Signed in as ${result.user.email}. Verify this email before generating a code.`);
        }
      } catch (error) {
        setMessage(authErrorMessage(error), "error");
      } finally {
        setLoading(false);
        updateAuthState();
      }
    });

    forgotPasswordButton?.addEventListener("click", async () => {
      if (authLoading) return;
      if (!(emailInput instanceof HTMLInputElement)) return;

      const email = emailInput.value.trim().toLowerCase();
      if (!email || !emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
      }

      setLoading(true);
      setMessage("Sending password reset email...");

      try {
        const { auth, sendPasswordResetEmail } = await loadAuthModule();
        await sendPasswordResetEmail(auth, email);
        setMessage("Password reset email sent. Check your inbox and spam folder.", "success");
      } catch (error) {
        setMessage(authErrorMessage(error), "error");
      } finally {
        setLoading(false);
        updateAuthState();
      }
    });

    authPage.querySelector("[data-auth-form]")?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (authLoading) return;

      if (!(emailInput instanceof HTMLInputElement)) return;
      const email = emailInput.value.trim().toLowerCase();
      if (!email || !emailInput.checkValidity()) {
        emailInput.reportValidity();
        return;
      }

      if (!(passwordInput instanceof HTMLInputElement) || !passwordInput.checkValidity()) {
        passwordInput?.reportValidity();
        return;
      }

      setLoading(true);
      setMessage(authMode === "register" ? "Creating account..." : "Logging in...");

      try {
        const { auth, createUserWithEmailAndPassword, sendEmailVerification, signInWithEmailAndPassword, signOut } =
          await loadAuthModule();
        await ensureAuthState();

        if (auth.currentUser?.email) {
          await auth.currentUser.reload();
          const currentUser = auth.currentUser;
          authUser = currentUser;
          const currentEmail = currentUser?.email?.toLowerCase();

          if (currentUser && currentEmail !== email) {
            await signOut(auth);
            authUser = null;
          } else if (currentUser?.emailVerified) {
            await ensureFreeCredits(currentUser);
            redirectToCodePage();
            return;
          } else if (currentUser) {
            await ensureFreeCredits(currentUser);
            await sendEmailVerification(currentUser);
            setMessage("Verification email sent. Check your inbox and spam folder, then log in again to continue.");
            return;
          }
        }

        let result;
        let reusedExistingAccount = false;
        try {
          result =
            authMode === "register"
              ? await createUserWithEmailAndPassword(auth, email, passwordInput.value)
              : await signInWithEmailAndPassword(auth, email, passwordInput.value);
        } catch (error) {
          const code = typeof error === "object" && error && "code" in error ? error.code : "";

          if (authMode === "register" && code === "auth/email-already-in-use") {
            reusedExistingAccount = true;
            result = await signInWithEmailAndPassword(auth, email, passwordInput.value);
          } else {
            throw error;
          }
        }

        if (!result.user.email) {
          setMessage("Account does not have an email address.", "error");
        } else if (authMode === "register") {
          await ensureFreeCredits(result.user);
          await sendEmailVerification(result.user);
          setMessage(
            reusedExistingAccount
              ? "Account already exists. Verification email sent again. Check your inbox and spam folder."
              : "Account created. Verification email sent. Check your inbox and spam folder.",
          );
        } else if (result.user.emailVerified) {
          await ensureFreeCredits(result.user);
          redirectToCodePage();
        } else {
          await ensureFreeCredits(result.user);
          await sendEmailVerification(result.user);
          setMessage("Email is not verified yet. We sent a new verification link to your inbox.", "error");
        }
      } catch (error) {
        setMessage(authErrorMessage(error), "error");
      } finally {
        setLoading(false);
        updateAuthState();
      }
    });

    updateAuthState();
    void ensureAuthState();
  }
