# Copy to `.env` for local dev and set the same values in Vercel (Production).
# NEVER commit real secrets. `.env` and `.env.production` are gitignored.

# --- Firebase (client-safe, PUBLIC_ prefix is exposed to the browser) ---
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Polar (server-only) ---
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=1311bb22-3d51-4b85-938a-280870aa88f3
POLAR_WEBHOOK_SECRET=
POLAR_SERVER=production

# --- App ---
NEXT_PUBLIC_APP_URL=https://www.beuniq.design

# --- Firebase Admin (server-only, full service-account JSON on one line) ---
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Extension session signing (server-only) ---
EXTENSION_AUTH_SECRET=
