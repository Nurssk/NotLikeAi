---
import Base from "../../layouts/Base.astro";
import Prism from "../../components/Prism.astro";

export const prerender = false;
---

<Base title="Sign in · BeUniq extension">
  <div class="pointer-events-none absolute inset-0 z-0">
    <Prism
      height={2.5}
      baseWidth={4}
      animationType="rotate"
      glow={1}
      noise={0.1}
      transparent={true}
      scale={3}
      hueShift={0}
      colorFrequency={1}
      timeScale={0.2}
    />
  </div>

  <main class="relative z-10 flex min-h-screen flex-col items-center justify-center px-5">
    <div class="w-full max-w-sm">
      <h1 class="text-center text-6xl font-bold tracking-tight sm:text-8xl">
        BeUniq
      </h1>
      <p class="mt-3 text-center font-mono text-xs text-ink">Connect the Chrome extension</p>

      <div class="mt-8">
        <div class="flex border border-rule" role="tablist">
          <button
            id="tab-login"
            role="tab"
            class="tab flex-1 py-3 text-sm font-medium"
            aria-selected="true"
          >
            Log in
          </button>
          <button
            id="tab-register"
            role="tab"
            class="tab flex-1 border-l border-rule py-3 text-sm font-medium"
            aria-selected="false"
          >
            Register
          </button>
        </div>

        <button
          id="google-btn"
          type="button"
          class="mt-6 inline-flex min-h-12 w-full items-center justify-center gap-2.5 border border-ink px-6 text-sm font-medium text-ink transition-colors duration-150 hover:bg-ink hover:text-paper disabled:opacity-40"
        >
          <svg viewBox="0 0 24 24" class="size-4" aria-hidden="true">
            <path fill="currentColor" d="M12 11v3.2h4.5a3.86 3.86 0 0 1-1.67 2.53v2.1h2.7A8.15 8.15 0 0 0 20 12.2a9.5 9.5 0 0 0-.15-1.7Z"></path>
            <path fill="currentColor" d="M12 20.4c2.25 0 4.14-.74 5.53-2l-2.7-2.1a5.1 5.1 0 0 1-2.83.78 4.98 4.98 0 0 1-4.68-3.44H4.55v2.16A8.4 8.4 0 0 0 12 20.4Z"></path>
            <path fill="currentColor" d="M7.32 13.64a4.97 4.97 0 0 1 0-3.28V8.2H4.55a8.4 8.4 0 0 0 0 7.6Z"></path>
            <path fill="currentColor" d="M12 7.68a4.56 4.56 0 0 1 3.22 1.26l2.4-2.4A8.08 8.08 0 0 0 12 4.4a8.4 8.4 0 0 0-7.45 4.6l2.77 2.16A4.98 4.98 0 0 1 12 7.68Z"></path>
          </svg>
          <span id="google-label">Continue with Google</span>
        </button>

        <div class="my-5 flex items-center gap-3">
          <span class="h-px flex-1 bg-rule"></span>
          <span class="font-mono text-xs text-ink">or with email</span>
          <span class="h-px flex-1 bg-rule"></span>
        </div>

        <form id="auth-form" class="space-y-4" novalidate>
          <label class="block">
            <span class="font-mono text-xs text-ink">Email</span>
            <input
              id="email"
              type="email"
              autocomplete="email"
              required
              class="mt-1.5 w-full border border-rule bg-transparent px-3 py-3 text-sm outline-none transition-colors duration-150 focus:border-ink"
            />
          </label>
          <label class="block">
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-ink">Password</span>
              <button
                id="forgot-btn"
                type="button"
                class="font-mono text-xs text-ink underline underline-offset-4 disabled:opacity-40"
              >
                Forgot password?
              </button>
            </div>
            <input
              id="password"
              type="password"
              autocomplete="current-password"
              minlength="6"
              required
              class="mt-1.5 w-full border border-rule bg-transparent px-3 py-3 text-sm outline-none transition-colors duration-150 focus:border-ink"
            />
          </label>

          <button
            id="submit-btn"
            type="submit"
            class="mt-2 inline-flex min-h-12 w-full items-center justify-center bg-ink px-6 text-sm font-medium text-paper transition-opacity duration-150 hover:opacity-80 disabled:opacity-40"
          >
            Log in
          </button>
        </form>

        <p id="status" class="mt-4 hidden text-sm leading-relaxed" role="status"></p>

        <button
          id="resend-btn"
          type="button"
          class="mt-3 hidden font-mono text-xs text-ink-70 underline underline-offset-4 hover:text-ink disabled:opacity-40"
        >
          Resend verification email
        </button>

        <button
          id="check-verification-btn"
          type="button"
          class="mt-3 hidden font-mono text-xs text-ink-70 underline underline-offset-4 hover:text-ink disabled:opacity-40"
        >
          I verified my email
        </button>
      </div>

      <p class="mt-8 text-center font-mono text-xs text-muted">
        After verifying your email you will get a one-time code to paste into the
        extension.
      </p>
    </div>
  </main>
</Base>

<script>
  import { getFirebaseAuth } from "../../lib/firebase";
  import {
    createUserWithEmailAndPassword,
    GoogleAuthProvider,
    onAuthStateChanged,
    sendEmailVerification,
    sendPasswordResetEmail,
    signInWithEmailAndPassword,
    signInWithPopup,
    type User,
  } from "firebase/auth";

  const auth = getFirebaseAuth();
  const $ = (id: string) => document.getElementById(id)!;
  const emailInput = $("email") as HTMLInputElement;
  const passwordInput = $("password") as HTMLInputElement;
  const submitBtn = $("submit-btn") as HTMLButtonElement;
  const statusEl = $("status") as HTMLParagraphElement;
  const resendBtn = $("resend-btn") as HTMLButtonElement;
  const checkVerificationBtn = $("check-verification-btn") as HTMLButtonElement;
  const tabLogin = $("tab-login") as HTMLButtonElement;
  const tabRegister = $("tab-register") as HTMLButtonElement;
  const form = $("auth-form") as HTMLFormElement;
  const forgotBtn = $("forgot-btn") as HTMLButtonElement;
  const googleBtn = $("google-btn") as HTMLButtonElement;
  const googleLabel = $("google-label") as HTMLSpanElement;

  let mode: "login" | "register" = "login";

  const actionSettings = () => ({
    url: `${window.location.origin}/extension/authorize`,
    handleCodeInApp: false,
  });

  function setStatus(msg: string, kind: "info" | "error" = "info") {
    statusEl.textContent = msg;
    statusEl.classList.remove("hidden");
    statusEl.style.color =
      kind === "error" ? "var(--color-ink)" : "var(--color-ink-70)";
  }

  function hideVerificationActions() {
    resendBtn.classList.add("hidden");
    checkVerificationBtn.classList.add("hidden");
  }

  function showVerificationActions() {
    resendBtn.classList.remove("hidden");
    checkVerificationBtn.classList.remove("hidden");
  }

  function setMode(next: "login" | "register") {
    mode = next;
    const login = next === "login";
    tabLogin.setAttribute("aria-selected", String(login));
    tabRegister.setAttribute("aria-selected", String(!login));
    submitBtn.textContent = login ? "Log in" : "Create account";
    passwordInput.autocomplete = login ? "current-password" : "new-password";
    statusEl.classList.add("hidden");
    hideVerificationActions();
  }

  tabLogin.addEventListener("click", () => setMode("login"));
  tabRegister.addEventListener("click", () => setMode("register"));

  async function goVerifiedOrPrompt(user: User) {
    await user.reload();
    if (user.emailVerified) {
      window.location.assign("/extension/code");
    } else {
      setStatus(
        "Check your inbox and verify your email, then click I verified my email.",
        "info"
      );
      showVerificationActions();
    }
  }

  onAuthStateChanged(auth, (user) => {
    if (!user) return;
    if (user.email) emailInput.value = user.email;
    if (user.emailVerified) {
      window.location.assign("/extension/code");
      return;
    }
    setStatus(
      "Your email is not verified yet. Check your inbox or resend the verification email.",
      "info"
    );
    showVerificationActions();
  });

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim().toLowerCase();
    const password = passwordInput.value;
    if (!email || password.length < 6) {
      setStatus("Enter a valid email and a password of at least 6 characters.", "error");
      return;
    }
    submitBtn.disabled = true;
    submitBtn.textContent = "Please wait…";
    try {
      if (mode === "register") {
        const cred = await createUserWithEmailAndPassword(auth, email, password);
        await sendEmailVerification(cred.user, actionSettings());
        setMode("login");
        emailInput.value = email;
        setStatus(
          "Account created. We sent a verification email. Verify it, then click I verified my email.",
          "info"
        );
        showVerificationActions();
      } else {
        const cred = await signInWithEmailAndPassword(auth, email, password);
        await goVerifiedOrPrompt(cred.user);
      }
    } catch (err: any) {
      const code = err?.code ?? "";
      const msg =
        code === "auth/invalid-credential" || code === "auth/wrong-password"
          ? "Incorrect email or password."
          : code === "auth/email-already-in-use"
            ? "That email already has an account — try logging in."
            : code === "auth/weak-password"
              ? "Password must be at least 6 characters."
              : code === "auth/operation-not-allowed"
                ? "This sign-in method is not enabled yet."
                : "Something went wrong. Please try again.";
      setStatus(msg, "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = mode === "login" ? "Log in" : "Create account";
    }
  });

  resendBtn.addEventListener("click", async () => {
    if (!auth.currentUser) return;
    resendBtn.disabled = true;
    try {
      await sendEmailVerification(auth.currentUser, actionSettings());
      setStatus("Verification email sent again.", "info");
    } catch {
      setStatus("Could not resend right now. Wait a minute and try again.", "error");
    } finally {
      resendBtn.disabled = false;
    }
  });

  checkVerificationBtn.addEventListener("click", async () => {
    const user = auth.currentUser;
    if (!user) {
      setStatus("Log in first, then check verification.", "error");
      return;
    }
    checkVerificationBtn.disabled = true;
    try {
      await goVerifiedOrPrompt(user);
    } finally {
      checkVerificationBtn.disabled = false;
    }
  });

  googleBtn.addEventListener("click", async () => {
    googleBtn.disabled = true;
    googleLabel.textContent = "Please wait…";
    try {
      const provider = new GoogleAuthProvider();
      const cred = await signInWithPopup(auth, provider);
      await goVerifiedOrPrompt(cred.user);
    } catch (err: any) {
      const code = err?.code ?? "";
      if (code === "auth/popup-closed-by-user") return;
      const msg =
        code === "auth/operation-not-allowed"
          ? "Google sign-in is not enabled yet."
          : code === "auth/unauthorized-domain"
            ? "This domain is not authorized for Firebase sign-in."
            : "Google sign-in failed. Please try again.";
      setStatus(msg, "error");
    } finally {
      googleBtn.disabled = false;
      googleLabel.textContent = "Continue with Google";
    }
  });

  forgotBtn.addEventListener("click", async () => {
    const email = emailInput.value.trim().toLowerCase();
    if (!email) {
      setStatus("Enter your email above, then click Forgot password.", "error");
      emailInput.focus();
      return;
    }
    forgotBtn.disabled = true;
    try {
      await sendPasswordResetEmail(auth, email, actionSettings());
      setStatus("Password reset email sent. Check your inbox.", "info");
    } catch (err: any) {
      const code = err?.code ?? "";
      if (code === "auth/user-not-found") {
        setStatus("No account found with that email.", "error");
      } else {
        setStatus("Could not send reset email. Try again later.", "error");
      }
    } finally {
      forgotBtn.disabled = false;
    }
  });
</script>

<style>
  .tab[aria-selected="true"] {
    background: var(--color-ink);
    color: var(--color-paper);
  }
</style>
