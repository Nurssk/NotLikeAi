---
import Base from "../layouts/Base.astro";
import { CTA_URL } from "../consts";

// Purchase confirmation landing. Credits are granted by the Polar webhook,
// not here — this page only confirms the browser returned from checkout.
export const prerender = false;
---

<Base title="Thank you · BeUniq">
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col justify-center px-5 py-24 sm:px-8">
    <span class="font-mono text-xs text-muted">Payment complete</span>
    <h1
      class="mt-4 text-4xl font-bold leading-tight tracking-tight sm:text-6xl"
    >
      Your screenshots are on the way.
    </h1>
    <p class="mt-6 max-w-lg text-lg leading-relaxed text-ink-70">
      We are confirming your purchase with our payment provider. Screenshots are
      added to the account matching your checkout email, usually within a few
      seconds. Open the extension and sign in with that email to use them.
    </p>
    <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
      <a
        href={CTA_URL}
        class="inline-flex min-h-12 items-center justify-center bg-ink px-8 text-base font-medium text-paper transition-opacity duration-150 hover:opacity-80"
      >
        Open the extension
      </a>
      <a
        href="/"
        class="inline-flex min-h-12 items-center text-sm text-ink transition-opacity duration-150 hover:opacity-60"
      >
        <span class="draw-link">Back to home</span>
      </a>
    </div>
    <p class="mt-8 font-mono text-xs text-muted">
      Screenshots not showing up? Wait a moment and refresh the extension, or
      contact support with your checkout email.
    </p>
  </main>
</Base>
