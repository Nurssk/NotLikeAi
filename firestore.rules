rules_version = '2';

// Server code uses the Firebase Admin SDK and bypasses these rules entirely.
// Browser clients may read their own credit doc and create/update their own
// one-time extension code for the website auth flow.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownEmail(normalized) {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email.lower() == normalized;
    }

    function ownVerifiedEmail(normalized) {
      return ownEmail(normalized)
        && request.auth.token.email_verified == true;
    }

    function validExtensionAuthCodeWrite(emailKey) {
      return ownVerifiedEmail(request.resource.data.email)
        && request.resource.data.keys().hasOnly([
          'email',
          'code'
        ])
        && request.resource.data.keys().hasAll([
          'email',
          'code'
        ])
        && request.resource.data.email == request.auth.token.email.lower()
        && request.resource.data.code is string
        && request.resource.data.code.matches('^[A-Z0-9]{6}$');
    }

    // A user may read only their own credit document (matched by the stored
    // normalizedEmail, so no fragile emailKey reconstruction in rules).
    match /customerCredits/{emailKey} {
      allow get: if ownEmail(resource.data.normalizedEmail);
      allow list, create, update, delete: if false;
    }

    // The website may create/update its own verified-user code. The extension
    // still consumes codes through the server API, so browser clients never
    // read or list codes.
    match /extensionAuthCodes/{emailKey} {
      allow create, update: if validExtensionAuthCodeWrite(emailKey);
      allow read, list, delete: if false;
    }

    // Payment webhook audit log — server-only.
    match /polarEvents/{eventId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
