rules_version = '2';

// Design Humanizer — MVP waitlist rules.
//
// Public visitors may ADD/UPDATE their own waitlist entry, but:
//   - reads are DISABLED (so the email list cannot be enumerated);
//   - deletes are DISABLED;
//   - only the expected fields are allowed, and `source` must be "landing".
//
// The frontend writes to: waitlist/{docId}, where docId is the normalized
// email with [.#$[]/ ] replaced by "_". It does NOT read before writing.
//
// Apply in Firebase Console → Firestore Database → Rules → paste → Publish.

service cloud.firestore {
  match /databases/{database}/documents {
    function waitlistFields() {
      return [
        'email',
        'normalizedEmail',
        'source',
        'page',
        'userAgent',
        'createdAt',
        'updatedAt'
      ];
    }

    function isValidWaitlistWrite() {
      return request.resource.data.keys().hasOnly(waitlistFields())
        && request.resource.data.keys().hasAll(waitlistFields())
        && request.resource.data.email is string
        && request.resource.data.normalizedEmail is string
        && request.resource.data.page is string
        && request.resource.data.userAgent is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.source == 'landing'
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 254
        && request.resource.data.normalizedEmail.size() <= 254;
    }

    function hasAuthEmail() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.size() > 3;
    }

    function isOwnCreditDocument(emailKey) {
      return hasAuthEmail()
        && resource.data.keys().hasAll(['normalizedEmail', 'emailKey'])
        && resource.data.normalizedEmail is string
        && resource.data.emailKey is string
        && resource.data.normalizedEmail == request.auth.token.email.lower()
        && resource.data.emailKey == emailKey;
    }

    function extensionAuthCodeFields() {
      return [
        'userId',
        'email',
        'normalizedEmail',
        'codeHash',
        'expiresAt',
        'usedAt',
        'createdAt',
        'source'
      ];
    }

    function isOwnExtensionAuthCodeCreate(codeHash) {
      return hasAuthEmail()
        && request.resource.data.keys().hasOnly(extensionAuthCodeFields())
        && request.resource.data.keys().hasAll(extensionAuthCodeFields())
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.normalizedEmail == request.auth.token.email.lower()
        && request.resource.data.codeHash == codeHash
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.usedAt == null
        && request.resource.data.createdAt is timestamp
        && request.resource.data.source == 'extension-code-page';
    }

    match /waitlist/{docId} {
      // Public landing-page signup only. No authentication is required here.
      // The frontend writes with serverTimestamp(), which evaluates to a
      // timestamp in rules.
      allow create, update: if isValidWaitlistWrite();

      // Never expose the public email list to browser clients.
      allow read, delete: if false;
    }

    // Payment / Polar state must be written only by trusted server code
    // or webhook handlers using an Admin SDK. Browser clients get no access.
    match /polar/{document=**} {
      allow read, write: if false;
    }

    match /payments/{document=**} {
      allow read, write: if false;
    }

    match /subscriptions/{document=**} {
      allow read, write: if false;
    }

    // Paid credits are written only by trusted server/webhook code with the
    // Firebase Admin SDK. A signed-in Chrome extension user may read only the
    // document tied to their Google email.
    match /customerCredits/{emailKey} {
      allow get: if isOwnCreditDocument(emailKey);
      allow list, create, update, delete: if false;
    }

    match /polarEvents/{document=**} {
      allow read, write: if false;
    }

    match /extensionAuthCodes/{codeHash} {
      allow create: if isOwnExtensionAuthCodeCreate(codeHash);
      allow read, update, delete: if false;
    }

    // Keep authenticated user data locked until the app has a concrete
    // account/profile flow. Do not mix auth documents with public waitlist
    // writes.
    match /users/{userId}/{document=**} {
      allow read, write: if false;
    }

    // Everything else stays locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
